    else if (reg_co_flush_sw_en ^ reg_co_flush_sw_en_next)
      reg_co_flush_sw_en <= reg_co_flush_sw_en_next;
  end
  always_ff @(posedge clock_dec) begin
    if (reset_c) reg_co_lock_sw_en <= '0;
    else if (reg_co_lock_sw_en ^ reg_co_lock_sw_en_next)
      reg_co_lock_sw_en <= reg_co_lock_sw_en_next;
  end
  always_ff @(posedge clock_dec) begin
    if (reset_c) reg_co_unlock_sw_en <= '0;
    else if (reg_co_unlock_sw_en ^ reg_co_unlock_sw_en_next)
      reg_co_unlock_sw_en <= reg_co_unlock_sw_en_next;
  end
