    .clk_i (clock_wb),
    .rst_i (reset_w_reg),
    .en_i  (reg_excl_mode_latch_clk_en),
    .d_i   (reg_excl_mode_next),
    .q_o   (reg_excl_mode)
  );
  always_ff @(posedge clock) begin
    reg_mbusaddr[0] <= reg_mbusaddr_next[0];
    reg_mbusaddr[1] <= reg_mbusaddr_next[1];
  end
`ifdef DCACHE_REPORT_PC
  always_ff @(posedge clock) begin
    reg_mbuspc[0] <= reg_mbuspc_next[0];
    reg_mbuspc[1] <= reg_mbuspc_next[1];
  end
`endif
