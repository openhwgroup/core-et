function automatic logic [63:0] tbox_usoc_all_match_pick;
input tbox_usoc_all_t all;
input [6:0] mux_sel;
begin
  logic [29:0] tmp;
  tmp[0] = all.top.address.in_valid; // Valid data is available at the input
