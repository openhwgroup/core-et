  tmp[12] = all.top.l2_reorder_fifo.vaddr_ready; // Driven when new input can be accepted
  tmp[13] = all.top.l2_reorder_fifo.l2_request_valid; // Driven when new data available at the input
  tmp[14] = all.top.l2_reorder_fifo.l2_request_ready; // Valid when new data can be accepted
  tmp[15] = all.top.l2_reorder_fifo.l2_reply_valid; // Valid data is available at the input
  tmp[16] = all.top.decompress.l2_valid; // Valid data is available at the input
  tmp[17] = all.top.decompress.l2_ready; // Driven when new input can be accepted
  tmp[18] = all.top.cache_data.tags_valid; // Valid data is available at the input
  tmp[19] = all.top.cache_data.tags_ready; // Driven when new input can be accepted
  tmp[20] = all.top.cache_data.l2_valid; // Valid data is available at the input
  tmp[21] = all.top.cache_data.l2_ready; // Driven when new input can be accepted
  tmp[22] = all.top.tmux.in_valid; // Valid data is available at the input
  tmp[23] = all.top.tmux.in_ready; // Driven when new input can be accepted
  tmp[24] = all.top.blender.in_valid; // Valid data is available at the input
  tmp[25] = all.top.blender.in_ready; // Driven when new input can be accepted
  tmp[26] = all.top.pixel_accum.in_ready; // Driven when new input can be accepted
  tmp[27] = all.top.pixel_accum.in_valid; // Valid data is available at the input
  tmp[28] = all.top.pixel_accum.out_valid; // Driven when new data is at the output
  tmp[29] = all.top.pixel_accum.out_ready; // Whether the tbox wrapper is ready to accept the output
  case (mux_sel)
  default: tbox_usoc_all_match_pick = {{34{1'b0}}, tmp[29:0]};
  endcase
end
endfunction

function automatic logic [127:0] tbox_usoc_all_data_pick;
input tbox_usoc_all_t all;
input [6:0] mux_sel;
begin
  logic [4129:0] tmp;
  tmp[0] = all.top.address.in_valid; // Valid data is available at the input
  tmp[256:1] = all.top.address.in_bits.data; // 256 bits of data from minion
  tmp[260:257] = all.top.address.in_bits.minion_id; // Minion id (in the 0 to 15 range)
  tmp[262:261] = all.top.address.in_bits.port_id; // Port id (in the 0 to 3 range)
  tmp[265:263] = all.top.address.in_bits.entry; // Type of entry (header, r, s, t)
  tmp[266] = all.top.address.sample_request_valid; // New tbox pull available
  tmp[272:267] = all.top.address.sample_request_bits.id; // N/A
  tmp[275:273] = all.top.address.sample_request_bits.size; // N/A
  tmp[276] = all.top.address.sample_request_ready; // Enough ring buffer space to store parameters for a new new tbox pull
  tmp[277] = all.top.address.l2_request_valid; // Driven when new data available at the input
  tmp[278] = all.top.address.l2_request_ready; // Valid when new data can be accepted
  tmp[279] = all.top.address.l2_reply_valid; // Valid data is available at the input
  tmp[281:280] = all.top.address.sampleValids; // N/A
  tmp[289:282] = all.top.address.pixelValids; // N/A
  tmp[290] = all.top.address.advancePixel; // N/A
  tmp[291] = all.top.address.aniso_enabled; // N/A
  tmp[296:292] = all.top.address.current_aniso_sample; // N/A
  tmp[297] = all.top.address.advanceAnisoSample; // N/A
  tmp[302:298] = all.top.address.aniso_count; // N/A
  tmp[307:303] = all.top.address.trilinear_conf.lod0; // LOD 0
  tmp[312:308] = all.top.address.trilinear_conf.lod1; // LOD 1
  tmp[313] = all.top.address.trilinear_conf.trilinear; // Whether the trilinear filter is enabled
  tmp[321:314] = all.top.address.trilinear_conf.mip_beta; // Weight for value from LOD0 in 0.8 fixed point
  tmp[329:322] = all.top.address.trilinear_conf.mip_beta_inv; // Value of "1.0 - mip_beta" in 0.8 fixed point
  tmp[330] = all.top.future_tags.in_valid; // Valid data is available at the input
  tmp[331] = all.top.future_tags.in_ready; // Driven when new input can be accepted
  tmp[395:332] = all.top.future_tags.tag_valid; // For each bank, for each line, whether the tag is valid
  tmp[4107:396] = all.top.future_tags.tag_arrays; // For each bank, for each line, the tag
  tmp[4108] = all.top.virtual_address.img_info_valid; // Valid data is available at the input
  tmp[4109] = all.top.virtual_address.tags_valid; // Valid data is available at the input
  tmp[4110] = all.top.virtual_address.tags_ready; // Driven when new input can be accepted
  tmp[4111] = all.top.l2_reorder_fifo.vaddr_valid; // Valid data is available at the input
  tmp[4112] = all.top.l2_reorder_fifo.vaddr_ready; // Driven when new input can be accepted
  tmp[4113] = all.top.l2_reorder_fifo.l2_request_valid; // Driven when new data available at the input
  tmp[4114] = all.top.l2_reorder_fifo.l2_request_ready; // Valid when new data can be accepted
  tmp[4115] = all.top.l2_reorder_fifo.l2_reply_valid; // Valid data is available at the input
  tmp[4116] = all.top.decompress.l2_valid; // Valid data is available at the input
  tmp[4117] = all.top.decompress.l2_ready; // Driven when new input can be accepted
  tmp[4118] = all.top.cache_data.tags_valid; // Valid data is available at the input
  tmp[4119] = all.top.cache_data.tags_ready; // Driven when new input can be accepted
  tmp[4120] = all.top.cache_data.l2_valid; // Valid data is available at the input
  tmp[4121] = all.top.cache_data.l2_ready; // Driven when new input can be accepted
  tmp[4122] = all.top.tmux.in_valid; // Valid data is available at the input
  tmp[4123] = all.top.tmux.in_ready; // Driven when new input can be accepted
  tmp[4124] = all.top.blender.in_valid; // Valid data is available at the input
  tmp[4125] = all.top.blender.in_ready; // Driven when new input can be accepted
  tmp[4126] = all.top.pixel_accum.in_ready; // Driven when new input can be accepted
  tmp[4127] = all.top.pixel_accum.in_valid; // Valid data is available at the input
  tmp[4128] = all.top.pixel_accum.out_valid; // Driven when new data is at the output
  tmp[4129] = all.top.pixel_accum.out_ready; // Whether the tbox wrapper is ready to accept the output
  case (mux_sel)
  0: tbox_usoc_all_data_pick = tmp[127:0];
  1: tbox_usoc_all_data_pick = tmp[255:128];
  2: tbox_usoc_all_data_pick = tmp[383:256];
  3: tbox_usoc_all_data_pick = tmp[511:384];
  4: tbox_usoc_all_data_pick = tmp[639:512];
  5: tbox_usoc_all_data_pick = tmp[767:640];
  6: tbox_usoc_all_data_pick = tmp[895:768];
  7: tbox_usoc_all_data_pick = tmp[1023:896];
  8: tbox_usoc_all_data_pick = tmp[1151:1024];
  9: tbox_usoc_all_data_pick = tmp[1279:1152];
  10: tbox_usoc_all_data_pick = tmp[1407:1280];
  11: tbox_usoc_all_data_pick = tmp[1535:1408];
  12: tbox_usoc_all_data_pick = tmp[1663:1536];
  13: tbox_usoc_all_data_pick = tmp[1791:1664];
  14: tbox_usoc_all_data_pick = tmp[1919:1792];
  15: tbox_usoc_all_data_pick = tmp[2047:1920];
  16: tbox_usoc_all_data_pick = tmp[2175:2048];
  17: tbox_usoc_all_data_pick = tmp[2303:2176];
  18: tbox_usoc_all_data_pick = tmp[2431:2304];
  19: tbox_usoc_all_data_pick = tmp[2559:2432];
  20: tbox_usoc_all_data_pick = tmp[2687:2560];
  21: tbox_usoc_all_data_pick = tmp[2815:2688];
  22: tbox_usoc_all_data_pick = tmp[2943:2816];
  23: tbox_usoc_all_data_pick = tmp[3071:2944];
  24: tbox_usoc_all_data_pick = tmp[3199:3072];
  25: tbox_usoc_all_data_pick = tmp[3327:3200];
  26: tbox_usoc_all_data_pick = tmp[3455:3328];
  27: tbox_usoc_all_data_pick = tmp[3583:3456];
  28: tbox_usoc_all_data_pick = tmp[3711:3584];
  29: tbox_usoc_all_data_pick = tmp[3839:3712];
  30: tbox_usoc_all_data_pick = tmp[3967:3840];
  31: tbox_usoc_all_data_pick = tmp[4095:3968];
  default: tbox_usoc_all_data_pick = {{94{1'b0}}, tmp[4129:4096]};
  endcase
end
endfunction

function automatic logic [199:0] tbox_usoc_all_filter_pick;
input tbox_usoc_all_t all;
input [6:0] mux_sel;
begin
  logic [81:0] tmp;
  tmp[63:0] = all.cycle_count; // A cycle counter intended for debugging
  tmp[67:64] = all.top.address.in_bits.minion_id; // Minion id (in the 0 to 15 range)
  tmp[69:68] = all.top.address.in_bits.port_id; // Port id (in the 0 to 3 range)
  tmp[72:70] = all.top.address.in_bits.entry; // Type of entry (header, r, s, t)
  tmp[78:73] = all.top.address.sample_request_bits.id; // N/A
  tmp[81:79] = all.top.address.sample_request_bits.size; // N/A
  case (mux_sel)
  default: tbox_usoc_all_filter_pick = {{118{1'b0}}, tmp[81:0]};
  endcase
end
endfunction
