// Regfile
`define VPU_REGFILE_NUM             32

// Regmask
`define VPU_REGMASK_DATA_SZ `VPU_LANE_NUM
`define VPU_REGMASK_LANE_DATA_SZ 1
`define VPU_REGMASK_ALL_DATA_SZ (`VPU_LANE_NUM*`VPU_REGMASK_NUM)
`define VPU_REGMASK_ALL_LANE_DATA_SZ (`VPU_REGMASK_LANE_DATA_SZ*`VPU_REGMASK_NUM)

  //instruction fields
`define VPU_INST_TYP_SEL 21:20
`define VPU_INST_REN1_RA_SEL 19:15
`define VPU_INST_REN2_RA_SEL 24:20
`define VPU_INST_REN3_RA_SEL 31:27
`define VPU_INST_DIVSQRT_RA_SEL 11:7
`define VPU_INST_RD_SEL 11:7
