// TIMA
`define VPU_NUM_TIMA  2

//Tensor FMA
`define DCACHE_ADDR_BCAST_RANGE 4:2

// TensorQuant transforms
`define TQUANT_BITS_PER_TRANSFORM 4
`define TQUANT_NUM_CFG_TRANSFORMS 10
`define TQUANT_TRANS_BITS         (`TQUANT_BITS_PER_TRANSFORM*`TQUANT_NUM_CFG_TRANSFORMS)

`define TQUANT_LAST              4'b0000
`define TQUANT_INT32_TO_FP32_CVT 4'b0001
`define TQUANT_FP32_TO_INT32_CVT 4'b0010
`define TQUANT_RELU              4'b0011
`define TQUANT_INT32_ADD_ROW     4'b0100
`define TQUANT_INT32_ADD_COL     4'b0101
`define TQUANT_FP32_MUL_ROW      4'b0110
`define TQUANT_FP32_MUL_COL      4'b0111
`define TQUANT_SAT_INT8          4'b1000
`define TQUANT_SAT_UINT8         4'b1001
`define TQUANT_PACK_128B         4'b1010

`define VPU_ML_LOAD_CTRL_WADDR_SZ     $clog2(`VPU_REGFILE_NUM)
`define VPU_ML_LOAD_CTRL_CHUNK_IDX_SZ $clog2(`VPU_DATA_SZ / `VPU_DATA_S_SZ)

// Performance counters
`define VPU_EVENT_TFMA_WAIT_TENB 0
