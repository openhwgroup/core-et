`define VPU_INST_MASK_MRA1_SEL 17:15
`define VPU_INST_MASK_MRA2_SEL 22:20
`define VPU_INST_MASK_FRA_SEL 19:15
`define VPU_INST_RM_SEL 14:12

  //dmem
`define VPU_DMEM_RESP_GROUP_DATA_SZ 64
`define VPU_CORE_VPU_STORE_DATA_SZ `VPU_DATA_SZ
`define VPU_CORE_VPU_STORE_GROUP_DATA_SZ 64
