            "0: No count                  6: DCACHE_ACCESS0        12: "
            "L2_EVICT_REQ            18: TFMA_WAIT_TENB         24: "
            "TFMA_INST        \n"
            "1: MCYCLE                     7: DCACHE_ACCESS1        13: "
            "L2_EVICT_REQ_REJ   19: TIMA_OPS                         25: "
            "TFMA_OPS         \n"
            "2: RETIRED_INST0      8: DCACHE_MISSES0         14:  TL_INST  "
