      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine exception program counter";
      property description =
         "The mepc register is an MXLEN-bit read/write register. The "
         "low-order bit of mepc (mepc[0]) is always zero. On "
         "implementations that support only IALIGN = 32, the two low bits "
         "(mepc[1:0]) are always zero.";
