      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Scratch register for machine trap handler";
      property description =
         "The mscratch register is dedicated for use by machine mode. "
         "Typically, it is used to hold a pointer to a machine-mode "
         "hart-local context space and swapped with a user register upon "
         "entry to an M-mode trap handler.";
