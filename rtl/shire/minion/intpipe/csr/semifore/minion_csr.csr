      field {
         (* Group = "SupervisorTrapHandling" *)
         property title =
            "Supervisor counter enable";
         property description =
            "This register stores the enable bits for each one of the "
            "counters in supervisor mode. These bits control the "
            "availability of the hardware performance-monitoring counters "
            "to the next-lowest privilege mode.  This means that U-mode "
            "and S-mode cannot access hpmcounter9 - hpmcounter31. "
            "Attempting to access these CSR's in U-mode or S-mode results "
            "in an illegal instruction exception. These bits are encoded "
            "as follows:\n"
            "0: CY. Setting this bit enables the cycle counter.\n"
            "1: TM. Setting this bit enables the time counter.\n"
            "2: IR. Setting this bit enables the instruction retire "
            "counter.\n"
            "7:3: HPM 3 - 7.  These bits enable hpmcounter 0 through "
            "hpmcounter 4.\n"
            "31:8: Reserved.";
         property reset_value = 9'o0;
      } [8:0] scounteren;
