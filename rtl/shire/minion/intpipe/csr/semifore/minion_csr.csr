   register {
      (* Group = "ET_Messaging" *)
      (* RISCV_Privilege_Level = "supervisor" *)
      property title =
         "super level control for msg port0";
      property description =
         "These 64-bit registers indicate the blocking control for each "
         "port in Supervisor mode. Each register is encoded as follows:\n"
         "0: EnablePort. If set to 1 the port is enabled, otherwise the "
         "port is disabled.\n"
         "1: Enable OutOfBand data on this port.\n"
         "4: Umode. If set to 1, user mode software can operate the port "
         "using PORTHEAD0…PORTHEAD3 and PORTHEADNB0…PORTHEADNB3.\n"
         "7:5: LogMsgSize. Logarithm of the message size in Bytes. Valid "
         "values: 2..5. Writing a value lower than 2 stores the value 2 in "
         "the field. Writing a value greater than 5 stores the value 5 in "
         "the field.\n"
         "11:8: MaxMsgs. Maximum number of messages the port can hold - 1.\n"
         "23:16: Set. Indicates the first set in the L1 cache where "
         "storage starts. The valid range of values for this field is "
         "0...15. Attempting to write a value N greater than 15 sets the "
         "value of the field to (N mod 16).\n"
         "31:24: Way. Indicates the L1 cache way where storage starts. All "
         "sets belonging to this port must be on the same way. The valid "
         "range of values for this field is 0...3. Attempting to write a "
         "value N greater than 3 sets the value of the field to (N mod 4).\n"
         "\n"
         "";
      field {
         (* Group = "ET_Messaging" *)
         (* RISCV_Privilege_Level = "supervisor" *)
         property title =
            "super level control for msg port0";
         property description =
            "These 64-bit registers indicate the blocking control for each "
            "port in Supervisor mode. Each register is encoded as follows:\n"
            "0: EnablePort. If set to 1 the port is enabled, otherwise the "
            "port is disabled.\n"
            "1: Enable OutOfBand data on this port.\n"
            "4: Umode. If set to 1, user mode software can operate the "
            "port using PORTHEAD0…PORTHEAD3 and "
            "PORTHEADNB0…PORTHEADNB3.\n"
            "7:5: LogMsgSize. Logarithm of the message size in Bytes. "
            "Valid values: 2..5. Writing a value lower than 2 stores the "
            "value 2 in the field. Writing a value greater than 5 stores "
            "the value 5 in the field.\n"
            "11:8: MaxMsgs. Maximum number of messages the port can hold - "
            "1.\n"
            "23:16: Set. Indicates the first set in the L1 cache where "
            "storage starts. The valid range of values for this field is "
            "0...15. Attempting to write a value N greater than 15 sets "
            "the value of the field to (N mod 16).\n"
            "31:24: Way. Indicates the L1 cache way where storage starts. "
            "All sets belonging to this port must be on the same way. The "
            "valid range of values for this field is 0...3. Attempting to "
            "write a value N greater than 3 sets the value of the field to "
            "(N mod 4).\n"
            "\n"
            "";
         property hardware_volatile = false;
      } [63:0] smsg_port0;
   } [0x9cc] smsg_port0;
