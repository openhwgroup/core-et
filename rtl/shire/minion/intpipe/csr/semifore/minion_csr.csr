            "Virtual Address[47:6]";
         property description =
            "This field contains the virtual address of the lock "
            "operation.";
      } [47:6] va;
      field {
         property title =
            "Use the tensor_mask CSR";
         property description =
            "When set, use the tensor_mask CSR. When xs[63] is 1, then the "
            "n-th operation is skipped (i.e., the cache line is not "
            "operated upon) if the n-th tensor_mask bit is clear.";
      } [63] use_tensor_mask;
   } [0x8df] co_lock_va;
