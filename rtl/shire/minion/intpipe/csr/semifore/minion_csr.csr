   register {
      (* Documentation_Source = "RISC-V Debug, Sec 5.2" *)
      (* Group = "DebugTraceRegisters" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Debug/Trace trigger register select";
      property description =
         "This register determines which trigger is accessible through the "
         "other trigger registers. The set of accessible triggers must "
         "start at 0, and be contiguous. Writes of values greater than or "
         "equal to the number of supported triggers may result in a "
         "diff-_x000B_erent value in this register than what was written. "
         "To verify that what they wrote is a valid index, debuggers can "
         "read back the value and check that tselect holds what they "
         "wrote. Since triggers can be used both by Debug Mode and M-mode, "
         "the debugger must restore this register if it modifies it.";
      field {
         (* Documentation_Source = "RISC-V Debug, Sec 5.2" *)
         (* Group = "DebugTraceRegisters" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Debug/Trace trigger register select";
         property description =
            "This register determines which trigger is accessible through "
            "the other trigger registers. The set of accessible triggers "
            "must start at 0, and be contiguous. Writes of values greater "
            "than or equal to the number of supported triggers may result "
            "in a diff-_x000B_erent value in this register than what was "
            "written. To verify that what they wrote is a valid index, "
            "debuggers can read back the value and check that tselect "
            "holds what they wrote. Since triggers can be used both by "
            "Debug Mode and M-mode, the debugger must restore this "
            "register if it modifies it.";
         property reset_value = 64'o0;
         property hardware_volatile = false;
      } [63:0] tselect;
   } [0x7a0] tselect;
   register {
      (* Documentation_Source = "RISC-V Debug" *)
      (* Group = "DebugTraceRegisters" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "First Debug/Trace trigger data register";
      field {
         property title =
            "Trigger specific data";
         property description =
            "Trigger specific data. ";
      } [26:0] data;
      field {
         property title =
            "Debug mode.";
         property description =
            "0: Both Debug and M-mode can write the tdata registers at the "
            "selected tselect.\n"
            "1: Only Debug Mode can write the tdata registers at the "
            "selected tselect. Writes from other modes are ignored. This "
            "bit is only writable from Debug Mode.";
      } [27] dmode;
      field {
         (* Documentation_Source = "Section 5.2.2 of RISC-V debug spec." *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Type of trigger.";
         property description =
            "This 4-bit field ndicates the type of trigger. This field is "
            "encoded as follows:\n"
            "0: No trigger at this tselect.\n"
            "1: Trigger not implemented.\n"
            "2: Address/data match trigger. The remaining bits in this "
            "register act as described in mcontrol.\n"
            "3: Instruction count trigger. The remaining bits in this "
            "register act as described in icount.\n"
            "4: Interrupt trigger. The remaining bits in this register act "
            "as described in itrigger.\n"
            "5: Exception trigger. The remaining bits in this register act "
            "as described in etrigger. \n"
            "6 - 14: Reserved.\n"
            "15:  This trigger exists (so enumeration shouldn't "
            "terminate), but is not currently available.";
      } [31:28] trigger;
   } [0x7a1] tdata1;
   register {
      (* Documentation_Source = "RISC-V Debug" *)
      (* Group = "DebugTraceRegisters" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Second Debug/Trace trigger data register";
      property description =
         "Trigger-specific data. If XLEN is less than DXLEN, writes to "
         "this register are sign-extended.";
      field {
         (* Documentation_Source = "RISC-V Debug" *)
