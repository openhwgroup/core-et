   register {
      (* Documentation_Source = "Section 3.1.16, RISC-V Spec Volume II" *)
      (* Group = "MachineTrapHandling" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine trap cause";
      property description =
         "The mcause register is an MXLEN-bit read-write register. When a "
         "trap is taken into M-mode, mcause is written with a code "
         "indicating the event that caused the trap. Otherwise, mcause is "
         "never written by the implementation, though it may be explicitly "
         "written by software. In this register, the uppermost bit is the "
         "INTERRUPT bit. The remaining bits are the EXCEPTION CODE. The "
         "encoding of the EXCEPTION CODE field depends on the state of the "
         "INTERRUPT bit. For more information, refer to Table 3.6 in the "
         "RISC-V spec, Volume II.";
      field {
         (* Documentation_Source = "Section 3.1.16, RISC-V Spec Volume II" *)
         (* Group = "MachineTrapHandling" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine trap cause";
         property description =
            "The mcause register is an MXLEN-bit read-write register. When "
            "a trap is taken into M-mode, mcause is written with a code "
            "indicating the event that caused the trap. Otherwise, mcause "
            "is never written by the implementation, though it may be "
            "explicitly written by software. In this register, the "
            "uppermost bit is the INTERRUPT bit. The remaining bits are "
            "the EXCEPTION CODE. The encoding of the EXCEPTION CODE field "
            "depends on the state of the INTERRUPT bit. For more "
            "information, refer to Table 3.6 in the RISC-V spec, Volume "
            "II.";
         property hardware_volatile = false;
      } [63:0] mcause;
