      property title =
         "Vendor ID";
      property description =
         "The mvendorid CSR is a 32-bit read-only register providing the "
         "JEDEC manufacturer ID of the provider of the core. This register "
         "must be readable in any implementation, but a value of 0 can be "
         "returned to indicate the field is not implemented or that this "
         "is a non-commercial implementation. This register is encoded as "
         "follows:\n"
         "31:7 - BANK. \n"
         "6:0 - OFFSET.\n"
         "For more information, refer to  Section 3.1.2 of the RISC-V "
         "Privileged Architecture Specification, Volume II.";
      property write_access = false;
