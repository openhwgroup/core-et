   register {
      (* Group = "SupervisorProtectionTranslation" *)
      (* RISCV_Privilege_Level = "supervisor" *)
      property title =
         "Supervisor address translation and protection";
      property description =
         "The Supervisor Address Translation and Protection (SATP) "
         "register is a 64-bit read/write register that controls S-mode "
         "address translation and protection. There is a single SATP "
         "register shared among the two harts of the processor. The bit "
         "assignments for this register are as follows:\n"
         "63:60, MODE. This 4-bit field selects the address translation "
         "schement and is encoded as follows. When MODE = Bare, M-mode "
         "virtual addresses are equal to M-mode physical addresses, and "
         "there is no additional memory protection. In this case, the "
         "remaining fields in MATP have no effect. All values not shown "
         "are reserved.\n"
         "0000: No address translation or protection.\n"
         "1000: Page-based 39-bit virtual addressing.\n"
         "1001: Page-based 48-bit virtual addressing.\n"
         "\n"
         "59:44 ASID. The address space identifier (ASID) facilitates "
         "address-translation fences on a per-address-space basis. \n"
         "43:0 PPN. Physical page number. This field stores the physical "
         "page number (PPN) of the root page table, i.e., its physical "
         "address divided by 4KiB.";
      field {
         (* Group = "SupervisorProtectionTranslation" *)
         (* RISCV_Privilege_Level = "supervisor" *)
         property title =
            "Supervisor address translation and protection";
         property description =
            "The Supervisor Address Translation and Protection (SATP) "
            "register is a 64-bit read/write register that controls S-mode "
            "address translation and protection. There is a single SATP "
            "register shared among the two harts of the processor. The bit "
            "assignments for this register are as follows:\n"
            "63:60, MODE. This 4-bit field selects the address translation "
            "schement and is encoded as follows. When MODE = Bare, M-mode "
            "virtual addresses are equal to M-mode physical addresses, and "
            "there is no additional memory protection. In this case, the "
            "remaining fields in MATP have no effect. All values not shown "
            "are reserved.\n"
            "0000: No address translation or protection.\n"
            "1000: Page-based 39-bit virtual addressing.\n"
            "1001: Page-based 48-bit virtual addressing.\n"
            "\n"
            "59:44 ASID. The address space identifier (ASID) facilitates "
            "address-translation fences on a per-address-space basis. \n"
            "43:0 PPN. Physical page number. This field stores the "
            "physical page number (PPN) of the root page table, i.e., its "
            "physical address divided by 4KiB.";
         property reset_value = 64'o0;
         property hardware_volatile = false;
      } [63:0] satp;
   } [0x180] satp;
   register {
      (* Group = "MachineTrapSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine status register";
      property description =
         "The mstatus register is an MXLEN-bit read/write register that "
         "keeps track of and controls the hart’s current operating "
         "state. Restricted views of the mstatus register appear as the "
         "sstatus and ustatus registers in the S-level and U-level ISAs "
         "respectively. For more information, refer to Section 3.1.6 of "
         "the RISC-V Privileged Architecture Specification, Volume II.";
      field {
         (* Group = "MachineTrapSetup" *)
         (* RISCV_Privilege_Level = "machine" *)
