   register {
      (* Documentation_Source = "RISC-V Debug" *)
      (* Group = "DebugTraceRegisters" *)
      (* \Is_Implemented?  = "0" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "trigger info";
      property description =
         "The info field occupies the lower 16-bits of this register. In "
         "this field, there is one bit for each possible type enumerated "
         "in\n"
         "tdata1. Bit N corresponds to type N. If the bit is set, then "
         "that type is supported by the currently selected trigger. If the "
         "currently selected trigger doesn't exist, this field contains 1. "
         "If type is not writable, this register may be unimplemented, in "
         "which case reading it causes an illegal instruction exception. "
         "In this case the debugger can read the only supported type from\n"
         "tdata1 This field is cirrently not implemented. ";
      field {
         (* Documentation_Source = "RISC-V Debug" *)
         (* Group = "DebugTraceRegisters" *)
         (* \Is_Implemented?  = "0" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "trigger info";
         property description =
            "The info field occupies the lower 16-bits of this register. "
            "In this field, there is one bit for each possible type "
            "enumerated in\n"
            "tdata1. Bit N corresponds to type N. If the bit is set, then "
            "that type is supported by the currently selected trigger. If "
            "the currently selected trigger doesn't exist, this field "
            "contains 1. If type is not writable, this register may be "
            "unimplemented, in which case reading it causes an illegal "
            "instruction exception. In this case the debugger can read the "
            "only supported type from\n"
            "tdata1 This field is cirrently not implemented. ";
         property hardware_volatile = false;
      } [63:0] tinfo;
   } [0x7a4] tinfo;
   register {
      (* Documentation_Source = "ET-SoC databook, section 9.9.2.1" *)
      (* Group = "DebugModeRegisters" *)
      (* RISCV_Privilege_Level = "debug" *)
      property title =
         "Debug control and status register";
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Privilege level when debug mode was entered.";
         property description =
            "Contains the privilege level the hart was operating in when "
            "Debug Mode was entered. A debugger can change this value to "
            "change the hart's privilege level when exiting Debug Mode. "
            "Not all privilege levels are supported on all harts. If the "
            "encoding written is not supported or the\n"
            "debugger is not allowed to change to it, the hart may change "
            "to any supported privilege level. This field is encoded as "
            "follows:\n"
            "0: User/Application\n"
            "1: Supervisor\n"
            "3: Machine ";
      } [1:0] prv;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Execute single instructions in debug mode.";
         property description =
            "When set and not in Debug Mode, the hart will only execute a "
            "single instruction and then enter Debug Mode. If the "
            "instruction does not complete due to an exception, the hart "
            "will immediately enter Debug Mode before executing the trap "
            "handler, with appropriate exception registers set. The "
            "debugger must not change the value of this bit while the hart "
            "is running";
      } [2] step;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "NMI pending enable.";
         property description =
            "When set, there is a Non-Maskable-Interrupt (NMI) pending for "
            "the hart. Since an NMI can indicate a hardware error "
            "condition, reliable debugging may no longer be possible once "
            "this bit becomes set.";
         property write_access = false;
      } [3] nmip;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "MPRV enable.";
         property description =
            "0: MPRV in mstatus is ignored in Debug mode.\n"
            "1: MPRV in mstatus takes effect in Debug mode. ";
      } [4] mpvren;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Why debug mode was entered.";
         property description =
            "Explains why Debug Mode was entered. When there are multiple "
            "reasons to enter Debug Mode in a single cycle, hardware "
            "should set cause\n"
            "to the cause with the highest priority.\n"
            "1: An ebreak instruction was executed. (priority 3)\n"
            "2: The Trigger Module caused a breakpoint exception. "
            "(priority 4, highest)\n"
            "3: The debugger requested entry to Debug Mode using haltreq. "
            "(priority 1)\n"
            "4: The hart single stepped because step was set. (priority 0, "
            "lowest)\n"
            "5: The hart halted directly out of reset due to resethaltreq. "
            "It is also acceptable to report 3 when this happens. "
            "(priority 2)";
         property write_access = false;
      } [8:6] cause;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Stop timers while in Debug mode.";
         property description =
            "0: Increment timers as usual.\n"
            "1: Don't increment any hart-local timers while in Debug Mode.";
      } [9] stoptime;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Stop counters while in Debug mode.";
         property description =
            "0: Increment counters as usual.\n"
            "1: Don't increment any counters while in Debug Mode or on "
            "ebreak instructions that cause entry into Debug Mode. These "
            "counters include the cycle and instret CSRs. This is "
            "preferred for most debugging scenarios.";
      } [10] stopcount;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Interrupt single-stepping.";
         property description =
            "0: Interrupts are disabled during single stepping.\n"
            "1: Interrupts are enabled during single stepping. "
            "Implementations may hardwire this bit to 0. In that case "
            "interrupt behavior can be emulated by the debugger. The "
            "debugger must not change the value of this bit while the hart "
            "is running.";
      } [11] stepie;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Ebreak instructions in U-mode.";
         property description =
            "0: ebreak instructions in U-mode behave as described in the "
            "Privileged Spec.\n"
            "1: ebreak instructions in U-mode enter Debug Mode.";
      } [12] ebreaku;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Ebreak instructions in S-mode.";
         property description =
            "0: ebreak instructions in S-mode behave as described in the "
            "Privileged Spec.\n"
            "1: ebreak instructions in S-mode enter Debug Mode.";
      } [13] ebreaks;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Ebreak instructions in M-mode.";
         property description =
            "0: ebreak instructions in M-mode behave as described in the "
            "Privileged Spec.\n"
            "1: ebreak instructions in M-mode enter Debug Mode.";
      } [15] ebreakm;
      field {
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Debug version.";
         property description =
            "0: No external debug support.\n"
            "4: External debug support exists.\n"
            "15: There is external debug support, but it does not conform "
            "to any available version of this spec.";
         property write_access = false;
      } [31:28] xdebugver;
   } [0x7b0] dcsr;
   register {
      (* Documentation_Source = "RISC-V Debug" *)
      (* Group = "DebugModeRegisters" *)
      (* RISCV_Privilege_Level = "debug" *)
      property title =
         "Debug PC";
      property description =
         "Upon entry to debug mode, dpc is updated with the virtual "
         "address of the next instruction to be executed. When resuming, "
         "the hart's PC is updated to the virtual address stored in dpc. A "
         "debugger may write dpc to change where the hart resumes. See "
         "Section 4.8.2 of the RISC-B Debug Specification.";
      field {
         (* Documentation_Source = "RISC-V Debug" *)
         (* Group = "DebugModeRegisters" *)
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Debug PC";
         property description =
            "Upon entry to debug mode, dpc is updated with the virtual "
            "address of the next instruction to be executed. When "
            "resuming, the hart's PC is updated to the virtual address "
            "stored in dpc. A debugger may write dpc to change where the "
            "hart resumes. See Section 4.8.2 of the RISC-B Debug "
            "Specification.";
         property hardware_volatile = false;
      } [63:0] dpc;
   } [0x7b1] dpc;
   register {
      (* Documentation_Source = "RISC-V Debug" *)
      (* Group = "DebugModeRegisters" *)
      (* RISCV_Privilege_Level = "debug" *)
      property title =
         "Debug scratch register";
      property description =
         "Debug scratch register. A debugger must not write to this "
         "register unless hartinfo explicitly mentions it (the Debug "
         "Module may use this register internally).";
      field {
         (* Documentation_Source = "RISC-V Debug" *)
         (* Group = "DebugModeRegisters" *)
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Debug scratch register";
         property description =
            "Debug scratch register. A debugger must not write to this "
            "register unless hartinfo explicitly mentions it (the Debug "
            "Module may use this register internally).";
         property hardware_volatile = false;
      } [63:0] dscratch0;
   } [0x7b2] dscratch0;
   register {
      (* Documentation_Source = "RISC-V Debug" *)
      (* Group = "DebugModeRegisters" *)
      (* RISCV_Privilege_Level = "debug" *)
      property title =
         "Debug Data register";
      property description =
         "ddata0 register. This register is not listed in the RISC-V debug "
         "spec.";
      field {
         (* Documentation_Source = "RISC-V Debug" *)
         (* Group = "DebugModeRegisters" *)
         (* RISCV_Privilege_Level = "debug" *)
         property title =
            "Debug Data register";
         property description =
            "ddata0 register. This register is not listed in the RISC-V "
            "debug spec.";
         property hardware_volatile = false;
      } [63:0] ddata0;
   } [0x7b8] ddata0;
   register {
      (* Documentation_Source = "PRM-0, Section 17.1." *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine address translation and protection";
      property description =
         "The Machine Address Translation and Protection (MATP) register "
         "is a 64-bit read/write register that controls M-mode address "
         "translation and protection. There is a single MATP register "
         "shared among the two harts of the processor. The bit assignments "
         "for this register are as follows:\n"
         "63:60, MODE. This 4-bit field selects the address translation "
         "schement and is encoded as follows. When MODE = Bare, M-mode "
         "virtual addresses are equal to M-mode physical addresses, and "
         "there is no additional memory protection. In this case, the "
         "remaining fields in MATP have no effect. All values not shown "
         "are reserved.\n"
         "0000: No address translation or protection.\n"
         "1000: Page-based 39-bit virtual addressing.\n"
         "1001: Page-based 48-bit virtual addressing.\n"
         "\n"
         "59: L bit. Setting this bit permits writes to this register. "
         "Clearing the bit disallows writes to this register. \n"
         "43:0 PPN. Physical page number. This field stores the physical "
         "page number (PPN) of the root page table, i.e., its physical "
         "address divided by 4KiB.";
      field {
         (* Documentation_Source = "PRM-0, Section 17.1." *)
         (* Group = "ET_SpecificCSRs" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine address translation and protection";
         property description =
            "The Machine Address Translation and Protection (MATP) "
            "register is a 64-bit read/write register that controls M-mode "
            "address translation and protection. There is a single MATP "
            "register shared among the two harts of the processor. The bit "
            "assignments for this register are as follows:\n"
            "63:60, MODE. This 4-bit field selects the address translation "
            "schement and is encoded as follows. When MODE = Bare, M-mode "
            "virtual addresses are equal to M-mode physical addresses, and "
            "there is no additional memory protection. In this case, the "
            "remaining fields in MATP have no effect. All values not shown "
            "are reserved.\n"
            "0000: No address translation or protection.\n"
            "1000: Page-based 39-bit virtual addressing.\n"
            "1001: Page-based 48-bit virtual addressing.\n"
            "\n"
            "59: L bit. Setting this bit permits writes to this register. "
            "Clearing the bit disallows writes to this register. \n"
            "43:0 PPN. Physical page number. This field stores the "
            "physical page number (PPN) of the root page table, i.e., its "
            "physical address divided by 4KiB.";
         property hardware_volatile = false;
      } [63:0] matp;
   } [0x7c0] matp;
   register {
      (* Documentation_Source = "PRM-0" *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Mask to implement instruction in mcode";
      property description =
         "MINSTMASK CSRs are used to cause a trap to M-code when the "
         "minion decodes a certain instruction pattern. The instruction "
         "pattern is applied *after* expanding RVC compressed "
         "instructions. Given a 32b instruction named inst, if the "
         "following expression evaluates to true then a trap to M-mode "
         "will be taken with mcause set to 0x1e and mtval holding the 32b "
         "of inst: ((inst[31:0] & minstmask[31:0]) == (minstmatch[31:0] & "
         "minstmask[31:0])) && minstmask[32]. Instruction matching can be "
         "disabled by setting minstmask[32] to zero.";
      field {
         property title =
            "Mask value";
      } [32:0] minstmask;
   } [0x7cd] minstmask;
   register {
      (* Documentation_Source = "PRM-0" *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Value to match to the instruction bits anded with minstmask to "
         "trap to mcode";
      property description =
         "MINSTMASK and MINSTMATCH CSRs are used to cause a trap to M-code "
         "when the minion decodes a certain instruction pattern. The "
         "instruction pattern is applied *after* expanding RVC compressed "
         "instructions. Given a 32b instruction named inst, if the "
         "following expression evaluates to true then a trap to M-mode "
         "will be taken with mcause set to 0x1e and mtval holding the 32b "
         "of inst: ((inst[31:0] & minstmask[31:0]) == (minstmatch[31:0] & "
         "minstmask[31:0])) && minstmask[32]. Instruction matching can be "
         "disabled by setting minstmask[32] to zero.";
      field {
         property title =
            "Instruction opcode match value (after RVC)";
      } [31:0] minstmatch;
   } [0x7ce] minstmatch;
   register {
      (* \Is_Implemented?  = "0" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Chicken bits for acquire and release operations";
      field {
         (* \Is_Implemented?  = "0" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Chicken bits for acquire and release operations";
         property hardware_volatile = false;
      } [63:0] amofence_ctrl;
   } [0x7cf] amofence_ctrl;
   register {
      (* Documentation_Source = "PRM-0" *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Cache Invalidate ";
      property description =
         "This register can trigger invalidation of various cache "
         "structures used by the Minion core.";
      field {
         property title =
            "Invalidate I-Cache";
         property description =
            "Writing 0 into bit 0 does not affect the instruction cache.  "
            "Writing a 1 into bit 0 of this CSR invalidates the "
            "instruction cache connected to the Minion core that issues "
            "the instruction.";
      } [0] i_cache_invalidate;
      field {
         property title =
            "Invalidate Data TLB, Instruction TLB, PTW Cache";
         property description =
            " Writing a 1 into bit 1 of this CSR invalidates the data TLB, "
            "the instruction TLB, and the PTW (page table walker) cache "
            "connected to the Minion core that issues the instruction. "
            "Writing 0 into bit 1 does not affect the TLBs nor the PTW.";
      } [1] tlb_ptw_invalidate;
   } [0x7d0] cacheInvalidate;
   register {
      (* Group = "ET_SpecificCSRs" *)
      (* \Is_Implemented?  = "0" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Power gate txfma and trans from 2 to 7";
      property description =
         "This register is not implemented.";
      field {
         (* Group = "ET_SpecificCSRs" *)
         (* \Is_Implemented?  = "0" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Power gate txfma and trans from 2 to 7";
         property description =
            "This register is not implemented.";
         property hardware_volatile = false;
      } [63:0] msleep_txfma_27;
   } [0x7d1] msleep_txfma_27;
   register {
      (* Documentation_Source = "PRM-0" *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Enable some shadow registers in umode (hartid, sleep_txfma...)";
      property description =
         "This register controls the availability of the MHARTID register "
         "to U-mode and S-mode.";
      field {
         property description =
            "When MENABLE_SHADOWS[0] is clear, attempts to read the HARTID "
            "register will cause an illegal instruction exception. When "
            "MENABLE_SHADOWS[0] is set, access to HARTID is permitted.";
      } [0] menable_shadows;
   } [0x7d2] menable_shadows;
   register {
      (* Documentation_Source = "PRM-0" *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "csr to allow exclusive access for a thread";
      property description =
         "Sometimes, it is desirable for a hart to execute alone on the "
         "processor core (i.e., with all other harts stopped/paused). This "
         "can be achieved through an IPI-based mechanism, but it is slow "
         "(see at the end for details). To accelerate this operation the  "
         "CSR allows a hart to request exclusive access to the minion "
         "(halting the other thread).";
      field {
      } [0] excl_mode;
   } [0x7d3] excl_mode;
   register {
      (* Group = "ET_SpecificCSRs" *)
      (* \Is_Implemented?  = "0" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "controls what instruction using the txfma will trap if "
         "sleep_txfma is on";
      property description =
         "This register is not implemented.";
      field {
         (* Group = "ET_SpecificCSRs" *)
         (* \Is_Implemented?  = "0" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "controls what instruction using the txfma will trap if "
            "sleep_txfma is on";
         property description =
            "This register is not implemented.";
         property hardware_volatile = false;
      } [63:0] mtxfma_sleep_traps;
   } [0x7d4] mtxfma_sleep_traps;
   register {
      (* Documentation_Source = "PRM-0" *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "machine" *)
      field {
         property title =
            "Address that caused a dcache bus error";
         property description =
            "This 40-bit values stores the address that caused the data "
            "cache bus error.";
         property hardware_volatile = true;
      } [39:0] mbusaddr;
   } [0x7d5] mbusaddr;
   register {
      (* Group = "ET_SimulationSpecific" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "PC that got a dcache bus error";
      property description =
         "This register stores the program counter value when the data "
         "cache bus error occurred.";
      field {
         (* Group = "ET_SimulationSpecific" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "PC that got a dcache bus error";
         property description =
            "This register stores the program counter value when the data "
            "cache bus error occurred.";
         property hardware_volatile = false;
      } [63:0] mbuspc;
   } [0x7d6] mbuspc;
   register {
      (* Documentation_Source = "PRM-8, Section 1.1.1." *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Supervisory Scratchpad Control";
      property description =
         "See PRM-8 for complete details. The mcache_control register is a "
         "64b read/write register. The mcache_control register keeps track "
         "of and controls the Minion D-cache current operation state. A "
         "restricted view of the mcache_control register appears as "
         "ucache_control register in the U-level ISA. This register is "
         "encoded as follows:\n"
         "63:2, Reserved.\n"
         "1: SCPENABLE. \n"
         "0: D1SPLIT. \n"
         "These two bits work together as follows to support the following "
         "three modes of operation:\n"
         "1. Shared mode (C0). When D1Split is 0, the L1 dcache is "
         "dynamically shared among the two harts of the minion.  In this "
         "mode, the value of SCPEnable is ignored.\n"
         "2. Split mode (C1). When D1Split is 1 and SCPEnable is 0, the L1 "
         "dcache is hard-partitioned across the two harts and each hart "
         "can only access its own partition. In the first Esperanto "
         "implementation, hart0 will have access to sets 0-7 in the cache, "
         "while hart1 will have access to sets 14-15 in the cache. Sets "
         "8-13 are inaccessible to either hart.\n"
         "3. Scratchpad mode (C2). When D1Split is 1 and SCPEnable is 1, "
         "the L1 dcache is hard-partitioned across the two harts and each "
         "hart can only access its own partition. In the first Esperanto "
         "implementation, hart0 will have access to sets 12-13 in the "
         "cache, while hart1 will have access to sets 14-15 in the cache. "
         "In addition, sets 0-11 are turned into a scratchpad area usable "
         "only by hart0 using tensor instructions.";
      field {
         property description =
            "When D1Split is 0, the L1 dcache is dynamically shared among "
            "the two harts of the minion. In this mode, the value of "
            "SCPEnable is ignored.";
      } [0] D1Split;
      field {
         property description =
            "Split Mode: When D1Split is 1 and SCPEnable is 0, the L1 "
            "dcache is hard-partitioned across the two harts and each hart "
            "can only access its own partition. In the first Esperanto "
            "implementation, hart0 will have access to sets 0-7 in the "
            "cache, while hart1 will have access to sets 14-15 in the "
            "cache. Sets 8-13 are inaccessible to either hart.\n"
            "Scratchpad Mode: When D1Split is 1 and SCPEnable is 1, the L1 "
            "dcache is hard-partitioned across the two harts and each hart "
            "can only access its own partition. In the first Esperanto "
            "implementation, hart0 will have access to sets 12-13 in the "
            "cache, while hart1 will have access to sets 14-15 in the "
            "cache. In addition, sets 0-11 are turned into a scratchpad "
            "area usable only by hart0 using tensor instructions.";
      } [1] SCPEnable;
   } [0x7e0] mcache_control;
   register {
      (* Documentation_Source = "PRM-8" *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Evict Set/Way Cache operation";
      property description =
         "M-code software can cause the eviction of a particular set-way "
         "in the L1 data cache. Using the PA found in cache "
         "<L1>[<set>,<way>], hardware writes-back (if needed) the line "
         "containing PA from all cache levels between <L1> and "
         "<DestLevel-1> to level <DestLevel>. The line containing PA is "
         "invalidated in all levels from <L1> through <DestLevel-1>. The "
         "operation is repeated as many times as indicated by xs[3:0]+1, "
         "linearly increasing the set and wrapping over to the next cache "
         "way if set overflows. When xs[63] is 1, then the n-th operation "
         "is skipped (i.e., the cache line is not operated upon) if the "
         "n-th tensor_mask bit is clear. If <set>,<way> specifies a line "
         "allocated to the scratchpad or a line that is hard-locked, then "
         "this operation is a NOP. If <DestLevel> is <L1> then this "
         "operation is a NOP.";
      field {
         property title =
            "Number of Lines (minus 1)";
         property description =
            "This 4-bit field contains the number of lines (minus 1). "
            "Maximum value is 0xF.";
      } [3:0] num_lines;
      field {
         property title =
            "Way";
         property description =
            "This 2-bit field contains the number of ways. Maximum value "
            "is 0x3.";
      } [7:6] way;
      field {
         property title =
            "Set";
         property description =
            "This 4-bit field contains the number of sets. Maximum value "
            "is 0xF.";
      } [17:14] set;
      field {
         property title =
            "Destination Level ";
         property description =
            "The values are as follows: \n"
            "00 - L1\n"
            "01 - L2\n"
            "10 - L3\n"
            "11 - MEM";
      } [59:58] dest_level;
      field {
         property title =
            "Use the tensor_mask CSR";
      } [63] use_tensor_mask;
   } [0x7f9] co_evict_sw;
   register {
      (* Documentation_Source = "PRM-8" *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Flush Set/Way Cache operation";
      property description =
         "M-code software can cause the flushing of a particular set-way "
         "in the L1 data cache. Using the PA found in cache "
         "<L1>[<set>,<way>], hardware writes-through (if needed) the line "
         "containing PA from all cache levels between <L1> and "
         "<DestLevel-1> to level <DestLevel>. At the end of the operation, "
         "levels <L1> through <DestLevel-1> will keep a clean copy of the "
         "line containing PA if it was already present.The operation is "
         "repeated as many times as indicated by xs[3:0]+1, linearly "
         "increasing the set and wrapping over to the next cache way if "
         "set overflows. When xs[63] is 1, then the n-th operation is "
         "skipped (i.e., the cache line is not operated upon) if the n-th "
         "tensor_mask bit is clear.If <set>,<way> specifies a line "
         "allocated to the scratchpad, then this operation is a NOP.If "
         "<DestLevel> is <L1> then this operation is a NOP.";
      field {
         property title =
            "Number of Lines (minus 1)";
         property description =
            "Number of Lines (minus 1)";
      } [3:0] num_lines;
      field {
         property title =
            "Way";
         property description =
            "Way. This field specifies the way of the L1 cache in C0 mode, "
            "ignoring the actual value of mcache_control.";
      } [7:6] way;
      field {
         property title =
            "Set";
         property description =
            "Set. This field specifies the set of the L1 cache in C0 mode, "
            "ignoring the actual value of mcache_control.";
      } [17:14] set;
      field {
         property title =
            "Destination Level ";
         property description =
            "The values are as follows: \n"
            "00 - L1. If <DestLevel> is <L1>, then this operation is a "
            "NOP.\n"
            "01 - L2\n"
            "10 - L3\n"
            "11 - MEM";
      } [59:58] dest_level;
      field {
         property title =
            "Use the tensor_mask CSR";
      } [63] use_tensor_mask;
   } [0x7fb] co_flush_sw;
   register {
      (* Documentation_Source = "PRM-8" *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Hard-Lock and Zero particular Set/Way Cache operation";
      property description =
         "The line at address {xs[39:6],6b0} is zeroed and locked into the "
         "L1 at the set derived from the current L1 indexing function, "
         "which depends on the value of mcache_control, and the way "
         "indicated by  tensxs[56:55]. If the requested set/way specifies "
         "a line that has been soft-locked using LockVA (see later), the "
         "soft-lock will be ignored (i.e., the line will be still cleared "
         "and hard-locked). Implementation: The line is marked as modified "
         "in the L1 cache, as is customary with any newly written line.";
      field {
         property title =
            "Physical Address";
         property description =
            "Physical Address. Indicates the physical address in the cache "
            "to be locked.";
      } [39:6] pa;
      field {
         property title =
            "Way";
         property description =
            "Way. Indicates the way in the cache to be locked.";
      } [56:55] way;
   } [0x7fd] co_lock_sw;
   register {
      (* Documentation_Source = "PRM-8" *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Unlock Set/Way Cache operation";
      property description =
         "The line at the set indicated by set xs[9:6] and way indicated "
         "by xs[62:55] is unconditionally unlocked, whether the line was "
         "hard- or soft-locked. Applying this operation to a non-locked "
         "line does not cause any action.Only the N low-order bits of "
         "xs[62:55] are used to encode the cache way, where N is log2 of "
         "the associativity of the cache. Fields xs[9:6] and xs[56:55] "
         "specify the set and way of the L1 cache in C0 mode, ignoring the "
         "actual value of mcache_control. Implementation: Unlocking only "
         "removes the locked attribute from the particular set-way. It "
         "does not alter its modified state (which was set when the line "
         "was locked and zeroed).";
      field {
         property title =
            "Set";
         property description =
            "Physical Address. Indicates the physical address in the cache "
            "to be unlocked.";
      } [9:6] set;
      field {
         property title =
            "Way";
         property description =
            "Way. Indicates the way in the cache to be unlocked.";
      } [56:55] way;
   } [0x7ff] co_unlock_sw;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "tensor_reduce control";
      property description =
         "Tensor reductions instructions are the pseudo-instructions "
         "encoded as writes to CSR 0x800 (tensor_reduce). These "
         "instructions can be used to transfer and operate on tensor data "
         "among harts. It is the responsibility of the software to make "
         "sure that the appropriate conditions mentioned in PRM-10 are met "
         "when using these instructions otherwise the behavior of the "
         "system becomes undefined. The instructions covered here are: "
         "TensorSend, TensorRecv, TensorReduce, TensorBroadcast.";
      field {
         property title =
            "Encoding to determine which Tensor Reduce Op";
         property description =
            "See PRM-10 for complete details. For the tensor reduce "
            "instruction, this field contains a value of 2'b11.\n"
            "00 - TensorSend\n"
            "01 - TensorRecv\n"
            "10 - TensorBroadcast\n"
            "11 - TensorReduce";
      } [1:0] tensor_op_encoding;
      field {
         property description =
            "Tree depth. This field is in the PRM-10 register "
            "descriptions, so I added it here. Note that this field "
            "overlaps with bits [15:3].";
      } [6:3] tree_depth;
      field {
         property title =
            "Minion ID";
         property description =
            "This field is not in the PRM-10 register description.";
      } [15:7] minion_id;
      field {
         property title =
            "Number of FP regs";
         property description =
            "Number of floating-point registers. The Ax values to be sent "
            "are stored in bits [22:16] consecutive floating-point "
            "registers starting from the register number specified in bits "
            "[61:57], wrapping around to f0 when reaching f31.\n"
            "The Ay values to be operated on are stored in bits [22:16] "
            "consecutive floating-point registers starting from the "
            "register number specified in bits [61:57], wrapping around to "
            "f0 when reaching f31.\n"
            "The Az values are stored in bits [22:16] consecutive "
            "floating-point registers starting from the register number "
            "specified in bits [61:57], wrapping around to f0 when "
            "reaching f31.\n"
            "If bits [22:16] encode a value of 0, then no operation is "
            "performed.";
      } [22:16] num_regs;
      field {
         property title =
            "Sub-operation to be performed";
         property description =
            "Some pseudo-instructions like "
            "TensorRecv/TensorReduce/TensorBroadcast use this field to "
            "encode sub-operations to be performed. The TensorReduce "
            "pseudo-instruction allows a group of up to 1024 harts, on "
            "different Minions (but only hart 0 of the Minion), to "
            "communicate values held in floating-point registers to "
            "collectively calculate a reduction function A=f(A0,...,An-1). "
            "The function to be performed is specified in bits [27:24]. "
            "The encoding of this field is as follows:\n"
            " \n"
            "0000 - fadd. The fadd reduction operation uses the rounding "
            "mode specified in FRM.\n"
            "0010 - fmax\n"
            "0011 - fmin\n"
            "0100 - iadd\n"
            "0110 - imax\n"
            "0111 - imin\n"
            "1000 - fget\n"
            "\n"
            "If bits [27:24] encodes ‘fadd’ and frm encodes an invalid "
            "rounding mode, an illegal instruction trap is generated, even "
            "if bits [22:16] encodes a value of 0.\n"
            "If bits [27:24] encodes a non-existent function and the "
            "Minion is a receiver, then the operation is not performed and "
            "tensor_error[9] is set, even if bits [22:16] encodes a value "
            "of 0.";
      } [27:24] sub_op;
      field {
         property title =
            "Starting FP register";
         property description =
            "Starting floating-point register.";
      } [61:57] start_reg;
   } [0x800] tensor_reduce;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "tensor_fma control";
      property description =
         "TensorFMA instructions are the pseudo-instructions encoded as "
         "writes to CSR 0x801 (tensor_fma). Bits [3:1] of the source "
         "operand value encodes one of the TensorFMA variants described "
         "below. When bits [3:1] do not encode one of the operations "
         "listed in this document then an illegal instruction exception "
         "trap is raised.";
      field {
         property title =
            "Clear source FP registers before starting operation";
         property description =
            "See PRM-10 for complete details.\n"
            "TensorFMA32/TensorFMA16A32 - If set to 1 then the source "
            "floating-point registers are cleared before starting the "
            "operation\n"
            "TensorIMA8A32 - If set to 0, initial value of TenC is added "
            "to the result.";
      } [0] set_clear;
      field {
         property title =
            "Tensor Type";
         property description =
            "See PRM-10 for complete details\n"
            "000 - TensorFMA32\n"
            "001 - TensorFMA16A32\n"
            "011 - TensorIMA8A32";
      } [3:1] tensor_type;
      field {
         property title =
            "Starting L1 scratchpad cache line where matrix A is stored";
         property description =
            "Starting L1 scratchpad cache line where matrix A is stored.";
      } [9:4] l1scp_start_line_a;
      field {
         property title =
            "Starting L1 scratchpad cache line where matrix B is stored, "
            "ignored when xs[20] =1";
         property description =
            "Starting L1 scratchpad cache line where matrix B is stored, "
            "ignored when bit [20] = 1.";
      } [17:12] l1scp_start_line_b;
      field {
         property title =
            "Location of matrix B (0=L1 scratchpad, 1=memory)";
         property description =
            "Location of matrix B\n"
            "0 = L1 scratchpad\n"
            "1 = Memory";
      } [20] loc_b;
      field {
         property title =
            "A matrix starting column (inside the L1 scratchpad line) for "
            "the operation divided by SIZE.";
         property description =
            "A matrix starting column (inside the L1 scratchpad line) for "
            "the operation divided by SIZE.";
      } [46:43] a_start_col;
      field {
         property title =
            "A matrix number of columns divided by SIZE (minus 1)";
         property description =
            "A matrix number of columns divided by SIZE (minus 1).\n"
            "TensorIMA8A32: SIZE = 4\n"
            "TensorFMA16A32: SIZE = 2\n"
            "TensorFMA32: SIZE = 1";
      } [50:47] a_num_cols;
      field {
         property title =
            "A matrix number of rows (minus 1)";
         property description =
            "A matrix number of rows (minus 1).";
      } [54:51] a_num_rows;
      field {
         property title =
            "B matrix number of columns divided by 4 (minus 1)";
         property description =
            "B matrix number of columns divided by 4 (minus 1).";
      } [56:55] b_num_cols;
      field {
         property title =
            "Use tensor_mask CSR to skip operations in an A row "
            "granularity";
         property description =
            "When this bit is set, use the tensor_mask CSR to skip "
            "operations in an A row granularity.";
      } [63] use_tensor_mask;
   } [0x801] tensor_fma;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "convolution size: sets tensor_mask indirectly";
      property description =
         "This CSR specifies the number of rows and columns of the 2D "
         "array used for convolutions. Additionally, this CSR specifies "
         "how many elements (in terms of number of rows and columns) to "
         "step over when performing the next memory operation in a "
         "TensorLoad/CacheOp-generated sequence of operations. Reading "
         "this register returns a value of 0.\n"
         "\n"
         "When this register is written, the hardware computes a new value "
         "for tensor_mask indicating which TensorLoad/CacheOp accesses "
         "fall within the 2D array and which outside of it, as shown in "
         "tensor_mask CSR.";
      field {
         property title =
            "Number of Columns";
         property description =
            "Number of columns, interpreted as unsigned integer.";
      } [15:0] ncol;
      field {
         property title =
            "Column Step";
         property description =
            "Column step, interpreted as signed integer.";
      } [31:24] scol;
      field {
         property title =
            "Number of Rows";
         property description =
            "Number of rows, interpreted as unsigned integer.";
      } [47:32] nrow;
      field {
         property title =
            "Row Step";
         property description =
            "Row step, interpreted as signed integer.";
      } [63:56] srow;
   } [0x802] tensor_conv_size;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "convolution control: sets tensor_mask indirectly";
      property description =
         "This CSR encodes the location of a TensorLoad instruction inside "
         "a large 2D array, in terms of a starting row number and a "
         "starting column number of the array. The array dimensions are "
         "specified in the tensor_conv_size CSR. The starting row and "
         "column numbers can specify negative offsets to indicate that the "
         "TensorLoad is starting outside the 2D array. \n"
         "Reading this register returns a value of 0.\n"
         "When this register is written, the hardware computes a new value "
         "for tensor_mask indicating which TensorLoad/CacheOp accesses "
         "fall within the 2D array and which outside of it, as shown in "
         "tensor_mask CSR.";
      field {
         property title =
            "Starting Column";
         property description =
            "Interpreted as a signed integer.";
      } [15:0] colstart;
      field {
         property title =
            "Starting Row";
         property description =
            "Interpreted as a signed integer.";
      } [47:32] rowstart;
   } [0x803] tensor_conv_ctrl;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Cooperation Info used by TensorLoad";
      property description =
         "The tensor_coop CSR is used to reduce L2 bandwidth when several "
         "harts on different Minions (but only hart 0 of the Minion) in "
         "the same neighborhood are requesting the same cache line(s) "
         "using TensorLoad instructions. The fields coopneighmask and "
         "coopminmask define which hart 0s will participate in the "
         "cooperative TensorLoad. Cooperative TensorLoads, from hart 0s "
         "specified by the (coopid, coopneighmask, coopminmask) tuple must "
         "use the same address, TensorLoad variant, and tensor_mask value, "
         "otherwise it depends on the implementation which address/variant "
         "will be used for reading from memory, although it is guaranteed "
         "to be the address/variant of one of the participating "
         "cooperative TensorLoads. \n"
         "\n"
         "For the purposes of this operation, address means: Physical "
         "address if virtual memory is disabled. A cooperative TensorLoad "
         "instruction from a hart specified in the (coopid, coopneighmask, "
         "coopminmask) tuple cannot complete until all other harts "
         "specified in the same (coopid, coopneighmask, coopminmask) tuple "
         "have executed a cooperative TensorLoad instruction. Concurrently "
         "executing cooperative TensorLoads with the same coopid inside a "
         "neighborhood leads to undefined behavior. This means that inside "
         "a shire, multiple TensorLoads with the same coopid can execute "
         "concurrently only if their corresponding coopneighmask values do "
         "not overlap, otherwise the behavior of the system becomes "
         "undefined. If SW wants to re-use a coopid, it must use some "
         "external synchronization mechanism to guarantee that the "
         "execution of the last TensorLoad with the same coopid has "
         "completed across all cooperating harts before executing the new "
         "TensorLoad instruction. Note: Look for a separate document "
         "called Minion Shire Coop Toad which has some examples of "
         "TensorLoad-related thread synchronization cases. Reading the "
         "tensor_coop register returns a value of 0.";
      field {
         property title =
            "Neighborhood cooperation mask";
         property description =
            "Coopneighmask is a bit mask, where the n-th bit corresponds "
            "to the n-th neighborhood in a shire.";
      } [0] coopneighmask;
      field {
         property title =
            "Minion cooperation mask";
         property description =
            "Coopminmask is a bit mask, where the n-th bit corresponds to "
            "the n-th Minion in a neighborhood.";
      } [1] coopminmask;
      field {
         property title =
            "Cooperation ID";
         property description =
            "Coopid is an integer, in the range 0-15, used by hardware to "
            "coordinate simultaneous cooperative loads across multiple "
            "minions and neighborhoods.";
      } [2] coopid;
   } [0x804] tensor_cooperation;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Mask info used by TensorLoad ";
      property description =
         "The TensorLoad, TensorFMA and CacheOp instructions can operate "
         "under the control of the tensor_mask CSR. The tensor_mask CSR "
         "contains one bit for each of the destination lines that "
         "TensorLoad can potentially write into the scratchpad. The value "
         "of the tensor_mask CSR can be set either directly or indirectly "
         "by writing into the tensor_conv_size or tensor_conv_ctrl CSRs, "
         "which will cause the computation of a mask that will be written "
         "into the tensor_mask CSR. See pseudo-code operation in PRM-10.";
      field {
         property title =
            "Tensor Mask";
         property hardware_volatile = true;
      } [15:0] tensormask;
   } [0x805] tensor_mask;
   register {
      (* Documentation_Source = "PRM-10, Section 1.5.1." *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Quantization pseudo-instruction";
      property description =
         "The TensorQuant pseudo-instruction performs a sequence of up to "
         "10 transformations to a matrix A. Each transformation is "
         "executed sequentially, starting with the transformation located "
         "in position 0 of the list (xs[3:0]) up to position 9 "
         "(xs[39:36]). Each transformation writes its result into A. If a "
         "transformation has the encoding 0 (LAST), no more "
         "transformations will be executed. Transformations that operate "
         "on floating-point values use the rounding mode specified in "
         "FRM.The A matrix is stored in N=(xs[54:51]+1)*(xs[56:55]+1)/2 "
         "consecutive floating-point registers starting from the register "
         "number specified in xs[61:57], wrapping around to f0 when "
         "reaching f31. There are currently 11 transformation functions, "
         "including LAST, encoded. See PRM-10 for more details.  Note that "
         "there are 11 transformations in PRM-10, not 10 as listed below.";
      field {
         property title =
            "Transformation 0";
         property description =
            "LAST: Do not perform any more transformations";
      } [3:0] transform_0;
      field {
         property title =
            "Transformation 1";
         property description =
            "INT32_TO_FP32: Convert all elements of A from INT32 to FP32.";
      } [7:4] transform_1;
      field {
         property title =
            "Transformation 2";
         property description =
            "FP32_TO_INT32: Convert all elements of A from FP32 to INT32.";
      } [11:8] transform_2;
      field {
         property title =
            "Transformation 3";
         property description =
            "RELU: Convert all negative INT32 values in A to 0";
      } [15:12] transform_3;
      field {
         property title =
            "Transformation 4";
         property description =
            "INT32_ADD_ROW: Read a vector of sixteen INT32 values from the "
            "L1 scratchpad, and add the first N elements to every row of "
            "the INT32 matrix A, where N is the number of columns of A.";
      } [19:16] transform_4;
      field {
         property title =
            "Transformation 5";
         property description =
            "INT32_ADD_COL: Read a vector of sixteen INT32 values from the "
            "L1 scratchpad, and add the first N elements to every column "
            "of the INT32 matrix A, where N is the number of rows of A.";
      } [23:20] transform_5;
      field {
         property title =
            "Transformation 6";
         property description =
            "FP32_MUL_ROW: Read a vector of sixteen FP32 values from the "
            "L1 scratchpad, and multiply the first N elements with every "
            "row of the FP32 matrix A, where N is the number of columns of "
            "A.";
      } [27:24] transform_6;
      field {
         property title =
            "Transformation 7";
         property description =
            "FP32_MUL_COL: Read a vector of sixteen FP32 values from the "
            "L1 scratchpad, and multiply the first N elements with every "
            "column of the FP32 matrix A, where N is the number of rows of "
            "A.";
      } [31:28] transform_7;
      field {
         property title =
            "Transformation 8";
         property description =
            "SATINT8: Clamp all elements of A from INT32 to the range "
            "[-128, 127]. The values are stored in the low-order byte of "
            "each element.";
      } [35:32] transform_8;
      field {
         property title =
            "Transformation 9";
         property description =
            "SATUINT8: Clamp all elements of A from INT32 to the range [0, "
            "255]. The values are stored in the low-order byte of each "
            "element.";
      } [39:36] transform_9;
      field {
         property title =
            "L1 scratchpad cache line where the first vector is stored";
         property description =
            "L1 scratchpad cache line where the first vector is stored";
      } [50:45] l1scp_start_line;
      field {
         property title =
            "A matrix number of rows (minus 1)";
         property description =
            "A matrix number of rows (minus 1)";
      } [54:51] a_matrix_num_rows;
      field {
         property title =
            "A matrix number of columns divided by 4 (minus 1)";
         property description =
            "A matrix number of columns divided by 4 (minus 1)";
      } [56:55] a_matrix_num_cols;
      field {
         property title =
            "Start register";
      } [61:57] start_reg;
   } [0x806] tensor_quant;
   register {
      (* Documentation_Source = "PRM-14" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property description =
         "Technically, this belongs to the Esperanto Texturization "
         "Extension. However, it is currently using offsets in Tensor "
         "Extension.";
      field {
         (* Documentation_Source = "PRM-14" *)
         (* Group = "ET_TensorExtension" *)
         (* RISCV_Privilege_Level = "user" *)
         property description =
            "Technically, this belongs to the Esperanto Texturization "
            "Extension. However, it is currently using offsets in Tensor "
            "Extension.";
         property hardware_volatile = false;
      } [63:0] tex_send;
   } [0x807] tex_send;
   register {
      (* Documentation_Source = "PRM-10, Section 1.1.5." *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property description =
         "The tensor_error register records miscellaneous error conditions "
         "occurred during the execution of tensor pseudo-instructions and "
         "cache management operations. When the execution of a tensor or "
         "cache management instruction generates a synchronous fault, the "
         "tensor_error register is updated with the fault condition and no "
         "trap is generated. Asynchronous faults (i.e., a bus errors) "
         "generated by tensor or cache management instructions are not "
         "captured in tensor_error and are not suppressed. The various "
         "fault bits in tensor_error register are never cleared by the "
         "hardware (i.e., the bits are sticky). It is the responsibility "
         "of the software to clear tensor_error. The value of tensor_error "
         "is guaranteed to be up-to-date only after executing a TensorWait "
         "instruction. Software is expected to, at least periodically, "
         "read the value of tensor_error to check for problems found "
         "during the execution of such instructions.";
      field {
         property title =
            "TensorLoad configured with wrong transform field";
         property description =
            "TensorLoad configured with wrong transform field.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [1] wrong_tload_txform;
      field {
         property title =
            "Fast Credit Counter Overflow";
         property description =
            "Fast Credit Counter Overflow.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [3] fcc_overflow;
      field {
         property title =
            "L1 scratchpad disabled when operation requires it";
         property description =
            "L1 scratchpad disabled when operation requires it.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [4] l1_scp_disabled;
      field {
         property title =
            "LockSW failed";
         property description =
            "LockSW failed.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [5] lock_sw_failed;
      field {
         property title =
            "Invalid combination of TensorStore cooperation and size";
         property description =
            "Invalid combination of TensorStore cooperation and size.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [6] ill_tb_tfma_pair;
      field {
         property title =
            "Tensor Load/Store or Cache-op generated Memory Fault";
         property description =
            "Tensor Load/Store or Cache-op generated Memory Fault.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [7] mem_fault;
      field {
         property title =
            "Illegal tensor send/recv partner or illegal reduction "
            "operation specified";
         property description =
            "Illegal tensor send/recv partner or illegal reduction "
            "operation specified.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [8] inv_comb_store_size;
      field {
         property title =
            "illegal_tensor_send_rcv";
         property description =
            "illegal_tensor_send_rcv.";
         property write_function = "zero_clear";
         property hardware_volatile = true;
      } [9] illegal_tensor_send_rcv;
   } [0x808] tensor_error;
   register {
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Scratchpad Control for DCache";
      property description =
         "User-level software, executing on thread 0 of a Minion core, can "
         "set the SCPEnable bit using the ucache_control CSR, which is an "
         "alias of the mcache_control register that only allows changing "
         "SCPEnable. Note that writes to SCPEnable while D1Split is zero "
         "or from thread 1 of a Minion core are ignored, and do not change "
         "the cache configuration. User-level software, from both threads "
         "of a Minion core, is also allowed to set the CacheOp control "
         "fields of ucache_control.";
      field {
         property description =
            "Read-only shadow of mcache_control[0]";
         property write_access = false;
         property field_type = "status";
         property input_value = true;
      } [0] D1Split;
      field {
         property description =
            "Shadow of mcache_control[1]. Writeable by thread 0 when "
            "D1Split equals 1";
         property hardware_volatile = true;
      } [1] SCPEnable;
      field {
         property description =
            "CacheOp_RepRate is a 3 bit field that encodes the repeat rate "
            "at which the above cache operations can inject requests into "
            "the system. The 3 bit field encodes the log2 of the number of "
            "cycles to be inserted in between requests. Thus a value of 6 "
            "would represent that the cache op engine would wait 64 cycles "
            "before injecting the next cache op request into the system. A "
            "value of 0 indicates no delay and should be used for maximum "
            "throughput on the above operations.";
      } [4:2] CacheOp_RepRate;
      field {
         property description =
            "CacheOp_Max is a 5 bit field that encodes the number of "
            "outstanding requests that the above instructions may issue "
            "from a given minion. Encoding 0 indicates no limit. Other "
            "values, from 1 to 31, encode the maximum number of requests "
            "injected into the L2/L3";
         property reset_value = 5'd8;
      } [10:6] CacheOp_Max;
   } [0x810] ucache_control;
   register {
      (* Documentation_Source = "PRM-8" *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "user level prefetch cache operation";
      property description =
         "User-level software can prefetch a particular address from "
         "memory with this Cache op pseudo-instruction.";
      field {
         property title =
            "Number of Lines (minus 1)";
         property description =
            "This field stores the number of lines (minus 1). Maximum "
            "value is 15";
      } [3:0] num_lines;
      field {
         property title =
            "Virtual Address[47:6]";
         property description =
            "This field stores bits 47:6 of the virtual address";
      } [47:6] va;
      field {
         property title =
            "Destination Level";
         property description =
            "The values are as follows: \n"
            "00 - L1\n"
            "01 - L2\n"
            "10 - L3\n"
            "11 - MEM";
      } [59:58] dest_level;
      field {
         property title =
            "Use the tensor_mask CSR";
      } [63] use_tensor_mask;
   } [0x81f] co_prefetch_va;
   register {
      (* Group = "ET_FastLocalBarrier" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Fast Local Barrier";
      property description =
         "The FLBarrier pseudo-instruction allows one minion to join one "
         "of the 32 barriers. The instruction atomically increments the "
         "barrier counter specified in xs[4:0]. After incrementing, the "
         "barrier counter is compared to the value xs[12:5]+1. On match, "
         "xd is set to 1 and the barrier counter is reset to zero. "
         "Otherwise, xd is set to 0. Notice that if software erroneously "
         "provides an xs[12:5] value smaller than the current value in the "
         "barrier counter, the atomic increment will still unconditionally "
         "happen and xd will be set to 0.";
      field {
         property title =
            "Barrier Number";
         property description =
            "Barrier number.";
      } [4:0] barrier_number;
      field {
         property title =
            "Match Value - 1";
         property description =
            "Match value.";
      } [12:5] match_value;
   } [0x820] flb;
   register {
      (* Group = "ET_FastCreditCounter" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Fast Credit Counter";
      property description =
         "Writing this register will block if the selected credit counter "
         "value is zero, until a credit or an interrupt is received. If "
         "the selected counter value is larger than zero, then it "
         "atomically decrements by one. Note that accesses that do not "
         "write the register, such as CSRRS/CSRRC with x0, or "
         "CSRSSI/CSRRCI with 0, do not block nor decrement the counter.";
      field {
         property title =
            "Selected Credit Counter Index";
      } [0] counter_index;
   } [0x821] fcc;
   register {
      (* Documentation_Source = "PRM-0, Section 16.6." *)
      (* Group = "ET_SpecificCSRs" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Stall CSR (wait for redirect)";
      property description =
         "When read, this u-mode CSR stalls the hart, similarly to issuing "
         "a WFI in m-mode. If an interrupt is delivered to the core, "
         "caused by writing the IPI_REDIRECT_TRIGGER ESR with a bit "
         "corresponding to the hart set, and the IPI_REDIRECT_FILTER ESR "
         "has the bit corresponding to the hart set, and the hart was in "
         "U-mode, then the hart will vector to the location configured in "
         "the IPI_REDIRECT_PC ESR. If the hart was not stalled on the "
         "STALL CSR or the hart is not in u-mode, then the hart will trap "
         "with cause 0x10. Reading this register returns a 0x0 value.";
      field {
         (* Documentation_Source = "PRM-0, Section 16.6." *)
         (* Group = "ET_SpecificCSRs" *)
         (* RISCV_Privilege_Level = "user" *)
         property title =
            "Stall CSR (wait for redirect)";
         property description =
            "When read, this u-mode CSR stalls the hart, similarly to "
            "issuing a WFI in m-mode. If an interrupt is delivered to the "
            "core, caused by writing the IPI_REDIRECT_TRIGGER ESR with a "
            "bit corresponding to the hart set, and the "
            "IPI_REDIRECT_FILTER ESR has the bit corresponding to the hart "
            "set, and the hart was in U-mode, then the hart will vector to "
            "the location configured in the IPI_REDIRECT_PC ESR. If the "
            "hart was not stalled on the STALL CSR or the hart is not in "
            "u-mode, then the hart will trap with cause 0x10. Reading this "
            "register returns a 0x0 value.";
         property hardware_volatile = false;
      } [63:0] stall;
   } [0x822] stall;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property description =
         "Due to the high concurrency offered by the different Esperanto "
         "Tensor instructions, it is sometimes necessary for software to "
         "wait for a previously issued tensor instruction (or cacheop) "
         "before proceeding. To this end, the TensorWait CSR register is "
         "provided. The full table of event ID(s) is available in PRM-10. "
         "To wait for the completion of an L1 prefetch instruction, "
         "Software must execute a TensorWait with ID = 6, followed by a "
         "FENCE instruction. At most one event can be waited-for "
         "concurrently. Software uses any of the CSR write instructions to "
         "write the ID into the TensorWait CSR. If specified event is "
         "still in progress, then the write blocks until the event "
         "finishes (or an interrupt occurs). Otherwise it behaves like a "
         "NOP. Returns value 0 in 'xd'.";
      field {
         property title =
            "ID of the event to wait for";
         property description =
            "Field encoding is as follows:\n"
            "0x0 - TensorLoad_0. TensorLoad to L1 Scratchpad with ID = 0 "
            "is complete.\n"
            "0x1 - TensorLoad_1. TensorLoad to L1 Scratchpad with ID = 1 "
            "is complete.\n"
            "0x2 - TensorLoad2_0. TensorLoadL2 with ID = 0 is complete.\n"
            "0x3 - TensorLoad2_1. TensorLoadL2 with ID = 1 is complete.\n"
            "0x4 - Prefetch_0. Prefetch to L2/L3 with ID = 0 is complete.\n"
            "0x5 - Prefetch_1. Prefetch to L2/L3 with ID = 1 is complete.\n"
            "0x6 - Cacheop. All previous Cacheops are complete.\n"
            "0x7 - TensorFMA. TensorFMA is complete.\n"
            "0x8 - TensorStore. TensorStore/TensorStoreFromScp  is "
            "complete.\n"
            "0x9 - TensorReduce. TensorReduce is complete.\n"
            "0xA - TensorQuant. TensorQuant is complete.";
      } [3:0] event_id;
   } [0x830] tensor_wait;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property description =
         "TensorLoad is a pseudo-instruction that loads data from memory "
         "(bypassing the L1) into the L1 scratchpad. The data to be loaded "
         "is specified using a base address, a stride, and a count of "
         "cache lines to be loaded specified in xs. The data is written "
         "into the L1 scratchpad at the provided starting cache line "
         "(xs[58:53]). TensorLoad supports cooperative operation with the "
         "other Minions in the same neighborhood. The tensor_mask CSR "
         "controls which cache lines are loaded from memory. Tensor Load "
         "operations implicitly use x31[47:6] for the stride value, x31[0] "
         "for ID. For more information, please refer to PRM-10. ";
      field {
         property title =
            "Number of Lines (minus 1)";
      } [3:0] num_lines;
      field {
         property title =
            "Virtual Address ";
         property description =
            "Lower 6-bits omitted";
      } [47:6] va;
      field {
         property title =
            "Is Tensor B?";
         property description =
            "if (TensorLoadSetupB) value = 1, else value = 0";
      } [52] is_tensor_b;
      field {
         property title =
            "L1 Scratchpad starting cache line";
         property description =
            "L1 Scratchpad starting cache line,";
      } [58:53] l1_scp_start_cl;
      field {
         property title =
            "Tensor Load variant";
         property description =
            "Look at PRM-10 for complete details.  Some examples shown "
