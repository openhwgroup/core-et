   register {
      (* Documentation_Source = "PRM-0" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "Gather/Scatter Progress";
      property description =
         "The Gather/Scatter Progress (GSC_PROGRESS) register is a 3-bit "
         "read/write register, holding an integer value. The value of the "
         "register denotes the next element to be processed by a Gather or "
         "Scatter SIMD operation.";
      field {
         property title =
            "Gather/Scatter Progress value N";
         property description =
            "When a gather or scatter operation is interrupted halfway "
            "through its execution while processing the n-th element of a "
            "vector, and the processing of the n-th element is not "
            "complete, then the GSC_PROGRESS register is written with the "
            "value n. When a gather or scatter instruction executes "
            "successfully the value of GSC_PROGRESS is set to 0.";
         property hardware_volatile = true;
      } [2:0] gsc_progress;
   } [0x840] gsc_progress;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      property description =
         "See PRM-10 for complete details. Translates the given VA to a "
         "PA, issues a read request to the next hierarchy level after L2 "
         "and writes the data in the L2 scratchpad position specified by "
         "the instruction. If NumLines > 0, it adds the stride in the x31 "
         "register to the VA, increments the L2 scratchpad destination by "
         "1 and repeats the operation as many times as indicated by the "
         "NumLines field. Always returns 0 in xd. Implicitly uses register "
         "x31[47:6] for the stride value, x31[0] for ID.";
      field {
         property title =
            "NumLines (minus 1)";
         property description =
            "NumLines (minus 1)";
      } [3:0] num_lines;
      field {
         property title =
            "L2 Scratchpad starting cache line (PhysAddr[7:6])";
         property description =
            "L2 Scratchpad starting cache line (PhysAddr[7:6])";
      } [5:4] l2scp_start_line_7_6;
      field {
         property title =
            "Virtual Address (bits [47:6])";
         property description =
            "Virtual Address (bits [47:6])";
      } [47:6] va;
      field {
         property title =
            "L2 scratchpad starting cache line (PhysAddr[22:8])";
         property description =
            "L2 scratchpad starting cache line (PhysAddr[22:8])";
      } [62:48] l2scp_start_line_22_8;
      field {
         property title =
            "Use the tensor_mask CSR";
         property description =
            "Use the tensor_mask CSR";
      } [63] use_tensor_mask;
   } [0x85f] tensor_load_l2scp;
   register {
      (* Documentation_Source = "PRM-10" *)
      (* Group = "ET_TensorExtension" *)
      (* RISCV_Privilege_Level = "user" *)
      field {
         property title =
            "Virtual Address";
         property description =
            "For TensorStore bits 47:4 are used for VA. For "
            "TensorStoreFromSCP bits 47:6 are used for VA. Lower order "
            "bits are omitted. ";
      } [47:4] va;
      field {
         property title =
            "Encoding to determine which Tensor Store Op";
         property description =
            "0 - TensorStore; 1 - TensorStoreFromSCP";
      } [48] tensor_op_encoding;
      field {
         property title =
            "Number of minions to cooperate with (minus 1)";
         property description =
            "Used for TensorStore only. Unused for TensorStoreFromSCP.";
      } [50:49] num_coop_minions;
      field {
         property title =
            "Number of Rows/Lines";
         property description =
            "For TensorStore, A-matrix number of rows (minus 1), for "
            "TensorStoreFromSCP number of lines (minus 1)";
      } [54:51] num_rows;
      field {
         property title =
            "Start Register/L1SCP Starting Cacheline";
         property description =
            "For TensorStore:\n"
            "[61:57] - Start Register\n"
            "[56:55] - A-Matrix row size in groups of 16B (minus 1); MUST "
            "be a power of 2\n"
            "For TensorStoreFromSCP:\n"
            "[61:56] - L1SCP Starting Cache Line\n"
            "[55]: Reserved";
      } [61:55] start_size;
      field {
         property title =
            "Register/L1SCP stride (minus 1)";
