            "The mstatus register is an MXLEN-bit read/write register that "
            "keeps track of and controls the hart’s current operating "
            "state. Restricted views of the mstatus register appear as the "
            "sstatus and ustatus registers in the S-level and U-level ISAs "
            "respectively. For more information, refer to Section 3.1.6 of "
            "the RISC-V Privileged Architecture Specification, Volume II.";
         property hardware_volatile = false;
      } [63:0] mstatus;
   } [0x300] mstatus;
   register {
      (* Group = "MachineTrapSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "ISA and extensions";
      property description =
         "The misa CSR is a WARL read-write register reporting the ISA "
         "supported by the hart. This register is encoded as follows:\n"
         "63:62 - MXL[1:0]. A value of 10 in this bit indicates a 64-bit "
         "register width. Other values are 01 (32-bit) and 11 (128-bit).\n"
         "61:26 - WLRL. Write legal and read legal values.\n"
         "25:0 - EXTENSION. The Extensions field encodes the presence of "
         "the standard extensions, with a single bit per letter of the "
         "alphabet (bit 0 encodes presence of extension “A” , bit 1 "
         "encodes presence of extension “B”, through to bit 25 which "
         "encodes “Z”). For the definition of each letter, refer to "
         "Table 3-2 of the RISC-V Privileged Architecture Specification, "
         "Volume II.";
      field {
         (* Group = "MachineTrapSetup" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "ISA and extensions";
         property description =
            "The misa CSR is a WARL read-write register reporting the ISA "
            "supported by the hart. This register is encoded as follows:\n"
            "63:62 - MXL[1:0]. A value of 10 in this bit indicates a "
            "64-bit register width. Other values are 01 (32-bit) and 11 "
            "(128-bit).\n"
            "61:26 - WLRL. Write legal and read legal values.\n"
            "25:0 - EXTENSION. The Extensions field encodes the presence "
            "of the standard extensions, with a single bit per letter of "
            "the alphabet (bit 0 encodes presence of extension “A” , "
            "bit 1 encodes presence of extension “B”, through to bit "
            "25 which encodes “Z”). For the definition of each letter, "
            "refer to Table 3-2 of the RISC-V Privileged Architecture "
            "Specification, Volume II.";
         property reset_value = 64'h8000000000941124;
         property hardware_volatile = false;
      } [63:0] misa;
   } [0x301] misa;
   register {
      (* Documentation_Source = "Section 3.1.8, RISC-V Volume II" *)
      (* Group = "MachineTrapSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine exception delegation register";
      property description =
         "By default, all traps at any privilege level are handled in "
         "machine mode, though a machine-mode handler can redirect traps "
         "back to the appropriate level with the MRET instruction. To "
         "increase performance, implementations can provide individual "
         "read/write bits within medeleg and mideleg to indicate that "
         "certain exceptions and interrupts should be processed directly "
         "by a lower privilege level. The machine exception delegation "
         "register (medeleg) and machine interrupt delegation register "
         "(mideleg) are MXLEN-bit read/write registers.\n"
         "\n"
         "In systems with all three privilege modes (M/S/U), setting a bit "
         "in medeleg or mideleg will delegate the corresponding trap in "
         "S-mode or U-mode to the S-mode trap handler. If U-mode traps are "
         "supported, S-mode may in turn set corresponding bits in the "
         "sedeleg and sideleg registers to delegate traps that occur in "
         "U-mode to the U-mode trap handler. In systems with S-mode, the "
         "medeleg and mideleg registers must exist, whereas the sedeleg "
         "and sideleg registers should only exist if the N extension for "
         "user-mode interrupts is also implemented. For an encoding of "
         "this register, refer to Table 3-6 of the RISC-V specification, "
         "volume II.";
      field {
         (* Documentation_Source = "Section 3.1.8, RISC-V Volume II" *)
         (* Group = "MachineTrapSetup" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine exception delegation register";
         property description =
            "By default, all traps at any privilege level are handled in "
            "machine mode, though a machine-mode handler can redirect "
            "traps back to the appropriate level with the MRET "
            "instruction. To increase performance, implementations can "
            "provide individual read/write bits within medeleg and mideleg "
            "to indicate that certain exceptions and interrupts should be "
            "processed directly by a lower privilege level. The machine "
            "exception delegation register (medeleg) and machine interrupt "
            "delegation register (mideleg) are MXLEN-bit read/write "
            "registers.\n"
            "\n"
            "In systems with all three privilege modes (M/S/U), setting a "
            "bit in medeleg or mideleg will delegate the corresponding "
            "trap in S-mode or U-mode to the S-mode trap handler. If "
            "U-mode traps are supported, S-mode may in turn set "
            "corresponding bits in the sedeleg and sideleg registers to "
            "delegate traps that occur in U-mode to the U-mode trap "
            "handler. In systems with S-mode, the medeleg and mideleg "
            "registers must exist, whereas the sedeleg and sideleg "
            "registers should only exist if the N extension for user-mode "
            "interrupts is also implemented. For an encoding of this "
            "register, refer to Table 3-6 of the RISC-V specification, "
            "volume II.";
         property hardware_volatile = false;
      } [63:0] medeleg;
   } [0x302] medeleg;
   register {
      (* Documentation_Source = "Section 3.1.8, RISC-V Volume II" *)
      (* Group = "MachineTrapSetup" *)
