      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine bad address or instruction";
      property description =
         "The mtval register is an MXLEN-bit read-write register. When a "
         "trap is taken into M-mode, mtval is either set to zero or "
         "written with exception-specific information to assist software "
         "in handling the trap. Otherwise, mtval is never written by the "
         "implementation, though it may be explicitly written by software. "
         "The hardware platform will specify which exceptions must set "
         "mtval informatively and which may unconditionally set it to "
         "zero.";
      field {
         (* Documentation_Source = "Section 3.1.17, RISC-V Spec Volume II" *)
         (* Group = "MachineTrapHandling" *)
         (* RISCV_Privilege_Level = "machine" *)
