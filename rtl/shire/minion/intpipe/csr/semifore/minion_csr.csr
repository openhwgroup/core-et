      (* Group = "ET_FastCreditCounter" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "non blocking read of FCC registers";
      property description =
         "Reading from this read-only register returns the current value "
         "in the two credit counters of the hart. This operation is "
         "non-blocking.";
      property write_access = false;
      field {
         property title =
            "Credit Counter 0 value";
         property description =
            "Returns the value of the hart's first credit counter in bits "
            "[15:0].";
         property field_type = "status";
         property input_value = true;
      } [15:0] credit_0;
      field {
         property title =
            "Credit Counter 1 value";
         property description =
            "Returns the value of the hart's second credit counter in bits "
            "[31:16].";
         property field_type = "status";
         property input_value = true;
      } [31:16] credit_1;
   } [0xcc0] nb_fcc;
