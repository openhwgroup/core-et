            "written with exception-specific information to assist "
            "software in handling the trap. Otherwise, mtval is never "
            "written by the implementation, though it may be explicitly "
            "written by software. The hardware platform will specify which "
            "exceptions must set mtval informatively and which may "
            "unconditionally set it to zero.";
         property hardware_volatile = false;
      } [63:0] mtval;
