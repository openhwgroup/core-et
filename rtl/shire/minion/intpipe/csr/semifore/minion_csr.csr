      property title =
         "User-Level Lock VA Cache operation";
      property description =
         "User-level software can soft-lock and zero a cache line with "
         "this Cache op pseudo-instruction. ";
      field {
         property title =
            "Number of Lines (minus 1)";
         property description =
            "Number of lines. If more than one line is selected using this "
            "field, then the VA is incremented by the stride, and the "
            "process repeats as many times as indicated by xs[3:0]+1.";
      } [3:0] num_lines;
      field {
