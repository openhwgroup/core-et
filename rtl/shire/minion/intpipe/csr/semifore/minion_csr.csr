      property title =
         "Supervisor trap handler base address";
      property description =
         "The stvec register stores the trap vector configuration, "
         "consisting of a vector base address (BASE) and a vector mode "
         "(MODE). Bits 64:2 store the BASE address, and bits 1:0 store the "
         "MODE. Two modes are supported, meaning that the MODE field is "
         "encoded as follows:\n"
         "MODE = 00: Direct. All exceptions set the PC to BASE.\n"
         "MODE = 01: Vectored. Asynchronout interrupts set PC to (BASE + 4 "
         "x Cause)";
