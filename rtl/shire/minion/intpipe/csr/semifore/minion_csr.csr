            "4: BRANCHES0          10: L2_MISS_REQ                  16: "
            "TS_INST                        22: TRANS_OPS         \n"
            "5: BRANCHES1          11: L2_MISS_REQ_REJ         17: TS_OPS  "
            "                       23: SHORT_OPS        ";
