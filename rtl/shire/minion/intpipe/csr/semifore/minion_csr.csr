   } [0x303] mideleg;
   register {
      (* Documentation_Source = "Section 3.1.9, RISC-V Volume II" *)
      (* Group = "MachineTrapSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine interrupt-enable register";
      property description =
         "Interrupt enable register. This register is encoded as follows.\n"
         "Bit 11: MEIE. Machine external interrupt enable.\n"
         "Bit 9: SEIE. Supervisor external interrupt enable.\n"
         "Bit 8: UEIE. Machine external interrupt enable.\n"
         "Bit 7: MTIE. Machine timer interrupt enable.\n"
         "Bit 5: STIE. Supervisor timer interrupt enable.\n"
         "Bit 4: UTIE. User timer interrupt enable.\n"
         "Bit 3: MSIE. Machine software interrupt enable.\n"
         "Bit 1: SSIE. Supervisor software interrupt enable.\n"
         "Bit 0: USIE. User software interrupt enable.";
      field {
         (* Documentation_Source = "Section 3.1.9, RISC-V Volume II" *)
         (* Group = "MachineTrapSetup" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine interrupt-enable register";
         property description =
            "Interrupt enable register. This register is encoded as "
            "follows.\n"
            "Bit 11: MEIE. Machine external interrupt enable.\n"
            "Bit 9: SEIE. Supervisor external interrupt enable.\n"
            "Bit 8: UEIE. Machine external interrupt enable.\n"
            "Bit 7: MTIE. Machine timer interrupt enable.\n"
            "Bit 5: STIE. Supervisor timer interrupt enable.\n"
            "Bit 4: UTIE. User timer interrupt enable.\n"
            "Bit 3: MSIE. Machine software interrupt enable.\n"
            "Bit 1: SSIE. Supervisor software interrupt enable.\n"
            "Bit 0: USIE. User software interrupt enable.";
         property hardware_volatile = false;
      } [63:0] mie;
   } [0x304] mie;
   register {
      (* Documentation_Source = "Section 3.1.7, RISC-V Volume II" *)
      (* Group = "MachineTrapSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine trap-handler base address";
      property description =
         "The mtvec register stores the trap vector configuration, "
         "consisting of a vector base address (BASE) and a vector mode "
         "(MODE). Bits 64:2 store the BASE address, and bits 1:0 store the "
         "MODE. Two modes are supported, meaning that the MODE field is "
         "encoded as follows:\n"
         "MODE = 00: Direct. All exceptions set the PC to BASE.\n"
         "MODE = 01: Vectored. Asynchronout interrupts set PC to (BASE + 4 "
         "x Cause)";
      field {
         (* Documentation_Source = "Section 3.1.7, RISC-V Volume II" *)
         (* Group = "MachineTrapSetup" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine trap-handler base address";
         property description =
            "The mtvec register stores the trap vector configuration, "
            "consisting of a vector base address (BASE) and a vector mode "
            "(MODE). Bits 64:2 store the BASE address, and bits 1:0 store "
            "the MODE. Two modes are supported, meaning that the MODE "
            "field is encoded as follows:\n"
            "MODE = 00: Direct. All exceptions set the PC to BASE.\n"
            "MODE = 01: Vectored. Asynchronout interrupts set PC to (BASE "
            "+ 4 x Cause)";
         property hardware_volatile = false;
      } [63:0] mtvec;
   } [0x305] mtvec;
   register {
      (* Group = "MachineTrapSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine counter enable";
      field {
         (* Documentation_Source = "Section 3.1.12, RISC-V Spec Volume II" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine counter enable";
         property description =
            "This register stores the enable bits for each one of the "
            "counters. These bits control the availability of the hardware "
            "performance-monitoring counters to the next-lowest privileged "
            "mode.  This means that U-mode and S-mode cannot access "
            "hpmcounter9 - hpmcounter31. Attempting to access these CSR's "
            "in U-mode or S-mode results in an illegal instruction "
            "exception. These bits are encoded as follows:\n"
            "0: CY. Setting this bit enables the cycle counter.\n"
            "1: TM. Setting this bit enables the time counter.\n"
            "2: IR. Setting this bit enables the instruction retire "
            "counter.\n"
            "7:3: HPM 3 - 7.  These bits enable hpmcounter 0 through "
            "hpmcounter 4.\n"
            "31:8: Reserved.";
      } [8:0] mcounteren;
   } [0x306] mcounteren;
   register {
      (* Group = "MachineCounterSetup" *)
      (* RISCV_Privilege_Level = "machine" *)
      property title =
         "Machine performance-monitoring event selector for Core";
      property description =
         "Counters 3 to 6 can be used for minion events. The counters are "
         "differentiated per thread, so in total there are 8 physical "
         "counters, 4 per thread. Each of them can be programmed with the "
         "following events:\n"
         "0: No count                  6: DCACHE_ACCESS0        12: "
         "L2_EVICT_REQ            18: TFMA_WAIT_TENB         24: TFMA_INST "
         "       \n"
         "1: MCYCLE                     7: DCACHE_ACCESS1        13: "
         "L2_EVICT_REQ_REJ   19: TIMA_OPS                         25: "
         "TFMA_OPS         \n"
         "2: RETIRED_INST0      8: DCACHE_MISSES0         14:  TL_INST     "
         "                   20: TXFMA_OPS16        \n"
         "3: RETIRED_INST1      9: DCACHE_MISSES1         15:  TL_OPS      "
         "                   21: TXFMA_OPS32      \n"
         "4: BRANCHES0          10: L2_MISS_REQ                  16: "
         "TS_INST                        22: TRANS_OPS         \n"
         "5: BRANCHES1          11: L2_MISS_REQ_REJ         17: TS_OPS     "
         "                    23: SHORT_OPS        ";
      field {
         (* Group = "MachineCounterSetup" *)
         (* RISCV_Privilege_Level = "machine" *)
         property title =
            "Machine performance-monitoring event selector for Core";
         property description =
            "Counters 3 to 6 can be used for minion events. The counters "
