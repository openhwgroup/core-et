   } [0x87f] tensor_store;
   register {
      (* Documentation_Source = "PRM-8, Section 1.2." *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "User-level Evict VA Cache operation";
      property description =
         "User-level software can cause the eviction of a particular "
         "address from the L1 data cache. Translates the given VA to a PA "
         "and writes-back (if needed) the line containing PA from all "
         "cache levels between <L1> and <DestLevel-1> to level "
         "<DestLevel>. The line containing PA is invalidated in all levels "
         "from <L1> through <DestLevel-1>.If NumLines > 0, the stride "
         "located in register x31 is added to the VA and the operation is "
         "repeated as many times as indicated by the NumLines field. When "
         "xs[63] is 1, then the n-th operation is skipped (i.e., the cache "
         "line is not operated upon) if the n-th tensor_mask bit is clear. "
         "If the VA specifies a line that is hard-locked, then this "
         "operation is a NOP. If <DestLevel> is <L1> then this operation "
         "is a NOP.If address translation is disabled the Virtual Address "
         "field in xs specifies a Physical Address. If the Physical "
         "Address is outside the SoC address space then this operation is "
         "a NOP. The ID field in x31 is used to identify the operation for "
         "the purposes of the TensorWait pseudo-instruction.";
      field {
         property title =
            "Number of Lines (minus 1)";
         property description =
            "Number of lines -1. ";
      } [3:0] num_lines;
      field {
         property title =
            "Virtual Address[47:6]";
         property description =
            "Virtual Address[47:6].";
      } [47:6] va;
      field {
         property title =
            "Destination Level";
         property description =
            "The values are as follows: \n"
            "00 - L1\n"
            "01 - L2\n"
            "10 - L3\n"
            "11 - MEM";
      } [59:58] dest_level;
      field {
         property title =
            "Use the tensor_mask CSR";
      } [63] use_tensor_mask;
   } [0x89f] co_evict_va;
   register {
      (* Documentation_Source = "PRM-8" *)
      (* Group = "ET_CacheControl" *)
      (* RISCV_Privilege_Level = "user" *)
      property title =
         "User-level Flush VA Cache operation";
      property description =
         "User-level software can cause the flushing of a particular "
         "address from the L1 data cache. Translates the given VA to a PA, "
         "and writes-through (if needed) the line containing PA from all "
         "cache levels between <L1> and <DestLevel-1> to level "
         "<DestLevel>. At the end of the operation, levels <L1> through "
         "<DestLevel-1> will keep a clean copy of the line containing PA. "
         "If NumLines > 0, the stride located in register x31 is added to "
         "the VA and the operation is repeated as many times as indicated "
         "by the NumLines field. When xs[63] is 1, then the n-th operation "
         "is skipped (i.e., the cache line is not operated upon) if the "
         "n-th tensor_mask bit is clear. If <DestLevel> is <L1> then this "
         "operation is a NOP. If address translation is disabled the "
         "Virtual Address field in xs specifies a Physical Address. If the "
         "Physical Address is outside the SoC address space then this "
         "operation is a NOP. The ID field in x31 is used to identify the "
         "operation for the purposes of the TensorWait pseudo-instruction.";
      field {
         property title =
            "Number of Lines (minus 1)";
         property description =
            "Number of Lines -1.";
      } [3:0] num_lines;
      field {
         property title =
            "Virtual Address[47:6]";
         property description =
            "Virtual Address[47:6].";
      } [47:6] va;
      field {
         property title =
            "Destination Level";
         property description =
            "The values are as follows: \n"
            "00 - L1\n"
            "01 - L2\n"
            "10 - L3\n"
            "11 - MEM";
      } [59:58] dest_level;
      field {
         property title =
            "Use the tensor_mask CSR";
      } [63] use_tensor_mask;
   } [0x8bf] co_flush_va;
