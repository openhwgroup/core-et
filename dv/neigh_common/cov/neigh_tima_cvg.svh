      // ===========================================================
      // Collecting the coverage related to input operands
      // ============================================================

      
	// Cross coverage COMMAND, RANGES and DATA_TYPES
     covergroup tima_cg (ref bit[31:0] in1, in2, in3, ref bit[7:0] cmd, ref bit [3:0] dtype, ref bit ren1, ren2, ren3);
     option.name = "tima_cg";
     option.per_instance = 0;
	 type_option.merge_instances = 1;

     input1_cvg : coverpoint in1 {`walking_one_32}
     input2_cvg : coverpoint in2 {`walking_one_32}
     input3_cvg : coverpoint in3 {`walking_one_32}

     in1_1_cvg: coverpoint in1[31:24] {bins in_1_zero={[8'h00:8'h7F]};
                                       bins in_1_one={[8'h80:8'hFF]};
                                       }
     in1_2_cvg: coverpoint in1[23:16] {bins in_1_zero={[8'h00:8'h7F]};
                                       bins in_1_one={[8'h80:8'hFF]};
                                       }
     in1_3_cvg: coverpoint in1[15:8]  {bins in_1_zero={[8'h00:8'h7F]};
                                       bins in_1_one={[8'h80:8'hFF]};
                                       }
     in1_4_cvg: coverpoint in1[7:0]   {bins in_1_zero={[8'h00:8'h7F]};
                                       bins in_1_one={[8'h80:8'hFF]};
                                       }

     in2_1_cvg: coverpoint in2[31:24] {bins in_2_zero={[8'h00:8'h7F]};
                                       bins in_2_one={[8'h80:8'hFF]};
                                       }
     in2_2_cvg: coverpoint in2[23:16] {bins in_2_zero={[8'h00:8'h7F]};
                                       bins in_2_one={[8'h80:8'hFF]};
                                       }
     in2_3_cvg: coverpoint in2[15:8]  {bins in_2_zero={[8'h00:8'h7F]};
                                       bins in_2_one={[8'h80:8'hFF]};
                                       }
     in2_4_cvg: coverpoint in2[7:0]   {bins in_2_zero={[8'h00:8'h7F]};
                                       bins in_2_one={[8'h80:8'hFF]};
                                       }

     in3_1_cvg: coverpoint in3[31:24] {bins in_3_zero={[8'h00:8'h7F]};
                                       bins in_3_one={[8'h80:8'hFF]};
                                       }
     in3_2_cvg: coverpoint in3[23:16] {bins in_3_zero={[8'h00:8'h7F]};
                                       bins in_3_one={[8'h80:8'hFF]};
                                       }
     in3_3_cvg: coverpoint in3[15:8]  {bins in_3_zero={[8'h00:8'h7F]};
                                       bins in_3_one={[8'h80:8'hFF]};
                                       }
     in3_4_cvg: coverpoint in3[7:0]   {bins in_3_zero={[8'h00:8'h7F]};
                                       bins in_3_one={[8'h80:8'hFF]};
                                       }

     num_of_active_operands_per_inst_cvg : coverpoint cmd {
            bins two_operands = {2};
            bins three_operands = {7};
		}

       CMD : coverpoint cmd {
			bins FCMD_MUL = {2};
			bins FCMD_TFMA = {7};
		} 
     DTYPE : coverpoint dtype {
			bins DTYPE_INT = {0};	
		}
	// Cross coverage COMMAND and DATA_TYPES
 /*    cmdXdtype : cross CMD, DTYPE {
		illegal_bins not_cmd_type = (binsof(CMD) intersect {2} && !binsof(DTYPE) intersect {0} || 						binsof(CMD) intersect {1} && !binsof(DTYPE) intersect {0});
		}
	// Cross coverage COMMAND and TWO_ACTIVE OPERANDS
     CMD_VS_TWO_ACTIVE_OPERANDS:
         cross CMD, num_of_active_operands_per_inst_cvg {
         ignore_bins three_operands = CMD_VS_TWO_ACTIVE_OPERANDS
         with (CMD == 7 || num_of_active_operands_per_inst_cvg == 7);
		}
	// Cross coverage COMMAND and THREE_ACTIVE OPERANDS
      CMD_VS_THREE_ACTIVE_OPERANDS:
         cross CMD, num_of_active_operands_per_inst_cvg{
         ignore_bins two_operands = CMD_VS_THREE_ACTIVE_OPERANDS
         with (CMD == 2 || num_of_active_operands_per_inst_cvg == 2);
      		}

	// Cross coverage COMMAND and INPUT_RANGES
      CMD_VS_OPERANDS12_RANGE:
         cross CMD, range_in1_cvg, range_in2_cvg{
         ignore_bins operands_not12 = CMD_VS_OPERANDS12_RANGE  
         with (CMD == 7);
     		}

       CMD_VS_OPERANDS123_RANGE:
         cross CMD, range_in1_cvg, range_in2_cvg, range_in3_cvg{
         ignore_bins operands_not123 = CMD_VS_OPERANDS123_RANGE  
 	 with (CMD == 2);
      		}
*/
     endgroup : tima_cg

endpackage;

module neigh_tima_cvg (input clock);
	import neigh_tima_cov_pkg::*;
	bit[31:0] in1, in2, in3;
	bit[7:0] cmd;
	bit ren1, ren2, ren3;
	bit [3:0] dtype;


	tima_cg	tima_cg_inst = new(in1, in2, in3, cmd, dtype, ren1, ren2, ren3);

        always @ (posedge clock) begin
		in1=tima_top.f1_in1;
		in2=tima_top.f1_in2;
                in3=tima_top.f2_in3;
		cmd= tima_top.f2_prod;
		tima_cg_inst.sample();

	end
endmodule: neigh_tima_cvg

	bind tima_top neigh_tima_cvg neigh_tima_cov(.clock(clock));

`endif
`endif


         


   
