### ###test List

##########################################################################################
# set default options. These will be sent to the sim as plusargs 
#    option = value  # sim will be run with cmd line param +option=value
#
# special options:
#   preSimCmd = command to run before launching the simulation
#   postSimCmd = command to run after the simulation has completed
#       all the parameters will be set as env vars before calling these commands
#       they will be run from the ###test base directory ($ENV{###testPath})
#       the ###test run dir can be found in $ENV{###testRunDir}
#       non-zero exit status adds an error tO the ###test run
#   timeout = max number of time to run
#   LOG_LEVEL = global log level
#   XXXX_LOG_LEVEL = log level for block named XXXX
#   SEED = random seed
#   TEST_PATH = relative path of the ###test directory. './' used if not specified.
#   TAG = tag1 tag2 tag3 ... => space separated values determining tags for ###tests.
#                               Script can then run only ###tests matching certain patterns)
##########################################################################################
LOG_LEVEL=1
timeout=1000000000

##########################################################################################
# ###test list, with specific options to be sent as plusargs for the current ###test only
# format is: ###test=binary [option=X option=Y... tag=tag1 tag=tag2 tag=tag3 ...]
# the script will run $TEST_PATH/build/SIM/binary where SIM=vcs|verilog
##########################################################################################

INPUT_COUNT = 10000

MIN_IDLE=0
MAX_IDLE=0
COMPUTATIONAL=1

simulator=verilator
tag=nightly
tag=computational
UVM_TESTNAME=tifma_test_base


SEED=0
test=tifma_tb TEST_TYPE=0 tag=tmul tag=kk2
test=tifma_tb TEST_TYPE=1 tag=tmadd tag=b4c
 


SEED=1
test=tifma_tb TEST_TYPE=0 tag=tmul
test=tifma_tb TEST_TYPE=1 tag=tmadd


SEED=2
#test=tifma_tb TEST_TYPE=0  tag=tifma

