# add autogenerated files
MANUAL_DEP=data.raw test.s scratch_size.ld
EXTRA_CLEAN=diagclean

EXTRA_LDFLAGS=-T./linker.ld
EXTRA_CFLAGS=-DDISABLE_ML
include $(MINION_DIAGS)/common/include.mk

diagclean:
	rm -f data.raw test.s scratch_size.ld

test.s:  genTest.py  genTest.conf
	./genTest.py --output test.s

data.raw:  genTest.py  genTest.conf
	./genTest.py --dataraw data.raw

scratch_size.ld: data.raw
	$(eval size := $(shell du -b data.raw | cut -f1))
	echo "SCRATCH_SIZE = $(size); " > scratch_size.ld

