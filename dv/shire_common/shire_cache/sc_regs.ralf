block sc_bank_regs {
   bytes 8;
   register sc_l3_shire_swizzle_ctl @'h0;
   register sc_reqq_ctl @ 'h1;
   register sc_pipe_ctl  @ 'h2;
   register sc_l2_cache_ctl  @ 'h3;
   register sc_l3_cache_ctl  @ 'h4;
   register sc_scp_cache_ctl  @ 'h5;
   register sc_idx_cop_sm_ctl  @ 'h6;
   register sc_idx_cop_sm_physical_index  @ 'h7;
   register sc_idx_cop_sm_data0  @ 'h8;
   register sc_idx_cop_sm_data1  @ 'h9;
   register sc_idx_cop_sm_ecc  @ 'ha;
   register sc_err_log_ctl  @ 'hb;
   register sc_err_log_info  @ 'hc;
   register sc_err_log_address  @ 'hd;
   register sc_sbe_dbe_counts  @ 'he;
   register sc_reqq_debug_ctl  @ 'hf;
   register sc_reqq_debug0  @ 'h10;
   register sc_reqq_debug1  @ 'h11;
   register sc_reqq_debug2  @ 'h12;
   register sc_reqq_debug3  @ 'h13;
   register sc_trace_address_enable  @ 'h14;
   register sc_trace_address_value  @ 'h15;
   register sc_trace_ctl  @ 'h16;
   register sc_perfmon_ctl_status  @ 'h17;
   register sc_perfmon_cyc_cntr  @ 'h18;
   register sc_perfmon_p0_cntr  @ 'h19;
   register sc_perfmon_p1_cntr  @ 'h1a;
   register sc_perfmon_p0_qual  @ 'h1b;
   register sc_perfmon_p1_qual  @ 'h1c;
}
