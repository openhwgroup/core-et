}

register sc_l2_cache_ctl {
   field TAG_MASK @'h0 {
      bits 12;
      reset 'h7f;
      access rw;
   }
   field TAG_MASK_RSVD @'hc {
      bits 4;
      reset 'h0;
      access ro;
   }
   field SET_MASK @'h10 {
      bits 12;
      reset 'h7f;
      access rw;
   }
   field SET_MASK_RSVD @'h1c {
      bits 4;
      reset 'h0;
      access ro;
   }
   field SET_SIZE @'h20 {
      bits 13;
      reset 'h80;
      access rw;
   }
   field SET_SIZE_RSVD @'h2d {
      bits 3;
      reset 'h0;
      access ro;
   }
   field SET_BASE @'h30 {
      bits 12;
      reset 'h280;
      access rw;
   }
   field SET_BASE_RSVD @'h3c {
      bits 4;
      reset 'h0;
      access ro;
   }
}

