register sc_l3_shire_swizzle_ctl {
   field ESR_SC_SHIRE_SEL_B0 @'h0 {
      bits 4;
      reset 'h0;
      access rw;
   }
   field ESR_SC_SHIRE_SEL_B1 @'h4 {
      bits 4;
      reset 'h1;
      access rw;
   }
   field ESR_SC_SHIRE_SEL_B2 @'h8 {
      bits 4;
      reset 'h2;
      access rw;
   }
   field ESR_SC_SHIRE_SEL_B3 @'hc {
      bits 4;
      reset 'h3;
      access rw;
   }
   field ESR_SC_SHIRE_SEL_B4 @'h10 {
      bits 4;
      reset 'h4;
      access rw;
   }
   field ESR_SC_SHIRE_SEL_B5 @'h14 {
      bits 4;
      reset 'h5;
      access rw;
   }
   field ESR_SC_BANK_SEL_B0 @'h18 {
      bits 4;
      reset 'h5;
      access rw;
   }
   field ESR_SC_BANK_SEL_B1 @'h1c {
      bits 4;
      reset 'h6;
      access rw;
   }
   field ESR_SC_BANK_SEL_B2 @'h20 {
      bits 4;
      reset 'h7;
      access rw;
   }
   field ESR_SC_SUB_BANK_SEL_B0 @'h24 {
      bits 4;
      reset 'h7;
      access rw;
   }
   field ESR_SC_SUB_BANK_SEL_B1 @'h28 {
      bits 4;
      reset 'h8;
      access rw;
   }
   field ESR_SC_SUB_BANK_SEL_B2 @'h2c {
      bits 4;
      reset 'h9;
      access rw;
   }
   field ESR_SC_ALL_SHIRE_ALIASING @'h30 {
      bits 1;
      reset 'h0;
      access rw;
   }
   field ESR_SC_TWO_SHIRE_ALIASING_USE_SHIRE_LSB @'h31 {
      bits 1;
      reset 'h0;
      access rw;
   }
}

register sc_reqq_ctl {
   field ESR_SC_L3_YIELD_PRIORITY @'h0 {
      bits 5;
      reset 'h0;
      access rw;
   }
   field ESR_SC_ECC_SCRUB_ENABLE @'h5 {
      bits 1;
      reset 'h0;
      access rw;
   }
   field ESR_SC_REQQ_NO_LINK_LIST @'h6 {
      bits 1;
      reset 'h0;
      access rw;
   }
   field ESR_SC_NUM_L3_REQQ_ENTRIES @'h7 {
      bits 6;
      reset 'h15;
      access rw;
   }
   field ESR_SC_L3_BYPASS @'hd {
      bits 1;
      reset 'h0;
      access rw;
   }
   field ESR_SC_L2_BYPASS @'he {
      bits 1;
      reset 'h0;
      access rw;
   }
   field ESR_SC_REMOTE_SCP_ENABLE @'hf {
      bits 1;
      reset 'h1;
      access rw;
   }
   field ESR_SC_REMOTE_L3_ENABLE @'h10 {
      bits 1;
      reset 'h1;
      access rw;
   }
   field ESR_SC_CBUF_ENABLE @'h11 {
      bits 1;
      reset 'h1;
      access rw;
   }
}

register sc_pipe_ctl {
   field ESR_SC_CBUF_ENTRY_ENABLE @'h0 {
      bits 32;
