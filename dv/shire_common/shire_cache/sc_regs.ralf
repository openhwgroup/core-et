register sc_idx_cop_sm_ctl {
   field GO @'h0 {
      bits 1;
      reset 'h0;
      access wc;
   }
   field ABORT @'h1 {
      bits 1;
      reset 'h0;
      access wc;
   }
   field OPCODE @'h8 {
      bits 4;
      reset 'h0;
      access rw;
   }
   field ECC_WR_EN @'hd {
      bits 1;
      reset 'h0;
      access rw;
   }
   field LOGICAL_RAM @'he {
      bits 2;
      reset 'h0;
      access rw;
   }
   field IDX_COP_SM_STATE @'h18 {
      bits 8;
      reset 'h4;
      access ro;
   }
}

register sc_idx_cop_sm_physical_index {
   field QW @'h0 {
