   function sample_master(input evl_shire_id_t shire, input evl_shire_id_t target_shire, input evl_paddr_t rcv_req_addr, input evl_noc_master_type_t master_type, input int noc_layer);
      case (master_type)
         L2TOL3_M       : cg_l2tol3_m.sample(shire, target_shire, rcv_req_addr, noc_layer);
         UCTOL3_M       : cg_uctol3_m.sample(shire, target_shire, rcv_req_addr);
         L3TOSYS_M      : cg_l3tosys_m.sample(shire, target_shire, rcv_req_addr);
         UCTOSYS_M      : cg_uctosys_m.sample(shire, target_shire, rcv_req_addr);
         MCTOSYS_M      : cg_mcamorsp_m.sample(shire, target_shire, rcv_req_addr);
         IO_TOL3_M      : cg_iotol3_m.sample(shire, target_shire, rcv_req_addr, noc_layer);
         IO_TOSYS_M     : cg_iotosys_m.sample(shire, target_shire, rcv_req_addr);
         IO_PM          : cg_iopm_m.sample(shire, target_shire, rcv_req_addr);
         PSHIRE_TOL3_M  : cg_pstol3_m.sample(shire, target_shire, rcv_req_addr);
         PSHIRE_TOSYS_M : cg_pstosys_m.sample(shire, target_shire, rcv_req_addr);
      endcase
   endfunction

   function sample_slave(input evl_shire_id_t shire, input evl_shire_id_t req_shire_origin, input evl_noc_slave_type_t slave_type, input int noc_layer);
      case (slave_type)
         TOL3_S      : cg_tol3_s.sample(shire, req_shire_origin, noc_layer);
         TOSYS_S     : cg_tosys_s.sample(shire, req_shire_origin);
         TOMEM_S     : cg_tomem_s.sample(shire, req_shire_origin);
         MC_SB_S     : cg_mcsb_s.sample(shire, req_shire_origin);
         IO_PS       : cg_iops_s.sample(shire, req_shire_origin);
         PSHIRE_PS   : cg_psps_s.sample(shire, req_shire_origin);
      endcase
   endfunction

   function new();
      super.new();
      cg_l2tol3_m = new;
      cg_uctol3_m = new;
      cg_l3tosys_m = new;
      cg_uctosys_m = new;
      cg_mcamorsp_m = new;
      cg_iotol3_m = new;
      cg_iotosys_m = new;
      cg_iopm_m = new;
      cg_pstol3_m = new;
      cg_pstosys_m = new;

      cg_tol3_s = new;
      cg_tosys_s = new;
      cg_tomem_s = new;
      cg_mcsb_s = new;
      cg_iops_s = new;
      cg_psps_s = new;

