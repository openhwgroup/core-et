
`ifndef __EVL_NOC_SB_CVG
`define __EVL_NOC_SB_CVG

class evl_noc_sb_cvg extends evl_void;

   covergroup cg_l2tol3_m with function sample (input evl_shire_id_t shire, input evl_shire_id_t target_shire, input evl_paddr_t rcv_req_addr, input int noc_layer);

      option.name = "evl_cg_l2tol3_m";
      option.per_instance         = 0;
      type_option.merge_instances = 1;

      cp_src_shire: coverpoint shire {
         bins minshires[] = {[0:33]};
      }

      cp_dst_shire: coverpoint target_shire {
         bins minshires[] = {[0:33]};
         bins ioshire     = {254};
      }

      cp_noc_lyr: coverpoint noc_layer {
         bins layer[] = {[0:3]};
      }

      cp_addr: coverpoint rcv_req_addr {
         wildcard bins io_ps_low       = {40'h001???????};
         wildcard bins io_ps_high      = {40'b00000000001?????????????????????????????};
         wildcard bins mem_1_5G_to_2G  = {40'h006???????};
         wildcard bins sratchpad       = {40'b000000001???????????????????????????????};
         wildcard bins global_csr      = {40'h01????????};
         wildcard bins pshire          = {40'b01??????????????????????????????????????};
         wildcard bins l3_dram         = {40'b10??????????????????????????????????????};
         wildcard bins noncache_dram   = {40'b11??????????????????????????????????????};
      }

      ccp_src_lyr: cross cp_src_shire, cp_noc_lyr;

      ccp_src_dst: cross cp_src_shire, cp_dst_shire;

   endgroup

