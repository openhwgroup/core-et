end

def prune_file start_string,end_string, filename, prune_filename
  line_num=0
  started=false
  @log.info "Pruning file=#{filename}"
  File.open(filename, "r") do |source_file|
    File.open(prune_filename, "w") do |prune_file|
      source_file.each_line do |line|
        line_num+=1
        if line =~ /#{start_string}/
          @log.debug "Match Start line=#{start_string} at line #{line_num}"
          started=true
          prune_file.puts line
          next
        end
        if started
          prune_file.puts line
        end
        if started and line =~ /#{end_string}/
          @log.debug "Match End line=#{end_string} at line #{line_num}"
          started=false
        end
        if (line_num % 1000000) == 0
          @log.debug "looping: line_num=#{line_num}"
        end
      end # each line
    end # prune_filename
  end # source_filename
end # method prune_file

