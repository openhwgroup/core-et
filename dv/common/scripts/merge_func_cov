  end # end constructor
end # end class

def file_edit(filename, regexp, replacement)
  Tempfile.open(".#{File.basename(filename)}", File.dirname(filename)) do |tempfile|
    File.open(filename).each do |line|
      tempfile.puts line.gsub(regexp, replacement)
    end
    tempfile.fdatasync
    tempfile.close
    stat = File.stat(filename)
    FileUtils.chown stat.uid, stat.gid, tempfile.path
    FileUtils.chmod stat.mode, tempfile.path
    FileUtils.mv tempfile.path, filename
  end
end

def setup_repo options

# Is $REPOROOT defined and is it a valid writable path?
#   if ENV.has_key? "REPOROOT"
#     unless File.writable? ENV['REPOROOT']
#       error "$REPOROOT points to non existant path #{ENV['REPOROOT']} or is not writable".colorize("red")
#     end
#  else
#       error "Env var reporoot is not defined.  source env.sh in root of repo".colorize("red")
#   end

   logpath="."
   options[:logpath] = logpath

   # Now that we are done cleaning etc, we can setup the proper log
   #
   level=:info
   @log = EtLog.new("#{logpath}/merge_func_cov.log",:info,false,"merge_func_cov")
   if options[:verbose]
    level=:debug
   end
   @log.level = level
   @log.info "merge_func_cov is running"
   @log.info "logpath is #{logpath}/merge_func_cov.log"
   options[:logfile] = "#{logpath}/mege_func_cov.log"

   @log.info "command line=#{options[:cmd_line]}"

   options[:git_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse HEAD"
   options[:git_hash].chomp!
   @log.info "git revision=#{options[:git_hash]}"

   options[:git_short_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse --short HEAD"
   options[:git_short_hash].chomp!
   @log.info "git short hash=#{options[:git_short_hash]}"

end

def find_coverage regressions
   regressions.each do |regr|
     @log.info "Finding coverage for regression name=#{regr.name}"

     # Construct the path to the repo_root so we can start searching for finished and valid coverage regressions
     regr.repo_root = "#{regr.regr_root}/#{regr.name}/#{regr.start_path}/#{regr.repo_name}"
     @log.debug "Starting search for regression=#{regr.name} repo_root=#{regr.repo_root}"
     unless Dir.exists? regr.repo_root
       @log.error "regr=#{regr.name} path not found.  path=#{regr.repo_root}"
     end
     real_path=File.realpath regr.repo_root
     real_path =~ /.*\/(\d+)\//
     version=$1.to_i
     @log.debug "Version is #{version}"
     min_version = version - NUM_REGR_TO_CHECK   # Max number of regressions to check before erroring
     regr_done_file_path = "#{regr.repo_root}/#{regr.regr_done_file_path}"

     # Now find the latest regression thats done
     while (version > min_version)
       @log.debug "Testing path=#{regr_done_file_path}"
       if File.exists? regr_done_file_path
         @log.debug "Regression name=#{regr.name} version=#{version} has completed!"
         vdb_find_path="#{regr.repo_root}/#{regr.cov_root}/**/#{regr.test_vdb_name}"
         regr.cov_files = Dir[vdb_find_path]
         regr.cov_files.reject! { |f| /partitionLib/.match(f) }   # Memshire has simv.vdb's everywhere this gets rid of the results internal to the compilation
         if regr.cov_files.size == 0
           @log.warn "regr=#{regr.name} is done but contains not coverage dirs named #{regr.test_vdb_name} in path #{vdb_find_path} "
           version -=1
           regr.repo_root = "#{regr.regr_root}/#{regr.name}/#{version}/#{regr.repo_name}"
           regr_done_file_path = "#{regr.repo_root}/#{regr.regr_done_file_path}"
           next
         else
           @log.info "regr=#{regr.name} at #{regr.repo_root} contains #{regr.cov_files.size} coverage records".colorize("yellow")
         end
         break;
       else
         @log.debug "Regression name=#{regr.name} version=#{version} is incomplete"
         version-=1
         regr.repo_root = "#{regr.regr_root}/#{regr.name}/#{version}/#{regr.repo_name}"
         regr_done_file_path = "#{regr.repo_root}/#{regr.regr_done_file_path}"
       end
     end

     if (regr.cov_files.nil?) or (regr.cov_files.size == 0)
       @log.error "regr=#{regr.name} has no valid completed regressions with coverage files",true
       @log.error "Please check the configuration and try again"
     end
   end
   @log.info "Finished find all required coverage data!".colorize("yellow")
end

def merge_coverage options,regressions
   total_size=0
   @log.info "Started merging all required coverage data!".colorize("yellow")
   File.open("#{options[:merge_target]}/master.flist", "w") do |master_file|
     regressions.each do |regr|
       @log.info "Merging coverage for regression name=#{regr.name}"

       @log.debug "Creating flist #{regr.name}.flist"
       File.open("#{options[:merge_target]}/#{regr.name}.flist", "w") do |f|
         f.puts(regr.cov_files)
         master_file.puts(regr.cov_files)
         total_size += regr.cov_files.size
       end

       # Instead of doing one big merge we can merge blocks.
       # useful for debug
       if options[:gen_unit_cov]
         @log.et_sys "cd #{options[:merge_target]}; urg -full64 -f #{regr.name}.flist -format both -metric group -dbname merged_#{regr.name} -report merged_#{regr.name} -log #{regr.name}_merge.log -group   merge_across_scopes -group instcov_for_score"
       end
     end
   end

   @log.et_sys "cd #{options[:merge_target]}; urg -full64 -f master.flist -format both -metric group -dbname master_merged -report master_merged_html -log master_merge.log -group merge_across_scopes -group instcov_for_score"
   @log.et_sys "cd #{options[:merge_target]}; mkdir master_merged_text; mv master_merged_html/*.txt master_merged_text/"
   grpinfo_path="#{options[:merge_target]}/master_merged_text/grpinfo.txt"
   pad_grpinfo_path="#{options[:merge_target]}/master_merged_text/pad_grpinfo.txt"

   prune_file "Group : pin_toggle_cov::cg_toggle_cov","Group : ",grpinfo_path,pad_grpinfo_path
   @log.info "Finished merging all required #{total_size} tests from #{regressions.size} regressions".colorize("yellow")
end

