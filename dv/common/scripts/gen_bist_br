     ENV_SH="#{ENV['REPOROOT']}/env.sh"
     file_edit(ENV_SH,/export MIN_BIST_DIR=orig/, 'export MIN_BIST_DIR=bist')
     file_edit(ENV_SH,/export IOS_BIST_DIR=orig/, 'export IOS_BIST_DIR=bist')
     #file_edit(ENV_SH,/vcs\/P-2019.06-SP1-1/,'vcs-mx/LATEST')

     @log.et_sys "git add --ignore-removal rtl"
     @log.et_sys "git add --ignore-removal env.sh"
     @log.et_sys "git add --ignore-removal dv/standalone/ioshire/Makefile"
     @log.et_sys "git add --ignore-removal dv/standalone/fc/Makefile"

     @log.et_sys "git commit -m \"Bist insertion for git hash=#{options[:git_hash]}\" --no-verify"
  #   @log.et_sys "git reset --hard "
     @log.et_sys "cp $REPOROOT/gen_bist_br.log ~/"
  #   @log.et_sys "cd #{ENV['REPOROOT']};git clean -fd",true

     @log.info "git repo updated".colorize("yellow")
     @log.info "Running tests...".colorize("yellow")

     @log.info "b4c started!".colorize("yellow")
     @log.et_sys "sync; cd $REPOROOT; ls -l; cat env.sh"
     rc=@log.et_sys "export MIN_BIST_DIR=bist;export IOS_BIST_DIR=bist;#{ENV['REPOROOT']}/dv/common/scripts/run_bist_smoke",true
     if rc==0
       @log.info "b4c passed!".colorize("yellow")
     else
       @log.et_sys "chmod g+rwx ${TESTRUN}/b4c*",true
       @log.error "b4c failed!"
     end
     @log.info "Pushing Branch".colorize("yellow")
     @log.et_sys "git push origin #{options[:branch_name]}"
     @log.et_sys "git st; git reset --hard HEAD"
     @log.et_sys "git fetch;git co master_bisted"
     @log.et_sys "git merge --strategy-option theirs --no-edit origin/#{options[:branch_name]}"
     @log.et_sys "git push -u"
     @log.et_sys "git checkout #{options[:branch_name]}"
     @log.et_sys "cd ${REPOROOT};git clean -fdx",true
     @log.info "DFT regression started".colorize("yellow")
     @log.et_sys "et-dvrun --config $MINION_REG --make -j 8 -s --noclean --runroot $TESTRUN --tags sms_b4c --noslurm  --status --zkmof" 
     @log.info "DFT regression completed".colorize("yellow") 
     @log.et_sys "cd ${REPOROOT};git clean -fdx",true
   else
     @log.info "SKIP BIST PATH"
     @log.et_sys "git reset --hard HEAD"
     @log.et_sys "git clean -fdx",true
     @log.et_sys "git fetch;git co master_bisted"
     @log.et_sys "git pull"
     hash,rc=@log.et_backtick "git rev-parse HEAD"
     @log.info "Source hash=#{hash}"
     @log.et_sys "git merge --strategy-option theirs --no-edit origin/master"
     change_list,rc=@log.et_backtick "git diff --name-only HEAD #{hash}"
     @log.info "Change List is=#{change_list}"
     change_list_array=change_list.split("\n")
     #ap change_list_array
     intersection=change_list_array & BIST_RTL_FILE_LIST
     if intersection.length() != 0 
        @log.error "Bisted RTL files were modified. Aborted. Admin needs to resolve this by hand!",true
        @log.error intersection
     end
     @log.info "git repo updated".colorize("yellow")
     @log.info "Running tests...".colorize("yellow")

     @log.info "b4c started!".colorize("yellow")
     @log.et_sys "sync; cd $REPOROOT; ls -l; cat env.sh"
     rc=@log.et_sys "export MIN_BIST_DIR=bist;export IOS_BIST_DIR=bist;#{ENV['REPOROOT']}/dv/common/scripts/run_bist_smoke",true
     if rc==0
       @log.info "b4c passed!".colorize("yellow")
     else
       @log.et_sys "chmod g+rwx ${TESTRUN}/b4c*",true
       @log.error "b4c failed!"
     end
     @log.info "Pushing Branch".colorize("yellow")
     @log.et_sys "git push origin master_bisted"

   end

rescue Interrupt => e
  @log.info "Interrupt detected (Ctrl-c): #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}" unless @log.nil?
  exit 1
#rescue Exception => e
#  @log.info "Exception detected : #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}" unless @log.nil?
# exit 1
rescue SystemExit => e
  exit e.status
ensure
  @log.close unless @log.nil?
end
