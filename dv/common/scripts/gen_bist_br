class Bist_rtl_record
  attr_accessor :name,:build_dir, :build_cmd, :bist_log, :fail_count,:pass_strings,:fail_string,:target_dir

  def initialize
    @fail_count=0
    @pass_strings=["P A S S"]
    @fail_string="F A I L"
    @bist_log="bist.log"
    @build_cmd="make bist > /dev/null 2>&1"
  end # end constructor
end # end class

def file_edit(filename, regexp, replacement)
  Tempfile.open(".#{File.basename(filename)}", File.dirname(filename)) do |tempfile|
    File.open(filename).each do |line|
      tempfile.puts line.gsub(regexp, replacement)
    end
    tempfile.fdatasync
    tempfile.close
    stat = File.stat(filename)
    FileUtils.chown stat.uid, stat.gid, tempfile.path
    FileUtils.chmod stat.mode, tempfile.path
    FileUtils.mv tempfile.path, filename
  end
end

def setup_repo options

   # Is $REPOROOT defined and is it a valid writable path?
   if ENV.has_key? "REPOROOT"
     unless File.writable? ENV['REPOROOT']
       error "$REPOROOT points to non existant path #{ENV['REPO_ROOT']} or is not writable".colorize("red")
     end
   else
       error "Env var reporoot is not defined.  source env.sh in root of repo".colorize("red")
   end

   logpath="."
   options[:logpath] = logpath

   # Now that we are done cleaning etc, we can setup the proper log
   #
   level=:info
   @log = EtLog.new("#{logpath}/gen_bist_br.log",:info,false,"gen_bist_br")
   if options[:verbose]
    level=:debug
   end
   @log.level = level
   @log.info "gen_bist_br is running"
   @log.info "logpath is #{logpath}/gen_bist_br.log"
   options[:logfile] = "#{logpath}/gen_bist_br.log"

   @log.info "command line=#{options[:cmd_line]}"

   options[:git_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse HEAD"
   options[:git_hash].chomp!
   @log.info "git revision=#{options[:git_hash]}"

   options[:git_short_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse --short HEAD"
   options[:git_short_hash].chomp!
   @log.info "git short hash=#{options[:git_short_hash]}"

   @log.info "Querying git repo for local modifications..."
   diff,rc =@log.et_backtick "cd ${REPOROOT};git diff"
   if diff != ""
     diff_path="#{logpath}/local_modifications.patch"
     f = File.new(diff_path, File::CREAT|File::TRUNC|File::RDWR, 0644)
     f.write diff
     f.close
     @log.warn "There were local modifications so creating patch file #{diff_path}"
   else
     @log.info "Repo is clean there are no modifications"
   end
end

def create_branch options
  time = Time.new
  options[:branch_name]="bist_rtl_#{time.strftime("%Y_%m_%d")}_#{options[:git_short_hash]}"
  @log.info "Using branch name=#{options[:branch_name]}"

  #
  # Fix me remove the ,true in the final script

  rc=@log.et_sys "git checkout -b #{options[:branch_name]}",true
  if rc != 0
    @log.error "Branch=#{options[:branch_name]} already exists"
  end
end

def check_log bist
  bist_log="#{ENV['REPOROOT']}/#{bist.build_dir}/#{bist.bist_log}"


  unless File.exist? bist_log
    @log.error "Missing logfile=#{bist_log} for block=#{bist.name}"
  end


  pass_count=0
  expected_pass_count=bist.pass_strings.size
  @log.info "Pass Count=#{pass_count} Expected Pass Count=#{expected_pass_count}"
  bist.pass_strings.each do |pass_string|
    out,pass=@log.et_backtick "grep \"#{pass_string}\" #{bist_log}",true,:debug
    #@log.info "pass=#{pass} out=#{out}"
    if out!=""
       @log.info "\"#{pass_string}\" detected in #{bist_log}"
     else
       @log.error"\"#{pass_string}\" not detected in #{bist_log}"
     end
     out,fail=@log.et_backtick "grep \"#{bist.fail_string}\" #{bist_log}",true,:debug
     #@log.info "fail=#{fail} out=#{out}"
     if out!=""
       @log.error "\"#{bist.fail_string}\" detected in #{bist_log}"
     else
       @log.info "\"#{bist.fail_string}\" not detected in #{bist_log}"
     end
     pass_count += 1
  end
  @log.info   "Found all #{expected_pass_count} pass strings. Build=#{bist.name} has passed".colorize("yellow");
end

def build_bists bists
   bists.each do |bist|
     @log.info "Building bist=#{bist.name}  log=#{bist.build_dir}/bist.log"
     ap bist, :raw => true
     @log.et_sys "cd #{bist.build_dir}/;#{bist.build_cmd}"
     check_log bist
     #@log.et_sys "git add #{ENV['REPOROOT']}/#{bist.target_dir}"
   end
   @log.info "All bist builds completed!".colorize("yellow")
end

begin
   bists = Array.new()

   # Vault
   bist_rec =Bist_rtl_record.new()
   bist_rec.name="Vault"
   bist_rec.build_dir="physical/bist/vault"
   bist_rec.build_cmd="./run_bist_vault > bist.log 2>&1"
   bist_rec.target_dir="rtl/ioshire/spio/vault/spio_vault_bisted_rtl"
   bist_rec.pass_strings=["P A S S vault mbist insertion"]
   bists << bist_rec

   # IO Shire
   bist_rec =Bist_rtl_record.new()
   bist_rec.name="IO Shire"
   bist_rec.build_dir="physical/bist/ioshire_wrapper"
   bist_rec.build_cmd="./run_bist_ioshire_wrapper run_all > bist.log 2>&1"
   bist_rec.target_dir="rtl/ioshire/wrapper/bisted_rtl"
   bist_rec.pass_strings=["P A S S Maxion shire channel is mbist inserted","P A S S Maxshire_top is mbist inserted","P A S S Pu is mbist inserted","P A S S Spio is mbist inserted","P A S S ioshire_wrapper bist insertion"]
   bists << bist_rec


   # Shire Channel
   bist_rec =Bist_rtl_record.new()
   bist_rec.name="Shire Channel"
   bist_rec.build_dir="physical/bist/shire_channel"
   bist_rec.target_dir="rtl/shire"
   bist_rec.pass_strings=["P A S S","CHECKPOINT: TOTAL 112 MEMORY INSTANCES HAVE BEEN DETECTED."]
   bists << bist_rec

   cmd_line="gen_bist_br"
   ARGV.each { |arg| cmd_line += " #{arg}" }

   options = {}
   OptionParser.new do |opts|
     opts.banner = "Usage: gen_bist_br [options]"
     opts.on("-a build_arguments","--build_args build_arguments","Specify additional build arguments") do |arg|
       options[:build_args] = arg
     end
     opts.on("-c", "--clean", "Clean the just the specified build dir") do |arg|
       options[:clean] = arg
     end
     opts.on("-i", "--insert", "Only run insertion. Skip all validation") do |arg|
       options[:insert_only] = arg
     end
     opts.on("-n", "--no_branch", "Don't create a git branch for bist insertion") do |arg|
       options[:no_branch] = arg
     end
     opts.on("-q", "--quiet", "Quiesce most output") do |arg|
       options[:quiet] = arg
     end
     opts.on("-s", "--skip", "Quiesce most output") do |arg|
       options[:skip] = arg
     end
     opts.on("-v", "--verbose", "Verbose output") do |arg|
       options[:verbose] = arg
     end
   end.parse!
   options[:cmd_line]=cmd_line

   unless options[:quiet]
     options[:quiet]=:info
   end

   #
   # Setup the workspace, cleanup, and get the log setup
   #
   setup_repo options
   @log.info "cmd_line=#{cmd_line}"

   require 'socket'
   hostname = Socket.gethostname
   @log.info "running on hostname=#{hostname}"

   if options[:insert_only]
     @log.info "running bist insertion only. skipping validation"
   end

   ap options      if options[:verbose]
   @log.ap options if options[:verbose]

   unless options[:no_branch] || options[:skip]
     create_branch options
   end

   unless options[:skip]
     build_bists bists

     @log.info "BIST Insertion Completed...".colorize("yellow")
     if options[:insert_only]
       @log.info "Insertion completed successfully. Exiting"
       exit 0
     end


     COMMON_LINT_F="#{ENV['RTLROOT']}/inc/common_lint.f"
     COMMON_SYN_F="#{ENV['RTLROOT']}/inc/common_syn.f"
     COMMON_VCS_F="#{ENV['RTLROOT']}/inc/common_vcs.f"

     #Fix up the dft_defines.vh
     DFT_DEFINES="#{ENV['RTLROOT']}/inc/dft_defines.vh"
     file_edit(DFT_DEFINES,/define ET_BIST_INSERTION       0/, "define ET_BIST_INSERTION       1")
     file_edit(DFT_DEFINES,/\/\/ \`define ET_USE_BIST_RTL/, "`define ET_USE_BIST_RTL\n`define ET_USE_ASIC_MEMS\n")

     #VCS_MK="#{ENV['REPOROOT']}/dv/standalone/ioshire/Makefile"
     #file_edit(VCS_MK,/VCS_USE_MX\?=0/, "VCS_USE_MX?=1")
     #file_edit(VCS_MK,/VCS_VER\?=P-2019.06-SP1-1/,"VCS_VER?=O-2018.09-SP2-3")

     #VCS_MK2="#{ENV['REPOROOT']}/dv/standalone/fc/Makefile"
     #file_edit(VCS_MK2,/VCS_USE_MX\?=0/, "VCS_USE_MX?=1")
     #file_edit(VCS_MK2,/VCS_VER\?=P-2019.06-SP1-1/,"VCS_VER?=O-2018.09-SP2-3")

     # Do we need to hack these as well
     #@log.et_sys "echo +define+ET_BIST_INSERTION=0 >> #{COMMON_LINT_F}"
     #@log.et_sys "echo +define+ET_BIST_INSERTION=0 >> #{COMMON_SYN_F}"
     #@log.et_sys "echo +define+ET_BIST_INSERTION=0 >> #{COMMON_VCS_F}"
     #@log.et_sys "echo +define+ET_BIST_RTL >> #{COMMON_LINT_F}"
     #@log.et_sys "echo +define+ET_BIST_RTL >> #{COMMON_SYN_F}"
