#!/eng/dvtools/release/ruby/2.4.2/bin/ruby
# Hack the GEM_PATH To Karls Libary
ENV['GEM_PATH']="/eng/dvtools/release/ruby/mygems"
Gem.clear_paths

require 'optparse'
require 'fileutils'
require 'logger'
require 'awesome_print'
require_relative 'rblib/et_log'

#@@usage="usage: $0 {-h} {-v <verbose level>} {-s <grid number>}"

include ET_LOG

#
# Just define some constants for now and refactor into class if needed
#
CLUSTER="ioshire"
SHIRE_PATH="dv/standalone/#{CLUSTER}"
SHIRE_TEST_DIR="dv/tests/#{CLUSTER}"
START_PC_HEX="40000000"
VERBOSITY_LEVELS=["NONE","LOW","MED","MEDIUM","HIGH","FULL","DEBUG"]
RISCV_LIB="export LD_LIBRARY_PATH=${RISCV}/riscv64-unknown-elf/lib:${LD_LIBRARY_PATH}"
TBV={}
TBV["NONE"]   = " +UVM_VERBOSITY=UVM_NONE    +verbosity=NONE    +DEFAULT_LOG_LEVEL=1 +EMU_LOG_LEVEL=2 "
TBV["LOW"]    = " +UVM_VERBOSITY=UVM_LOW     +verbosity=LOW     +DEFAULT_LOG_LEVEL=0 +EMU_LOG_LEVEL=2 "
TBV["MEDIUM"] = " +UVM_VERBOSITY=UVM_LOW     +verbosity=MEDIUM  +DEFAULT_LOG_LEVEL=0 +EMU_LOG_LEVEL=0 "
TBV["HIGH"]   = " +UVM_VERBOSITY=UVM_MEDIUM  +verbosity=HIGH    +DEFAULT_LOG_LEVEL=0 +EMU_LOG_LEVEL=0 "
TBV["FULL"]   = " +UVM_VERBOSITY=UVM_HIGH    +verbosity=FULL    +DEFAULT_LOG_LEVEL=0 +EMU_LOG_LEVEL=0 +UVM_OBJECTION_TRACE  +UVM_PHASE_TRACE +display_objections +verbosityMESH_MON=DEBUG  +verbosityNOC_SB=DEBUG"
TBV["DEBUG"]  = " +UVM_VERBOSITY=UVM_DEBUG   +verbosity=DEBUG   +DEFAULT_LOG_LEVEL=0 +EMU_LOG_LEVEL=0 +UVM_OBJECTION_TRACE  +UVM_PHASE_TRACE +display_objections +verbosityMESH_MON=DEBUG  +verbosityNOC_SB=DEBUG"
DEFAULT_UVM_TEST="dummy_test"
AAPG_TEST_PATH="#{ENV['REPOROOT']}/dv/tests/ioshire/aapg"

def setup_repo options

   # Is $REPOROOT defined and is it a valid writable path?
   if ENV.has_key? "REPOROOT"
     unless File.writable? ENV['REPOROOT']
       error "$REPOROOT points to non existant path #{ENV['REPO_ROOT']} or is not writable".colorize("red")
     end
   else
       error "Env var reporoot is not defined.  source env.sh in root of repo".colorize("red")
   end

   # Use the ENV var if set otherwise set to default
   unless ENV.has_key? "TESTRUN"
     ENV['TESTRUN'] = "#{ENV['REPOROOT']}/test_run_dir"
   end

   #
   # Now figure out where the log file goes based on test and build paramters
   #
   unless (options[:test] || options[:build] || options[:check_log] || options[:py_test] || options[:max_test] || options[:max_checkpoint] || options[:aapg_test_name])
     error  "-t testname, --test testname, -p testname.py, --py_test testname.py, -m testname, -c checkpoint, --aapg testname are mandatory flags unless using -b or --build or --check_log logfile to post process a log".colorize("red")
   end

   unless options[:build_name]
     options[:build_name]="debug"
   end

   if options[:xprop]
      puts Dir.pwd
      unless File.exists? options[:xprop]
        @log.error "Xprop configuration file does not exist file=#{options[:xprop]}"
      end
      options[:xprop]=File.expand_path options[:xprop]
   end

   if options[:py_test]
     unless (options[:build] || options[:check_log])
       unless File.exist? options[:py_test]
         error "specified python test does not exist. py_test=#{options[:py_test]}"
       end
       options[:py_test_name]=File.basename options[:py_test],'.py'
       options[:py_test] = File.expand_path options[:py_test]
     end
   end

   if options[:aapg_test_name]
    tests = options[:aapg_test_name].split "."
    tests.each do |test|
       unless (options[:build] || options[:check_log])
         aapg_ini_file="#{AAPG_TEST_PATH}/#{test}.ini"
         unless File.exist? aapg_ini_file
           error "specified aapg test does not exist. aapg_test=#{aapg_ini_file}"
         end
       end
     end
   end

   max_test_path="#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files"
   if options[:max_test]
     options[:max_test_name]=options[:max_test]
     unless (options[:build] || options[:check_log] || options[:postsi])
       max_file_path="#{max_test_path}/#{options[:max_test]}.hex"
       unless File.exist? max_file_path
         error "specified maxion test does not exist. max_test=#{max_file_path}"
       end
       options[:max_test] = File.expand_path max_file_path
     end
   end

   if options[:max_checkpoint]
     options[:max_chpt_name]=options[:max_checkpoint]
     unless (options[:build] || options[:check_log])
       max_file_path="#{max_test_path}/#{options[:max_checkpoint]}-mainram.hex"
       unless File.exist? max_file_path
         error "specified maxion checkpoint does not exist. max_checkpoint=#{max_file_path}"
       end
       options[:max_checkpoint] = File.expand_path max_file_path
     end
   end

   logpath="./"
   if options[:target]
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}"
   elsif options[:py_test]
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:py_test_name]}"
   elsif options[:aapg_test_name]
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:aapg_test_name]}"
   elsif options[:max_test]
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:max_test_name]}"
   elsif options[:max_checkpoint]
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:max_chpt_name]}"
   elsif options[:test]
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:test]}"
   else
     logpath="#{ENV['TESTRUN']}/#{CLUSTER}/builds/#{options[:build_name]}"
   end
   if options[:sfx]
     logpath += options[:sfx]
   end
   options[:logpath] = logpath
   options[:build_path]="#{ENV['TESTRUN']}/#{CLUSTER}/builds/#{options[:build_name]}"

   # Cleanup before we open the log
   if options[:clean] || options[:CLEAN] || options[:CLEAN_TEST]
     unless ENV.has_key? 'B4C_NOCLEAN'
       if options[:clean]
         puts "Cleaning build dir=#{options[:build_path]}"
         FileUtils.rm_rf options[:build_path]
       elsif options[:CLEAN]
         puts "Cleaning $TESTRUN=#{ENV['TESTRUN']}"
         FileUtils.rm_rf ENV['TESTRUN']
       elsif options[:CLEAN_TEST]
         puts "Cleaning testcase directory=#{logpath}"
         FileUtils.rm_rf logpath
       end
     else
       puts "Not forcing cleanup due to env $B4C_NOCLEAN set"
     end
   end

   FileUtils.mkdir_p logpath unless Dir.exists? logpath

   unless Dir.exists?  options[:build_path]
     FileUtils.mkdir_p options[:build_path]
   end

   #
   #
   level=:info
   @log = EtLog.new("#{logpath}/run_io.log",:info,false,"run_io")
   if options[:verbose]
    level=:debug
   end
   @log.level = level
   @log.info "run_io is running"
   @log.info "logpath is #{logpath}/run_io.log"
   options[:logfile] = "#{logpath}/run_io.log"

   @log.info "command line=#{options[:cmd_line]}"

   if options[:aapg_test_name]
     @log.info "Using AAPG Version=#{options[:aapg_ver]}"
   end

   unless ENV.has_key? 'B4C_NOCLEAN'
     @log.et_sys "make -f #{ENV['REPOROOT']}/#{SHIRE_PATH}/Makefile clean",false,options[:quiet] if (options[:clean] || options[:CLEAN])
   end

   if options[:py_test]
     unless options[:test]
      options[:test]="py_tb_wfi"
      @log.info "-t was not specified for python test so using default test=#{options[:test]}"
     end

     unless options[:uvm_test]
      options[:uvm_test]="py_tb_example"
      @log.info "-u was not specified for python test so using default test=#{options[:uvm_test]}"
     end
   end

   if options[:aapg_test_name]
     unless options[:test]
      options[:test]="aapgT1"
      @log.info "-t was not specified for AAPG test so using default test=#{options[:test]}"
     end
   end

   if options[:max_test] || options[:max_checkpoint]
     unless options[:test]
      options[:test]="max_linux_boot"
      @log.info "-t was not specified for python test so using default test=#{options[:test]}"
     end
   end

   if options[:git]
     options[:git_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse HEAD"
     options[:git_hash].chomp!
     @log.info "git revision=#{options[:git_hash]}"
     @log.et_sys "echo #{options[:git_hash]} > #{logpath}/git_rev_hash.txt"

     @log.info "Querying git repo for local modifications..."
     diff,rc =@log.et_backtick "cd ${REPOROOT};git diff"
     if diff != ""
       diff_path="#{logpath}/local_modifications.patch"
       f = File.new(diff_path, File::CREAT|File::TRUNC|File::RDWR, 0644)
       f.write diff
       f.close
       @log.warn "There were local modifications so creating patch file #{diff_path}"
     else
       @log.info "Repo is clean there are no modifications"
     end
   end
   Dir.chdir  "#{ENV['TESTRUN']}/#{CLUSTER}"
end

def build_model options
  unless options[:build_args]
    options[:build_args] = ""
  end

  if options[:no_print]
    print_select=" PRINT_OPT+=\"-D NO_PRINT\""
  else
    print_select=""
  end

  if options[:sys_emu_only]
    sys_emu_only="SYS_EMU_ONLY=1"
  else
    sys_emu_only=""
  end

  if options[:stub_randoms]
    stub_randoms="STUB_RANDOMS=1"
  else
    stub_randoms=""
  end

  if options[:bringup]
    bringup_vars="MAXION_BRINGUP=1 MINION_BRINGUP=1 SP_BRINGUP=1 "
    if options[:maxion_uart_print]
      bringup_vars+="MAXION_UART_PRINT=1 "
    end
  else
    bringup_vars=""
  end

  if options[:spi_model]
    model_select="DEFINES+=-DUSE_LE25S161"
  else
    model_select="DEFINES+=-DUSE_LE25S161"
  end
  if not options[:dummy_test]
  unless options[:build]
     @log.info "SW LIB build started".colorize("yellow")
     if options[:lib_recompile]
        @log.et_sys "cd #{ENV['REPOROOT']}/dv/tests/ioshire/scripts;#{RISCV_LIB};make -f makefile.master #{sys_emu_only} #{stub_randoms} #{bringup_vars} cleanswlib",false
     end
     @log.et_sys "cd #{ENV['REPOROOT']}/dv/tests/ioshire/scripts;#{RISCV_LIB};make -f makefile.master #{sys_emu_only} #{stub_randoms} #{bringup_vars} swlib #{print_select} #{model_select}",false#,options[:quiet]
     @log.info "SW LIB build completed".colorize("yellow")
  end
  end

  unless options[:build_test]
    @log.info "VCS Model Build Starting!!!".colorize("yellow")
    simv_path="#{options[:build_path]}/vbuild/simv"

    options[:simv_path]=simv_path

    debug_options=""
    if options[:debug_build]
      debug_options="VCS_DEBUG=2 "
    elsif options[:fast]
      debug_options="VCS_DEBUG=0 "
    else
      debug_options="VCS_DEBUG=1 "
    end
    if options[:upf]
      debug_options += "ENABLE_UPF?=1 "
    end
    if options[:xprop]
      debug_options += "ENABLE_XPROP?=1  XPROP_CFG=#{options[:xprop]}"
    end

    if options[:incr] and File.exists? simv_path
      @log.warn "simv exists but incremental compile was specified. Deleteing simv and building....."
      @log.warn "Deleting simv=#{simv_path}"
      FileUtils.rm_rf simv_path
    end

    profile_args=""

    if options[:py_type] == "jtag"
      if options[:build_args]
        options[:build_args] += " +define+ULTRASOC_JTAG_ENABLE "
      else
        options[:build_args] = " +define+ULTRASOC_JTAG_ENABLE "
      end
      options[:py_type] = " +py_jtag "
    else
      options[:py_type] = " +py_usb "
    end

    if options[:profile]
      options[:build_args] += " -simprofile -pcmakeprof "
    end

    # If CPP debug is enabled add this to make arguments
    #
    if options[:vcs_cpp_debug]
      if options[:vcs_make_args]
        options[:vcs_make_args]+=" VCS_CPP_DEBUG?=1 "
      else
        options[:vcs_make_args]=" VCS_CPP_DEBUG?=1 "
      end
    end
    if not options[:dummy_test]
    unless File.exists? simv_path
      @log.et_sys "make -C #{options[:build_path]} -f #{ENV['REPOROOT']}/dv/standalone/#{CLUSTER}/Makefile all VCS_CMPL_OPTS=\"#{VCS_BUILD_ARGS} #{options[:build_args]}\" #{profile_args} #{debug_options} #{options[:vcs_make_args]}",false,options[:quiet]
    else
      @log.info "Build target #{simv_path} exists so skipping TE build".colorize("yellow")
    end
    end #dummy_test
    @log.info "VCS Model Build Completed!".colorize("yellow")
  end # unless :build_test
end

def build_test options
  @log.info "Build testcase starting!!!".colorize("yellow")
  user_args=""
  test_path="#{ENV['REPOROOT']}/#{SHIRE_TEST_DIR}"
  test_case_path="#{test_path}/#{options[:test]}"
  unless Dir.exists? test_case_path
    @log.error "Can't find test=#{options[:test]} in path=#{test_path}"
  end

  test_base_path=""
  if options[:py_test]
    if options[:sfx]
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}#{options[:sfx]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:py_test_name]}#{options[:sfx]}"
      end
    else
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:py_test_name]}"
      end
    end
    FileUtils.mkdir_p test_base_path unless Dir.exists? test_base_path
    test_target_path="#{test_base_path}/sim"
    @log.et_sys "cp -rL #{test_case_path}/* #{test_base_path}"
  elsif options[:aapg_test_name]
    if options[:sfx]
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}#{options[:sfx]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:aapg_test_name]}#{options[:sfx]}"
      end
    else
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:aapg_test_name]}"
      end
    end
    FileUtils.mkdir_p test_base_path unless Dir.exists? test_base_path
    test_target_path="#{test_base_path}/sim"
    @log.et_sys "cp -rL #{test_case_path}/* #{test_base_path}"
    spMin_dir="#{test_base_path}/spMin"
    aapg_args=" -f "
    tests = options[:aapg_test_name].split "."
    aapg_ddr_id = ""
    tests.each do |test|
      aapg_ini_file="#{AAPG_TEST_PATH}/#{test}.ini"
      aapg_args+=" #{aapg_ini_file} "
      @log.et_sys "cp #{aapg_ini_file} #{spMin_dir}"
      if test.include? "ddr"
         aapg_ddr_id += test
      end
    end
    unless aapg_ddr_id.empty?
      data_preload_knob="#{AAPG_TEST_PATH}/sp_minion_#{aapg_ddr_id}_cfg_knobs.json"
      @log.et_sys "cd #{spMin_dir};/eng/dvtools/release/aapg/#{options[:aapg_ver]}/aapg/make.py --seed #{options[:seed]} -c Minion Minion 1 -r . #{aapg_args} -k /eng/dvtools/release/aapg/#{options[:aapg_ver]}/cfg/sp_minion_default_knobs.json #{data_preload_knob} "
      @log.et_sys "cd #{spMin_dir}/test1;/eng/dvtools/release/aapg/#{options[:aapg_ver]}/tools/sp_asm_process.py; riscv64-unknown-elf-gcc -march=rv64imaf -mcmodel=medany -fomit-frame-pointer -fno-strict-aliasing -fno-builtin -c -o data.o data.s; riscv64-unknown-elf-ld data.o -T /eng/dvtools/release/aapg/#{options[:aapg_ver]}/aapg/sp_link.ld -o data.elf; elf2hex data.elf memImage.hex; mkdir ../../sim; cp memImage.hex ../../sim/memImage.hex "
    else
      @log.et_sys "cd #{spMin_dir};/eng/dvtools/release/aapg/#{options[:aapg_ver]}/aapg/make.py --seed #{options[:seed]} -c Minion Minion 1 -r . #{aapg_args} -k /eng/dvtools/release/aapg/#{options[:aapg_ver]}/cfg/sp_minion_default_knobs.json "

    end
    unless File.exists? "#{spMin_dir}/aapgT1.S"
      @log.et_sys "cd #{spMin_dir};ln -s test1/output.s aapgT1.S"
    end
  elsif options[:max_test]
    if options[:sfx]
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}#{options[:sfx]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:max_test_name]}#{options[:sfx]}"
      end
    else
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:max_test_name]}"
      end
    end
    FileUtils.mkdir_p test_base_path unless Dir.exists? test_base_path
    test_target_path="#{test_base_path}/sim"
    @log.et_sys "cp -rL #{test_case_path}/* #{test_base_path}"
  elsif options[:max_checkpoint]
    if options[:sfx]
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}#{options[:sfx]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:max_chpt_name]}#{options[:sfx]}"
      end
    else
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:max_chpt_name]}"
      end
    end
    FileUtils.mkdir_p test_base_path unless Dir.exists? test_base_path
    test_target_path="#{test_base_path}/sim"
    @log.et_sys "cp -rL #{test_case_path}/* #{test_base_path}"
  else
    if options[:sfx]
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}#{options[:sfx]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:test]}#{options[:sfx]}"
      end
    else
      if options[:target]
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:target]}"
      else
        test_base_path="#{ENV['TESTRUN']}/#{CLUSTER}/#{options[:test]}"
      end
    end
    FileUtils.mkdir_p test_base_path unless Dir.exists? test_base_path
    test_target_path="#{test_base_path}/sim"
    @log.et_sys "cp -rL #{test_case_path}/* #{test_base_path}"
  end
  options[:test_target_path]=test_target_path;
  options[:test_base_path]=test_base_path
  options[:simv_log_path]="#{options[:test_target_path]}/simv.log"

  unless Dir.exists? test_target_path  # Look for sim subdir inside the test case and if it doesn't exist then create it.
    Dir.mkdir test_target_path
  end

  #
  # Create obj dirs for compiling.  make file requires these
  #
  if Dir.exist? "#{test_base_path}/spMin"
    obj_path="#{test_base_path}/spMin/obj"
    unless Dir.exists? obj_path
      @log.debug "Creating path=#{obj_path}"
      Dir.mkdir obj_path
    end
  end

  if Dir.exist? "#{test_base_path}/msMin"
    obj_path="#{test_base_path}/msMin/obj"
    unless Dir.exists? obj_path
      @log.debug "Creating path=#{obj_path}"
      Dir.mkdir obj_path
    end
  end

  if Dir.exist? "#{test_base_path}/ioMax"
    obj_path="#{test_base_path}/ioMax/obj"
    unless Dir.exists? obj_path
      @log.debug "Creating path=#{obj_path}"
      Dir.mkdir obj_path
    end
  end

  # We need to create the top level makefile before we build the test
  #

  if options[:no_print]
    print_flag="PRINT_SEL=2"
    print_select="PRINT_OPT+=\"-D NO_PRINT\""
  else
    print_flag="PRINT_SEL=1"
    print_select=""
  end

make_file_template = <<-EOS_MAKE
#{print_flag}

tc_name = #{options[:test]}
uvm_test = #{options[:uvm_test]}

include ${REPOROOT}/dv/tests/#{CLUSTER}/scripts/makefile.master
EOS_MAKE

  make_path="#{test_target_path}/makefile"
  f = File.new(make_path, File::CREAT|File::TRUNC|File::RDWR, 0755)
  f.write make_file_template
  f.close

  # OK Now actually build the test

  obj_path_max="#{test_base_path}/ioMax/obj"
  path_maxion="#{test_base_path}/ioMax"
  @log.info "Building testcase".colorize("yellow")
  #Recompile all TC and obj files
  if options[:sw_recompile]
    FileUtils.rm_rf obj_path
    @log.debug "Creating path=#{}"
    Dir.mkdir obj_path

    unless !(Dir.exists? path_maxion)
    FileUtils.rm_rf obj_path_max
    @log.debug "Creating path=#{obj_path_max}"
    Dir.mkdir obj_path_max
    end

    rc=@log.et_sys "cd #{test_target_path};#{RISCV_LIB};make cleansw",true
  end

  if options[:sys_emu_only]
    system ("python #{ENV['REPOROOT']}/dv/common/scripts/tcParam_gen.py --path #{test_base_path} --seed #{options[:seed]}") or raise "Cannot execute tcParam generator"
  end

  if options[:stub_randoms]
    system ("python #{ENV['REPOROOT']}/dv/common/scripts/tcParam_gen.py --path #{test_base_path} --seed #{options[:seed]}") or raise "Cannot execute tcParam generator"
  end

  maxion_core_selection=""
  if options[:maxion_core]
    maxion_core_selection="MAXION_BOOT_SELECTION=#{options[:maxion_core]}"
  end

  #default linker script for spMin puts the data into SRAM
  #this behavior is bad for bringup, we must laid down everything into SRAM
  boot_sp_from_sram=""
  if options[:bringup]
   boot_sp_from_sram="BOOT_SP_FROM_SRAM=1"
  end

  if not options[:dummy_test]
  rc=@log.et_sys "cd #{test_target_path};#{RISCV_LIB};make sw #{options[:test_make_args]} #{maxion_core_selection} #{boot_sp_from_sram}",true
  else
  rc=0
  end

  # Create the Status file for et-dvrun
  #
  if rc!=0 || options[:build_test]
    if ENV.has_key? "ETDV_RUNDIR"
      filename="#{ENV['ETDV_RUNDIR']}/status"
    else
      filename="#{test_target_path}/status"
    end

    open(filename, 'w') do |f|
        if rc==0
          f.puts "pass"
        else
          f.puts "fail ET_TESTCASE_BUILD_FAILED"
        end
        f.flush
    end
    if not options[:dummy_test]
    sleep 5
    end
    @log.info   "Created status file with Pathname=#{filename}"
    #
    #  FUTURE: This was debug code added to show Karl. seems to cause hangs now.  Removed.  delete after whiel
    if not options[:dummy_test]
    @log.et_sys "sync;ls -l #{filename}"
    @log.et_sys "cat #{filename}"
    end
    if rc !=0
      @log.error "Testcase build failed.  Created status=#{filename}"
    else
      @log.info "Testcase build PASSED!.  Created status=#{filename}"
    end
  end

  msMinString=""
  if not options[:dummy_test]
  if Dir.exists? "#{test_base_path}/msMin"
    elfs = Dir.glob "#{test_base_path}/msMin/*.elf"
    msMinElf = File.basename elfs[0]
    msMinString = "ELF Load: ../msMin/#{msMinElf}"
  end
  end
  aapgSpDataInDramString=""
  if options[:aapg_test_name] and options[:aapg_test_name].include? "ddr"
     firstMemAddr = File.open("#{test_target_path}/memImage.hex").first.split(' ')[0]
     aapgSpDataInDramString = "File Load: 40'h#{firstMemAddr}, ./memImage.hex\n"
  end
  # Create the mem_desc_text which BEMU uses to load the test into BEMU
mem_desc_txt = <<-EOS
ELF Load: ../spMin/#{options[:test]}.elf
#{msMinString}
#{aapgSpDataInDramString}
Ignore Data: 40'h0010000000, 40'h0011FFFFFF
Ignore Data: 40'h0012000000, 40'h0012007FFF
Ignore Data: 40'h0018000000, 40'h0018082FFF
Ignore Data: 40'h001A000000, 40'h001A007FFF
Ignore Data: 40'h001B000000, 40'h001BFFFFFF
Ignore Data: 40'h0020009000, 40'h0020009FFF
Ignore Data: 40'h0020030000, 40'h002003FFFF
Ignore Data: 40'h0040100000, 40'h00403FFFFF
Ignore Data: 40'h0050000000, 40'h0051FFFFFF
Ignore Data: 40'h0052000000, 40'h005201FFFF
Ignore Data: 40'h0052020000, 40'h0052029FFF
Ignore Data: 40'h0054000000, 40'h005404FFFF
Ignore Data: 40'h0054050000, 40'h0054057FFF
Ignore Data: 40'h0054088000, 40'h0054089FFF
Ignore Data: 40'h0056000000, 40'h0056001FFF
Ignore Data: 40'h0058101000, 40'hC7FFFFFFFF
Ignore Data: 40'h0020007000, 40'h0020007FFF
Ignore Data: 40'h0030001000, 40'h0030001FFF
Ignore Data: 40'h003000A000, 40'h003000BFFF
EOS

  mem_desc_file="#{test_target_path}/mem_desc.txt"
  f = File.new(mem_desc_file, File::CREAT|File::TRUNC|File::RDWR, 0644)
  f.write mem_desc_txt
  f.close

if not options[:dummy_test]
unless File.exist? "#{test_target_path}/vault_rom.vhx"
  @log.debug "Testcase does not specify vault_rom.vhx. linking default Vault ROM Image"
  File.symlink "#{ENV['REPOROOT']}/dv/tests/ioshire/vaultipMinimal/sim/vault_rom.vhx","#{test_target_path}/vault_rom.vhx"
end
end

@log.info "Build testcase completed!!!".colorize("yellow")
end # end of build_test method

# Run Sys Emu to detect possible test problems before actually running the
#

#
#$REPOROOT/emu/bemu/sys_emu/build/sys_emu -l  -max_cycles 1000000 -shires 0x400000000 -minions 0x1 -display_trap_info -elf #aapg.elf -reset_pc 0x40400000 -sp_reset_pc 0x40400000
#

def emu_test options

  sys_emu="#{ENV['BEMU']}/sys_emu/build/sys_emu"

  unless File.executable? sys_emu
    @log.info "Building sys_emu started".colorize("yellow")
    @log.et_sys "cd #{ENV['REPOROOT']}/emu/bemu/sys_emu/;make"
    @log.info "Building sys_emu completed".colorize("yellow")
  end

  sys_emu_txt = <<-EOT
#!/bin/bash -e
set -o pipefail
cd #{options[:test_target_path]}
#{sys_emu} -pu_uart0_tx_file pu_uart_tx.log -mem_desc mem_desc.txt  -sp_reset_pc 0x#{START_PC_HEX} -l  -max_cycles #{options[:sys_emu_max_cycles]}  -shires #{options[:shire_mask]} -minions 0x1 -display_trap_info > sys_emu_run.log 2>&1
EOT

  sys_emu_script="#{options[:test_target_path]}/run_sys_emu"
  f = File.new(sys_emu_script, File::CREAT|File::TRUNC|File::RDWR, 0755)
  f.write sys_emu_txt
  f.close

  sys_emu_pass_string="Signal end test with PASS"

  @log.info "Starting sys_emu on testcase".colorize("yellow")
  rc=@log.et_sys sys_emu_script,true,options[:quiet]

  @log.info "sys_emu completed. Checking pass/fail status".colorize("yellow")
  cat,grep_rc=@log.et_backtick "egrep \"#{sys_emu_pass_string}\" #{options[:test_target_path]}/sys_emu_run.log",true

  if (rc !=0) || (grep_rc !=0)
    @log.warn "sys_emu failed running testcase please review #{options[:test_target_path]}/sys_emu_run.log  sys_emu_rc=#{rc}  log_grep_rc=#{grep_rc}"
  else
    @log.info "sys_emu completed successfully!".colorize("yellow")
  end

  # create pass/fail signature for ET-DVRUN if we are in testcase only mode
  if options[:build_test]
    # Create the Status file for et-dvrun
    #
    if ENV.has_key? "ETDV_RUNDIR"
      filename="#{ENV['ETDV_RUNDIR']}/status"
    else
      filename="#{File.dirname options[:simv_log_path]}/status"
    end

    open(filename, 'w') do |f|
      if (rc==0) && (grep_rc==0)
        f.puts "pass"
   #   elsif (final_errors.size > 0)
   #     f.puts "fail "
      else
        f.puts "fail ET_NO_SYSEMU_PASS_STRING"
     end
     f.flush
     if not options[:dummy_test]
     sleep 5
     end
     @log.info   "Created status file with Pathname=#{filename}"
     @log.et_sys "sync;ls -l #{filename}"
     @log.et_sys "cat #{filename}"
   end
  end # end only build and sys_emu test

end  # end method emu_test()



def run_test options
  @log.info "Running testcase...".colorize("yellow")
  if options[:skip_sp_rom_load]
    test_args = "+UVM_TESTNAME=#{options[:uvm_test]} +HEX_FILE_IOMAX=../ioMax/#{options[:test]}.hex +TC_PATH=$REPOROOT/dv/tests/#{CLUSTER}/#{options[:test]}"
  else
   test_args = "+UVM_TESTNAME=#{options[:uvm_test]} +HEX_FILE=../spMin/#{options[:test]}.hex +HEX_FILE_IOMAX=../ioMax/#{options[:test]}.hex +TC_PATH=$REPOROOT/dv/tests/#{CLUSTER}/#{options[:test]}"
  end

  user_args = " "

  run_cmd_path="#{options[:test_target_path]}/rerun"

  if options[:fsdb]
    user_args+=" +dump=1 +fsdb+mda=on "
    options[:fsdb_run_cmd]="#{options[:test_target_path]}/debug_me"

verdi_template = <<-EOS_VERDI
#!/bin/bash
# NOTE: THIS needs to match version from IOSHIRE makefile
#
#export VERDI_HOME=/eng/cad/tools/snps/verdi/P-2019.06-SP1-1
#export PATH=$VERDI_HOME/bin:$PATH
export DISABLE_TDC_DELETED_MSG=1
cmd=`readlink -f $0`
debug_dir=`dirname $cmd`
verdi -ssf ${debug_dir}/trace.fsdb "$@"
EOS_VERDI

    verdi_path="#{options[:test_target_path]}/debug_me"
    f = File.new(verdi_path, File::CREAT|File::TRUNC|File::RDWR, 0755)
    f.write verdi_template
    f.close

  end  # Verdi

  if options[:no_sva]
    user_args+=" -assert quiet+quiet1+nopostproc "
  end


  if options[:gui]
    user_args+=" -verdi "
  end
  user_args += TBV[options[:tbv]]

  if options[:py_test]
    user_args += " +py_test=#{options[:py_test]} +py_start_script=$REPOROOT/test/scripts/start_ust_vcs +py_sys=soc_tb #{options[:py_type]} "
  end

  if File.exist? "#{options[:test_target_path]}/memImage.hex"
    user_args += " +memImage=#{options[:test_target_path]}/memImage.hex"
  end

  # FUTURE: This is non standard.  Hack to work around stuff
  #
  if Dir.exist? "#{options[:test_target_path]}/../msMin"
    user_args += " +CONTROL_START_PC=0x8000001000 +START_PC=0x8000001000 "
  end

  if options[:max_test]
    user_args += " +MAXIONS_MASK=0x1 +riscvemu_cfg=#{options[:max_test_name]}.cfg  +memImage=#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/#{options[:max_test_name]}.hex +bootramhex=#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/bootram.hex "

    max_cosim_txt = <<-EOT
{version:1,machine:"riscv64",memory_size:256,bios:"#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/#{options[:max_test_name]}.bin",memory_base_addr:0x8000000000,mmio_start:0x100000,mmio_end:0x12003000,bootrom:"#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/bootram.bin",logfile:"#{options[:max_test_name]}.riscvemu.log"}
EOT

     max_cosim_cfg="#{options[:test_target_path]}/#{options[:max_test_name]}.cfg"
     f = File.new(max_cosim_cfg, File::CREAT|File::TRUNC|File::RDWR, 0755)
     f.write max_cosim_txt
     f.close

     @log.debug "max_cosim_cfg=#{max_cosim_txt}"
  end

  if options[:max_checkpoint]
    user_args += " +MAXIONS_MASK=0x1 +riscvemu_cfg=#{options[:max_chpt_name]}.cfg  +memImage=#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/#{options[:max_test_name]}-mainram.hex +bootramhex=#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/#{options[:max_chpt_name]}-maskram.hex "

    max_cosim_txt = <<-EOT
{version:1,machine:"riscv64",memory_size:256,load:"#{options[:max_chpt_name]}",bios:"#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files/bbl-vmlinux0.bin",memory_base_addr:0x8000000000,mmio_start:0x100000,mmio_end:0x12003000,logfile:"#{options[:max_chpt_name]}.riscvemu.log"}
EOT

     max_cosim_cfg="#{options[:test_target_path]}/#{options[:max_chpt_name]}.cfg"
     f = File.new(max_cosim_cfg, File::CREAT|File::TRUNC|File::RDWR, 0755)
     f.write max_cosim_txt
     f.close

     @log.debug "max_cosim_cfg=#{max_cosim_txt}"

     max_test_path="#{ENV['REPOROOT']}/dv/tests/ioshire/maxion-hex-files"
     @log.et_sys "cp #{max_test_path}/#{options[:max_chpt_name]}.re_regs #{options[:test_target_path]}/."
     @log.et_sys "cp #{max_test_path}/#{options[:max_chpt_name]}.bootram #{options[:test_target_path]}/."
     @log.et_sys "cp #{max_test_path}/#{options[:max_chpt_name]}.mainram #{options[:test_target_path]}/."
  end


  @log.debug "user_args=#{user_args}"



python_test_bash=""
if options[:py_test]
  python_test_bash = <<-EOS
rm -rf ${testRunDir}/py_tb_sync
EOS
end

   log_redirect=""
   if options[:quiet]  == :info
     log_redirect=" |& tee simv.log"
   else
     log_redirect=" > simv.log 2>&1"
   end

  lic_debug=""
  if options[:lic_debug]
    lic_debug="export FLEXLM_DIAGNOSTICS=5; export SLI_DEBUG_SERVER=1  # Turn on License debugging"
  end


  rerun_snippet=""
  if options[:dummy_test]
    rerun_snippet="echo '*** TEST HAS PASSED ***' > simv.log\n"\
                  "echo -e 'N0:C0:T0]\t0123456789-9876543210-RET\tRetire' >> simv.log\n"\
                  "##{options[:simv_path]} #{options[:sim_args]} #{SIMV_ARGS} #{test_args} #{user_args} '$@' #{log_redirect}"
  else
    rerun_snippet="#{options[:simv_path]} #{options[:sim_args]} #{SIMV_ARGS} #{test_args} #{user_args} '$@' #{log_redirect}"
  end

run_cmd = <<-EOS
#!/bin/bash
set -o pipefail
export SLI_LOCAL_MODE=1
export DW_WAIT_LICENSE=1   # Wait for VIP License
