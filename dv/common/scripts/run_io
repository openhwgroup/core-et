  f = File.new(run_cmd_path, File::CREAT|File::TRUNC|File::RDWR, 0755)
  f.write run_cmd
  f.close

  # Write the build name so we know which build corresponds to this test for put_dropbox
  #
  f = File.new("#{options[:test_target_path]}/.build", File::CREAT|File::TRUNC|File::RDWR, 0755)
  f.write options[:build_name]
  f.close

  unless options[:dry]
    @log.info   "cd #{options[:test_target_path]};#{run_cmd_path}"
    options[:simv_rc]=@log.et_sys "cd #{options[:test_target_path]};#{run_cmd_path}",true
    if options[:simv_rc] != 0
      @log.error "Simulation exited with return code=#{options[:simv_rc ]}",true
    end
  else
    @log.info "Skipping execution"
    @log.info "final run script: #{run_cmd_path}"
  end
  @log.info "Running testcase completed".colorize("yellow")
end

RTL_PASS_STRINGS=["\*\*\* TEST HAS PASSED \*\*\*",
              "N0:C0:T0]\t[0-9a-f]{10}-[0-9a-f]{10}-RET\tRetire"]


GATE_PASS_STRINGS=["\*\*\* TEST HAS PASSED \*\*\*"]


FAIL_STRINGS=["Checker Error!!",
              " DUT Error \\(ERROR\\)",  # DUT/BEMU
               "UVM_ERROR",              # UVM
               "UVM_FATAL",              # UVM
               ": FATAL ",               # ??
               "Fatal: ",                # ??
               "Assertion failed: ",     # RTL Assertion
               "Error\\\-\\\[",          # Compiler error
               "Fatal\\\-\\\[",          # Compiler error
               "error at time",          # Inside Secure vault IP
               "ERROR CoSIM:",           # COSIM
               "ERROR MAXION:",          # riscvemu MAXION
               "ERROR!",                 # eFuse model
               "Antecedent of the implication never satisfied.",  # VCS error message for bad assertion.  causes non zero rc
               "here is a code failure of some sort",
               "VIRL_MEM_ERR"
               ]

IGNORE_STRINGS=["DUT error count",
               "UVM_ERROR count",
               "UVM_ERROR :",
               "UVM_FATAL :",
               "Number of demoted UVM_ERROR",
               "Number of demoted UVM_FATAL",
               "Number of caught UVM_ERROR",
               "Number of caught UVM_FATAL",
               "error at time               1.0 ns",  # Ignore the 1 Vault error at 1ns
               "time=             10.0 ns",            # Ignore mem errors before reset
               "SYS_ATTRS: S254:N15:C0 thread 0 has already completed the boot code",
               "S254:N15:C0 thread 0 finished the boot code more than once",
               "VIRL_MEM_ERR: Simultaneous access to the same address on B-port.*g_ioshire.ioshire_wrapper.i_ioshire_top.maxshire_top.maxneigh.maxion.maxion_subsys.tile.frontend.bpdpipeline.btb.btb.BTBbigSmall_[0-9]+.BpuSeqMemArray_sram_sram_b0.uut",
               "VIRL_MEM_ERR: Simultaneous access to the same address on B-port.*g_ioshire.ioshire_wrapper.i_ioshire_top.maxshire_top.maxneigh.maxion.maxion_subsys.tile.frontend.bpdpipeline.bpd.tables_[0-9]+.ram.TageTableDataArray_sram_b0.uut",
               "VIRL_MEM_ERR: Simultaneous access to the same address on B-port.*g_ioshire.ioshire_wrapper.i_ioshire_top.maxshire_top.maxneigh.maxion.maxion_subsys.tile_[0-9]+.frontend.bpdpipeline.bpd.tables_[0-9]+.ram.TageTableDataArray_sram_b0.uut",
	       "VIRL_MEM_ERR: Simultaneous access to the same address on B-port.*g_ioshire.ioshire_wrapper.i_ioshire_top.maxshire_top.maxneigh.maxion.maxion_subsys.tile_[0-9]+.frontend.bpdpipeline.btb.btb.BTBbigSmall_[0-9]+.BpuSeqMemArray_sram_sram_b0.uut",
               "VIRL_MEM_ERR: Simultaneous access to the same address on B-port.*g_ioshire.ioshire_wrapper.i_ioshire_top.maxshire_top.maxneigh.maxion.maxion_subsys.tile_[0-9]+.mau",
               "VIRL_MEM_ERR: Simultaneous access to the same address on B-port.*g_ioshire.ioshire_wrapper.i_ioshire_top.maxshire_top.maxneigh.maxion.maxion_subsys.tile.mau.dcache.data",
               "VIRL_MEM_ERR: D unknown>>.*g_ioshire.ioshire_wrapper.i_ioshire_top.spio.vault_wrapper.spio_vault.data_ram.data_ram.uut.report_unknown",
               "VIRL_MEM_ERR: TCLKE Transition during active Clock>>.*g_ioshire.ioshire_wrapper.i_ioshire_top.spio.vault_wrapper.spio_vault.prog_rom.prog_rom.blk_tclkebuf_0",
               "VIRL_MEM_ERR:RSCRST unknown>> at time=            0.180 ns; instance=top.soc_top.*pu.pu_scram_axi",
               "VIRL_MEM_ERR:RSCRST unknown>> at time=            0.180 ns; instance=top.soc_top.*spio.spio_scram_axi",
               "VIRL_MEM_ERR: D unknown.*spio.sp.standalone_minion.icache_data_ram.*uut.report_unknown",
               "<<VIRL_MEM_ERR:OUT OF RANGE BITS IN SCANCHAIN COLUMN>>"
]

# List of files to keep even if we clean_on_pass
#
KEEP_LIST=["spMin.log","ioMax.log","msMin.log"]

#
# Simple method to process pass/fail
# missing proper error checks since we dont have a test that works!
#
def check_test options,logfile

  # FUTURE: re-write
  # This is a total hack. Its just collects errors brute force but does not provide
  # signatures
  # its uses too many external calls
  # hack to eliminate the UVM_ERROR cout
  #
  # This should be replaced by et-dvrun checker
  # These checkers need to be expanded to control strings per test for weird exception cases

  @log.info "Parsing test log=#{logfile} to determine final status".colorize("yellow")

  log_dir = File.dirname logfile
  @log.debug "logpath=#{log_dir}"

  pass_count=0;
  pass_string_criteria_met=false
  missing_pass_strings=""

  if options[:gates]
    my_pass_strings=GATE_PASS_STRINGS
  else
    my_pass_strings=RTL_PASS_STRINGS
  end

  my_pass_strings.each do |pass_string|
    #@log.info "egrep  \"#{pass_string}\" #{logfile}"
    out,rc=@log.et_backtick "egrep -m 1 \"#{pass_string}\" #{logfile}",true
    if (out =="")
      missing_pass_strings << "#{pass_string}\n"
    else
      pass_count +=1
    end
  end

  if (pass_count != my_pass_strings.size)
    pass_string_criteria_met=false
    @log.error "The following require PASS_STRINGS were not found=#{missing_pass_strings}",true
  else
    @log.info "All #{pass_count} PASS_STRINGS were found"
    pass_string_criteria_met=true
  end

  error_strings=""
  FAIL_STRINGS.each do |fail_string|
    #@log.info "egrep  \"#{fail_string}\" #{logfile}"
    out,rc=@log.et_backtick "egrep  \"#{fail_string}\" #{logfile}",true
    if (out !="")
      error_strings << out
    end
  end

  #@log.debug "Error Strings=#{error_strings}"

  errors = error_strings.split "\n"
  final_errors=[];
  errors.each do |error|
    match_any=false
    IGNORE_STRINGS.each do |ignore|
      #@log.info "error=#{error} ignore=#{ignore}"
      if error =~ /#{ignore}/
        #@log.info "MATCH IGNORE"
        match_any=true
      end
    end
    #@log.info "Match Any=#{match_any}"
    final_errors << error unless match_any==true
  end

  if options[:simv_rc] != 0
    final_errors << "Fatal Error: simv exited with non zero return code. rc=#{options[:simv_rc]}"
  end

  # Check for Maxion cosim log
  maxion_pass_string="ET validation mhartid=0 PASS code=0"

  maxion_cosim_log=Dir["#{log_dir}/*.riscvemu.log"]
  if maxion_cosim_log.size != 0
    @log.debug "Maxion cosim log found=#{maxion_cosim_log[0]}"
#   out,rc=@log.et_backtick "egrep  \"#{maxion_pass_string}\" #{maxion_cosim_log[0]}",true
#   if (rc !=0)
#     final_errors << "Error: Maxion cosim log does not contain pass string.  log=#{maxion_cosim_log[0]}"
#   end
  else
    @log.debug "Maxion cosim log does not exist"
  end

 if final_errors.size > 0
  @log.error "Final error count=#{final_errors.size}",true
  final_errors.each do |error|
      @log.error error,true
  end
 else
  @log.info "No errors detected in logfile".colorize("yellow")
 end

 # Create the Status file for et-dvrun
 #
 if ENV.has_key? "ETDV_RUNDIR"
   filename="#{ENV['ETDV_RUNDIR']}/status"
 else
   filename="#{File.dirname logfile}/status"
 end

 open(filename, 'w') do |f|
   if (pass_string_criteria_met) && (final_errors.size==0)
     f.puts "pass"
   elsif (final_errors.size > 0)
     f.puts "fail #{final_errors[0]}"
   else
     f.puts "fail ET_NO_PASS_STRING"
   end
   f.flush
 end
 if not options[:dummy_test]
 sleep 5
 end
 @log.info   "Created status file with Pathname=#{filename}"
 @log.et_sys "sync;ls -l #{filename}"
 @log.et_sys "cat #{filename}"

 if options[:clean_on_pass] && (pass_string_criteria_met) && (final_errors.size==0)
   @log.info "--clean_on_pass specified and test passed. Removing sim directory contents #{File.dirname logfile}".colorize("yellow")
   @log.et_sys "cd #{options[:test_target_path]}; mkdir ../sim_keep"
   KEEP_LIST.each do |file|
     @log.et_sys "cd #{options[:test_target_path]};cp -f #{options[:test_target_path]}/#{file} ../sim_keep"
   end
   @log.et_sys "cd #{options[:test_target_path]};cd ..;mv sim_keep sim; rm -rf spMin;rm -rf ioMax; rm -rf msMin"
   @log.info "--clean_on_pass completed ".colorize("yellow");
 end

   @log.info "Starting test post processing for debug"
   if Dir.exists? "#{log_dir}/../spMin"
     @log.info "Detected testcase spMin directory"
     @log.et_sys "cd #{log_dir};parse_sp_test"
   end
   if Dir.exists? "#{log_dir}/../ioMax"
     @log.info "Detected testcase ioMax directory"
     @log.et_sys "cd #{log_dir};parse_maxion_test"
   end

 return (pass_string_criteria_met) && (final_errors.size==0)
end

#
# MAIN Program starts here
#

begin
   cmd_line="run_io"
   ARGV.each { |arg| cmd_line += " #{arg}" }
   puts "cmd_line=#{cmd_line}"

   options = {}
   OptionParser.new do |opts|
     opts.banner = "Usage: run_io [options]"
     opts.on("-a build_arguments","--build_args build_arguments","Specify additional build arguments") do |arg|
       options[:build_args] = arg
     end
     opts.on("--aapg_ver versioN# ","Run an aapg test defaults to SP template aapgT1") do |arg|
       options[:aapg_ver] = arg
     end
     opts.on("-A aapg_ini_file ","--aapg aapg_ini_file,[opt additional_ini] ","Run an aapg test defaults to SP template aapgT1") do |arg|
       options[:aapg_test_name] = arg
     end
     opts.on("--bringup", "Includes make variables needed for bringup sw") do |arg|
       options[:bringup] = arg
     end
     opts.on("-b", "--build_model", "build model only") do |arg|
       options[:build] = arg
     end
     opts.on("-B buildName", "--build_name buildName", "name of build to use") do |arg|
       options[:build_name] = arg
     end
     opts.on("-c", "--clean", "Clean the just the specified build dir") do |arg|
       options[:clean] = arg
     end
     opts.on("--check_log logfile","Post process build/simulation log for errors") do |arg|
       options[:check_log] = arg
     end
     opts.on("-C", "--clean_all", "Clean all $TESTRUN (all builds and simulations)") do |arg|
       options[:CLEAN] = arg
     end
     opts.on("--clean_test", "Clean just the test directory and not the builds") do |arg|
       options[:CLEAN_TEST] = arg
     end
     opts.on("--clean_on_pass","Clean the simulation dir if test passses") do |arg|
       options[:clean_on_pass] = arg
     end
     opts.on("--vcs_cpp_debug","Builds COSIM & VCS with Address Santizer enabled to debug VCS internal crashes") do |arg|
       options[:vcs_cpp_debug] = arg
     end
     opts.on("-d","--dry_run","Just build everything but don't run the simulation") do |arg|
       options[:dry] = arg
     end
     opts.on("-f", "--fsdb", "dump fsdb") do |arg|
       options[:fsdb] = arg
     end
     opts.on("-F","--force","Compile with full debug_build for forcing and extra debug (runs slow)") do |arg|
       options[:debug_build] = arg
     end
     opts.on("--fast", "optimize build for runtime speed.  no waves/vpd/fsdb possible") do |arg|
       options[:fast] = arg
     end
     opts.on("-g", "--gui", "Run Verdi in interactive mode") do |arg|
       options[:gui] = arg
     end
     opts.on("-G", "--git", "Run record git hash and diff for reproduction") do |arg|
       options[:git] = arg
     end
     opts.on("--gates", "Specify gate_sim.  This changes test pass/fail criteria for gatesime purposes") do |arg|
       options[:gates] = arg
     end
     opts.on("-i", "--incremental", "Enable incremental build in VCS (use at your own risk)") do |arg|
       options[:incr] = arg
     end
     opts.on("-l checkpoint", "--linuxchpt checkpoint", "name of the maxion checkpoint to execute") do |arg|
       options[:max_checkpoint] = arg
     end
     opts.on("--lic_debug") do |arg|
       options[:lic_debug] = arg
     end
     opts.on("--lib_recompile","") do |arg|
       options[:lib_recompile] = arg
     end
     opts.on("-m testname", "--max testname", "name of the maxion testcase to execute") do |arg|
       options[:max_test] = arg
     end
     opts.on("--maxion_core maxion_core", "Maxion core to keep alive in the simulation for BootRAM") do |arg|
       options[:maxion_core] = arg
     end
     opts.on("--maxion_uart_print", "Default printDbg via mailbox, if passed, print via PU_UART0") do |arg|
       options[:maxion_uart_print] = arg
     end
     opts.on("-M arguments", "--make arguments", "Pass arguments directly to VCS make file") do |arg|
       options[:vcs_make_args] = arg
     end
     opts.on("--no_cosim","Don't enable cosim checking step") do |arg|
       options[:no_cosim] = arg
     end
     opts.on("--no_print","Don't enable printDbg") do |arg|
       options[:no_print] = arg
     end
     opts.on("--no_sva","Quiet SVA's") do |arg|
       options[:no_sva] = arg
     end
     opts.on("-o name", "--target name", "Use specified name as target directory instead of the default testname") do |arg|
       options[:target] = arg
     end
     opts.on("-p testname", "--py_test testname", "name of (Ultrasoc/Python) testcase to execute") do |arg|
       options[:py_test] = arg
     end
     opts.on("--py_type usb|jtag", "Type of connection of ultrasoc test usb|jtag") do |arg|
       options[:py_type] = arg
     end
     opts.on("--profile","Profile simulation runtime") do |arg|
       options[:profile] = arg
     end
     opts.on("--postsi","Post silicon test") do |arg|
       options[:postsi] = arg
     end
     opts.on("-q","--quiet","Enable quiet simulation mode") do |arg|
       options[:quiet] = ":debug"
     end
     opts.on("-s args","--sim_args args","Arguements to pass directly to the simulator") do |arg|
       options[:sim_args] = arg
     end
     opts.on("--seed <num>","Specify seed or else random") do |arg|
       options[:seed] = arg
     end
     opts.on("--sfx suffix","Specify a suffix to append to test name") do |arg|
       options[:sfx]  = arg
     end
     opts.on("--skip_emu","Skip the emu step") do |arg|
       options[:skip_emu] = arg
     end
     opts.on("--skip_sp_rom_load","Don't load the testcase contents into the ROM.  Use with Gate level ROMs") do |arg|
       options[:skip_sp_rom_load] = arg
     end
     opts.on("--spi_model","Don't enable printDbg") do |arg|
       options[:spi_model] = arg
     end
     opts.on("--sys_emu_only","Change implementation of tb.c to tb_sysemu.c") do |arg|
       options[:sys_emu_only] = arg
     end
     opts.on("--stub_randoms", "Allow generation of tcParam.h") do |arg|
       options[:stub_randoms] = arg
     end

     opts.on("--sys_emu_max_cycles <num>","SYS_EMU simulation max cycles") do |arg|
       options[:sys_emu_max_cycles] = arg
     end
     opts.on("--sw_recompile","") do |arg|
       options[:sw_recompile] = arg
     end
     opts.on("-t testname", "--test testname", "name of testcase to execute") do |arg|
       options[:test] = arg
     end
     opts.on("-T testname", "--TEST testname", "Just build the testcase. Nothing else") do |arg|
       options[:test] = arg
       options[:build_test] = arg
     end
     opts.on("--test_make args", "Arguments are passed directory to testcase makefile") do |arg|
       options[:test_make_args] = arg
     end
     opts.on("-u uvm_testname","--uvm_test uvm_testname","Specify a UVM testname") do |arg|
       options[:uvm_test] = arg
     end
     opts.on("-U","--upf","Enable VCS UPF simulation mode") do |arg|
       options[:upf] = arg
     end
     opts.on("-v", "--[no-]verbose", "Run verbosely") do |arg|
       options[:verbose] = arg
     end
     opts.on("-V verbosity_level","--tbv verbosity_level","TB verbosity=[NONE,LOW,MED,HIGH,FULL,DEBUG") do |arg|
       options[:tbv] = arg.upcase
     end
     opts.on("-x xprop_file","--xprop xprop_file","Enable VCS X propogation mode") do |arg|
       options[:xprop] = arg
     end
     opts.on("-z", "--dummy_test", "Produce only rerun scripts") do |arg|
       options[:dummy_test] = arg
     end
   end.parse!
   options[:cmd_line]=cmd_line

   unless options[:quiet]
     options[:quiet]=:info
   end

   #
   # Setup the workspace, cleanup, and get the log setup
   #
   setup_repo options

   require 'socket'
   hostname = Socket.gethostname
   if (hostname =~ /vnc/) || (hostname =~ /sc\-dv[\d]*/)
     @log.error "running run_io directly on hostname=#{hostname} is forbidden. use \'srun run_io ....\' instead"
   end

   #
   # No check the rest of the command line flags
   #
   @log.debug "sim_args=#{options[:sim_args]}"

   unless options[:aapg_ver]
     options[:aapg_ver]="LATEST"
   end

   unless options[:sys_emu_max_cycles]
       options[:sys_emu_max_cycles] = 1000000
   end
   @log.info "SYSEMU_max_cycles=#{options[:sys_emu_max_cycles]}"

   unless options[:seed]
     options[:seed] = rand(0..0xFFFFFFFF)
     unless options[:build]
       @log.info "No command line seed specified.  Generated random SEED=#{options[:seed]}"
     end
   else
     unless options[:build]
       @log.info "Using command line SEED=#{options[:seed]}"
     end
   end

   unless options[:tbv]
       options[:tbv]="MEDIUM"
   end

   if options[:tbv]=="MED"
     options[:tbv]="MEDIUM"
   end

   unless VERBOSITY_LEVELS.include? options[:tbv]
     @log.error "Invalid verbosity level! Valid Levels=#{VERBOSITY_LEVELS}"
   end

   unless options[:py_type]
     options[:py_type]="usb"
     @log.info "--py_type was not specified for python test so using default connection=usb"
   end

   unless ["usb","jtag"].include? options[:py_type]
     @log.error "--py_type must be either jtag or usb.  #{options[:py_type]} is not a valid value"
   end

   #@log.ap options

   #Check for Valid Testcase
   #
   test_path="#{ENV['REPOROOT']}/#{SHIRE_TEST_DIR}"
   test_case_path="#{test_path}/#{options[:test]}"
   @log.info "C/ASM Testcase path=#{test_case_path}";
   unless Dir.exists? test_case_path
     @log.error "Can't find test=#{options[:test]} in path=#{test_path}"
   end



   #
   # FUTURE:  Refactor this into a method soon
   #
   if options[:no_cosim]
     checker_flag=" +CHECKER=0 +COSIM_LOG_LEVEL=1"
   else
     checker_flag=" +MONITOR=1 +CHECKER=1 +COSIM_LOG_LEVEL=1"
   end

   if Dir.exists? "#{test_case_path}/msMin"
     options[:shire_mask]="0x500000000"
   else
     options[:shire_mask]="0x400000000"
   end

   SIMV_ARGS="+verbosityTIMER=HIGH +vcs+lic+wait \
   #{checker_flag}  +SHIRE_MASK=#{options[:shire_mask]} +UVM_TIMEOUT=50000000 +ntb_random_seed=#{options[:seed]} +SEED=#{options[:seed]}"

   @log.debug "SIMV_ARGS=#{SIMV_ARGS}"

   VCS_BUILD_ARGS="+define+SVT_FSDB_ENABLE "

   #
   # End refactor section
   #

   unless (options[:uvm_test])
     @log.warn "no uvm test specified on command line.  Using default uvm_test=#{DEFAULT_UVM_TEST}"
     options[:uvm_test]=DEFAULT_UVM_TEST
   end
   if options[:check_log]
     unless File.exist? options[:check_log]
       @log.error "Logfile does not exist path=#{options[:check_log]}"
     end
     options[:simv_rc]=0
     @log.info "Post processing logfile=#{options[:check_log]}";
     final_pass_status=check_test options,options[:check_log]  # Check the logs and determing final pass/fail status
     exit final_pass_status;
   end

   build_model options  # Build the SIMV file to run. if :build_test it will just build SW Library which is needed for testcases

   # Run the sim and process the results
   #
   unless options[:build]

     build_test  options   # Compile the testcase

     unless options[:skip_emu]
       emu_test  options   # Check that the test runs on the SYS EMU emulator
     end
     if options[:build_test]
       @log.info "-T option specified.  Testcase has been built exiting!".colorize("yellow")
       exit 0
     end

     run_test options      # Actually run the RTL Simulation
     final_pass_status=check_test options,options[:simv_log_path]  # Check the logs and determing final pass/fail status

     if options[:fsdb]
       @log.info "invoke waves:  #{options[:fsdb_run_cmd]}".colorize("yellow")
     end
     @log.info "Path to log:  #{options[:simv_log_path]}".colorize("yellow")

     if (final_pass_status==true)
       @log.smiley
       if options[:clean_on_pass]  # only delete the log with the true argument to close if we pass and option is specified
         @log.close true unless @log.nil?
         @log=nil
       end
     else
       @log.cross
       exit 1;
     end
   end

rescue Interrupt => e
  @log.info "Interrupt detected (Ctrl-c): #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}"
  exit 1
#rescue Exception => e
#  @log.info "Exception detected : #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}"
# exit 1
rescue SystemExit => e
  exit e.status
ensure
  @log.close unless @log.nil?
end
