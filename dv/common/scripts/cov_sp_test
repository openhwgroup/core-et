$shire_dict = {34 => "sp", 32 => "msMin"}

class MergeRec
  attr_accessor :filename,:size, :map

  def initialize
    @filename="unknown"
  end
end

class Func
  attr_accessor :name,:file,:start_addr,:end_addr,:cov,:insn_cov_percent,:latency,:best_latency,:worst_latency,:status,:total_lines, :lines_covered,:num_insn,:cov_insn,:line_num,:waived,:waiver_reason

  def initialize
    @cov={}
    @file="unknown"
    @line_num=0
    @num_insn=0
    @cov_insn=0
    @name="unknown"
    @start_addr=0
    @end_addr=0
    @latency=0
    @status=""
    @waived=false
    @waiver_reason=""
    @best_latency=nil
    @worst_latency=0
  end # end constructor

  def to_array
   if @waived
     temp_waiver = @waiver_reason
   else
     temp_waiver = ""
   end
   [] << "#{@file}:#{@line_num}" << @name  << @num_insn << @cov_insn << @best_latency << @worst_latency << @status << (@insn_cov_percent * 100).to_i << @waiver_reason << @start_addr << @end_addr
  end
end # end class

class Cov_rec
  attr_accessor :count,:cycle,:tests,:instruction,:waived

  def initialize
    @count=0
    @cycle=0
    @instruction=""
    @tests=[]
    @insn_cov_percent=0
    @latency=0
    @waived=false
  end

end # end class Func

def file_edit(filename, regexp, replacement)
  Tempfile.open(".#{File.basename(filename)}", File.dirname(filename)) do |tempfile|
    File.open(filename).each do |line|
      tempfile.puts line.gsub(regexp, replacement)
    end
    tempfile.fdatasync
    tempfile.close
    stat = File.stat(filename)
    FileUtils.chown stat.uid, stat.gid, tempfile.path
    FileUtils.chmod stat.mode, tempfile.path
    FileUtils.mv tempfile.path, filename
  end
end

def setup_repo options

   # Is $REPOROOT defined and is it a valid writable path?
   if ENV.has_key? "REPOROOT"
     unless File.writable? ENV['REPOROOT']
       error "$REPOROOT points to non existant path #{ENV['REPO_ROOT']} or is not writable".colorize("red")
     end
   else
       error "Env var reporoot is not defined.  source env.sh in root of repo".colorize("red")
   end

   logpath="."
   options[:logpath] = logpath

   # Now that we are done cleaning etc, we can setup the proper log
   #
   level=:info
   @log = EtLog.new("#{logpath}/#{options[:output]}.log",:info,false,"cov_sp_test")
   if options[:verbose]
    level=:debug
   end
   @log.level = level
   @log.info "cov_sp_test is running"
   @log.info "logpath is #{logpath}/#{options[:output]}.log"
   options[:logfile] = "#{logpath}/#{options[:output]}.log"

   @log.info "command line=#{options[:cmd_line]}"

   options[:git_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse HEAD"
   options[:git_hash].chomp!
   @log.info "git revision=#{options[:git_hash]}"

   options[:git_short_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse --short HEAD"
   options[:git_short_hash].chomp!
   @log.info "git short hash=#{options[:git_short_hash]}"
end # setup_repo()

def parse_filter_file filename,map
  unless File.exist? filename
    @log.error "file=#{filename} is not found"
  end
  @log.info "Parsing filter file=#{filename}"

  File.open(filename) do |f|
    f.each_line do |line|
      @log.debug  "line=#{line}"
      if line =~ /^\s*\/\//      # Full line comment
        @log.debug "Skipping comment line=#{line}"
        next
      elsif line =~ /^\s*name:\s*([\d\w_]+)\s*(.*)/   # Function filter
        func_name=$1
        waiver_reason=$2
        @log.debug "Filter new Function! Addr=#{func_name}"
        map.each do |key,val|
          if val.name == $1
            @log.debug "Waiving coverage for function=#{$1}"
            val.waived=true
            val.waiver_reason=waiver_reason
            val.cov.each do |cov_key,cov_val|
              cov_val.waived=true
            end
            break
          end
        end
      elsif line=~ /\s*([\da-fA-F]+)-\s*([\da-fA-F]+)/   # Address Range Filter
        @log.debug "Found a filter range #{$1} #{$2}"
        start_addr=$1.to_i(16)
        end_addr=$2.to_i(16)
        map.each do |key,val|
            val.cov.each do |cov_key,cov_val|
              if cov_key >= start_addr and cov_key <= end_addr
                cov_val.waived=true
                @log.debug "Waiving address=#{cov_key}"
              end
            end
        end
      elsif line=~ /\s*([\da-fA-F]+)/   # Single Address filter
        @log.debug "Found a filter addr"
        addr=$1.to_i(16)
        map.each do |key,val|
            val.cov.each do |cov_key,cov_val|
              if cov_key == addr
                cov_val.waived=true
                @log.debug "Waiving address=#{addr}"
                break
              end
            end
        end
      end
    end
  end # end each line in file

  #ap map, :raw=>true
  @log.info "Done parsing filter file"
end # parse_filter_file()


def parse_lst_file filename

  unless File.exist? filename
    @log.error "file=#{filename} is not found"
  end
  @log.info "Parsing dissasembly file=#{filename}"
  map=Hash.new
  last_rec=nil
  File.open(filename) do |f|
    f.each_line do |line|
      #puts line
      if line =~ /^([\da-fA-F]+) <([\w_]+)>:/
        @log.debug "Found new Function! Addr=#{$1}  Name=#{$2}"
        rec=Func.new
        rec.name=$2
        rec.start_addr=$1.to_i(16)
        map[rec.start_addr]=rec
        last_rec=rec
      elsif line=~ /\s+([\da-fA-F]+):\s+([\da-fA-F]+)\s+(.*)/   # Compute the end address
        addr=$1.to_i(16)
        opcode=$2
        insn=$3.strip
        rec=Cov_rec.new
        rec.count=0
        rec.cycle=0
        rec.instruction=insn
        last_rec.cov[addr]=rec
        last_rec.end_addr=$1.to_i(16)
      elsif line=~ /([\w_]+.c):(\d+)/   # Compute the end address
        last_rec.file=$1
        last_rec.line_num=$2
      end
    end
  end # end each line in file

  # Delete the data segmnents which have no end_addr
  map.each do |key,val|
    if val.end_addr.nil?
     map.delete(key)
    end
  end

  #ap map, :raw=>true
  @log.info "Done Parsing dissasembly file=#{filename}"
  return map
end # parse_lst_file()

def map_list_to_exe_c options,map, shire
  @log.info "Processing co-sim event trace....."
  map_filename="#{$shire_dict[shire]}_trace.log"
  #open(map_filename, 'w') do |of|
      STDIN.each_line do |line|
        if line =~ /inst_retire.*cycle=(\d+).*pc=(\d+)/
         cycle=$1.to_i
         addr=$2.to_i
         #puts line
         #puts "cycle=#{$1}"
         @log.debug "processing pc=#{addr.to_s(16)}"
          map.reverse_each do |key,val|
            #puts "key=#{key.to_s(16)} #{val.name} addr=#{addr.to_s(16)}"
            if addr >= key
#              of.write "function: #{val.name} :: #{line}\n"
              #puts "TRUE"
              #ap val.cov

              if val.cov.key? addr
                cov_rec=val.cov[addr]
                unless cov_rec.tests.include? options[:test_name]
                  cov_rec.tests << options[:test_name]
                end
                cov_rec.count +=1
                if cov_rec.cycle==0
                  cov_rec.cycle=cycle
                end
                @log.debug "setting addr=#{addr.to_s(16)} count=#{val.cov[addr].count} test_name=#{cov_rec.tests}"
              else
                #puts "DOES NOT EXIST"
                #rec=Cov_rec.new
                #rec.count=1
                #rec.cycle=cycle
                #rec.tests << options[:test_name]
                #val.cov[addr]=rec
                @log.error "This path should not be taken.  Something is wrong!"
              end
              break
            end
          end
        end
      end
  #end # end each line in file
  #ap map,raw:true
end

def compute_coverage options,map
  summary = Func.new

  map.each do |key,rec|
    @log.info "key=#{key}"
    if rec.waived
      @log.debug "Waiving coverage for function=#{rec.name} start_addr=#{rec.start_addr.to_s(16)} end_addr=#{rec.end_addr}"
    else
      @log.debug "Computing Coverage for function=#{rec.name} start_addr=#{rec.start_addr.to_s(16)} end_addr=#{rec.end_addr}"
    end

    computed_size=rec.end_addr-rec.start_addr
    expect_insn=computed_size/4+1
    summary.num_insn+=expect_insn
    @log.debug "computed_size=#{computed_size} num_insn=#{expect_insn}"
    cov_insn=0
    start_cycle=nil
    end_cycle=0
    start_cycle=rec.cov[rec.start_addr].cycle
    @log.debug "func_name=#{rec.name} start_addr=#{rec.start_addr} end_addr=#{rec.end_addr} cycle=#{start_cycle}"
    end_addr=rec.end_addr

    while end_cycle == 0 and  (end_addr > rec.start_addr)
     #@log.info "End_addr=#{end_addr} rec.start_addr=#{rec.start_addr} rec.end_addr=#{rec.end_addr} start_cycle=#{start_cycle} end_cycle=#{end_cycle}"
      #ap rec.cov, :raw => true
      #exit
      if rec.cov[end_addr].nil?
        break
      else
        end_cycle=rec.cov[end_addr].cycle
      end

      if end_cycle==0 or end_cycle.nil?
         rec.latency=0
         rec.status="NC"
         end_addr -=4
      else
         if start_cycle > end_cycle
           @log.error "latency is negative.  start_cycle=#{start_cycle} end_cycle=#{end_cycle}", true
         end
         if (end_addr == rec.end_addr)
           rec.latency  = end_cycle - start_cycle
         else
           rec.latency  = end_cycle - start_cycle
         end
      end
      #puts "looping end_cycle=#{end_cycle}"
    end

    # if we have a valid latency record then lets update the best and worst case #'s
    #
    if rec.latency > 0
      if (rec.latency > rec.worst_latency)
        rec.worst_latency = rec.latency
      end
      if rec.best_latency.nil?
         rec.best_latency = rec.latency
      elsif rec.latency < rec.best_latency
         rec.best_latency = rec.latency
      end
    end

    unless rec.waived
      rec.cov.each do |addr,cov_rec|
        if cov_rec.count > 0 || cov_rec.waived
          cov_insn +=1
        end
      end
      if cov_insn > expect_insn
        @log.error "covered instructions=#{cov_insn} > expected_instructions=#{expect_insn}.  Something is wrong"
      end
      rec.insn_cov_percent=cov_insn.to_f/expect_insn.to_f
      rec.cov_insn=cov_insn
      @log.info "rec.insn_cov_percent=#{rec.insn_cov_percent}"
      if rec.insn_cov_percent == 1.0
        rec.status="C"
      elsif rec.latency < 0
        rec.status="E"
      else
        rec.status="NC"
      end
    else
      rec.insn_cov_percent=1.0
      rec.cov_insn=rec.cov.size
      rec.status = "W"
    end
    rec.num_insn=(rec.end_addr-rec.start_addr)/4+1
    @log.info "function=#{rec.name} Total Instructions=#{expect_insn} Measured Instructions=#{cov_insn} cov%=#{cov_insn.to_f/expect_insn.to_f}  latency=#{rec.latency}"
    summary.cov_insn += rec.cov_insn
  end
  summary.insn_cov_percent=(summary.cov_insn.to_f/summary.num_insn.to_f*100).to_i
  summary.name = "Totals:"
  return summary
  #ap map
end

def gen_holes_report   options,map,summary


map = map.sort_by {|k, v| -v.insn_cov_percent}.to_h

table_header_css = <<-HEADER
<!DOCTYPE html>
<html>
