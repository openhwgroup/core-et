  background: #ccffff;
}

</style>

HEADER

xm = Builder::XmlMarkup.new(:indent => 2)

xm.table {
     xm.tr { ["File Name:Line #","Function Name","Total # Instructions","Instructions Executed","Low # Cycles","High # Cycles","Status","Cov%","Waiver","Start_addr","End_addr"].each { |key| xm.th(key)}}
     map.each { |key,row|
         if row.insn_cov_percent != 1.0
           xm.tr { row.to_array.each { |value| xm.td(value)}}
         end
     }
   }

  map.each { |key,row|
    @log.info "Cov Detail for function=#{row.name} total_instructions=#{row.num_insn} covered_instructions=#{row.cov_insn} uncoverd_instructions=#{row.num_insn-row.cov_insn}"
    if row.insn_cov_percent != 1.0
      row.cov.each do |cov_key,rec|
        if rec.count == 0
          @log.info "    addr=#{cov_key.to_s(16)} count=#{rec.count} instruction=#{rec.instruction}"
        end
      end
    end
  }


table_footer = <<-FOOTER
 <tfoot>
 <tr>
    <td>All Files</td>
    <td>Totals:</td>
    <td>0</td>
    <td>0</td>
    <td>#{summary.num_insn}</td>
    <td>#{summary.cov_insn}</td>
    <td>unknown</td>
    <td>#{summary.insn_cov_percent}</td>
    <td></td>
    <td></td>
    <td></td>
  </tr>
  </tfoot>
  </table>
FOOTER

  File.open("#{options[:output]}_holes.html", 'w') { |file| file.write table_header_css+xm}
  file_edit("#{options[:output]}_holes.html",/<table>/,'<table class="searchable sortable">')
  file_edit("#{options[:output]}_holes.html",/<\/table>/,table_footer)
end


