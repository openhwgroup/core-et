def merge_cov merge_list
  merge_map=nil
  merge_list.each do |rec|
    @log.info "Merging file=#{rec.filename}"
    if merge_map.nil?  # copy the 1st record as the base for the merge
      merge_map=Marshal.load(Marshal.dump(rec.map))

      #@log.info "Source Map"
      #ap rec.map, :raw => true

      #@log.info "Merge Map"
      #ap merge_map, :raw => true
      @log.debug "Made an initial copy()"
    else
       rec.map.each do |key,temp_map|
         #@log.info "print key=#{key}"
         unless merge_map.key? key
           @log.error "File=#{rec.filename} has a function named=#{temp_map.name} at address=#{key.to_s(16)} and the master merge record does not contain this address. Source files must be from same dissasebly file"
         end
         #ap temp_map.start_addr, :raw => true
         local_merge = merge_map[key]
         #ap local_merge , :raw=>true

         # Do lots of error checking to make sure we merge like objects and avoid bad inputs from users and potential program bugs
         unless temp_map.start_addr == local_merge.start_addr
           @log.error "File=#{rec.filename} has a function named=#{temp_map.name} with start_addr=#{temp_map.start_addr} while merge record has start_addr=#{local_merge.start_addr}"
         end
         unless temp_map.end_addr == local_merge.end_addr
           @log.error "File=#{rec.filename} has a function named=#{temp_map.name} with end_addr=#{temp_map.end_addr} while merge record has end_addr=#{local_merge.end_addr}"
         end
         unless temp_map.num_insn == local_merge.num_insn
           @log.error "File=#{rec.filename} has a function named=#{temp_map.name} with num_insn=#{temp_map.end_addr} while merge record has num_insn=#{local_merge.num_insn}"
         end
         unless temp_map.cov.size == local_merge.cov.size
           @log.error "File=#{rec.filename} has a function named=#{temp_map.name} with cov_hash.size=#{temp_map.cov.size} while merge record has cov_hash.size=#{local_merge.cov.size}"
         end
         unless temp_map.cov.keys.all?{ |key| !!local_merge.cov[key] }
           @log.error "File=#{rec.filename} has a function named=#{temp_map.name} with cov_hash.size=#{temp_map.cov.size} while merge record has cov_hash.size=#{local_merge.cov.size} but the keys are different"
           ap temp_map.cov
           ap local_merge.cov
         end

         # if we have a valid latency record then lets update the best and worst case #'s
         #
         if (temp_map.worst_latency > local_merge.worst_latency)
            local_merge.worst_latency = temp_map.worst_latency
         end

         if local_merge.best_latency.nil?
           unless temp_map.best_latency.nil?
             local_merge.best_latency= temp_map.best_latency
           end
         else
           unless temp_map.best_latency.nil?
             if temp_map.best_latency < local_merge.best_latency
               local_merge.best_latency = temp_map.best_latency
             end
           end
         end

         temp_map.cov.each do | key,cov_rec |
            if cov_rec.count > 0
              #@log.info "Adding coverage for key=#{key}"
              local_merge.cov[key].tests += cov_rec.tests
              if local_merge.cov[key].count == 0
                @log.info "File=#{rec.filename} has a test=#{cov_rec.tests} and function=#{temp_map.name} with new coverage for addr=#{key}"
                #@log.debug "tests=#{local_merge.cov[key].tests}"
                #ap local_merge, :raw=>true
                #exit
              end
              local_merge.cov[key].count += cov_rec.count
            end
         end
       end
    end
  end
  return merge_map
end


begin
   cmd_line="cov_sp_test"
   ARGV.each { |arg| cmd_line += " #{arg}" }

   options = {}
   OptionParser.new do |opts|
     opts.banner = "Usage: gen_bist_br [options]"
     opts.on("-n", "--no_branch", "Clean the just the specified build dir") do |arg|
       options[:no_branch] = arg
     end
     opts.on("-t test_name", "--test test_name", "Specify the name of the test") do |arg|
       options[:test_name] = arg
     end
     opts.on("-c cov_file", "--cov cov_file", "Specify the name of the coverage file") do |arg|
       options[:cov_name] = arg
     end
     opts.on("-d dis_name", "--dis dis_name", "Specify the name of the dissasembly file") do |arg|
       options[:dis_name] = arg
     end
     opts.on("-f filter_file", "--filter filter_file", "Specify the name of the filter/waiver file") do |arg|
       options[:filter_name] = arg
     end
     opts.on("-m file1,file2", "--merge file1,file2", "List of files to Merge") do |arg|
       options[:merge] = arg
     end
     opts.on("-o filename", "--output filename", "Output prefix filename") do |arg|
       options[:output] = arg
     end
     opts.on("-q", "--quiet", "Quiesce most output") do |arg|
       options[:quiet] = arg
     end
     opts.on("-v", "--verbose", "Verbose output") do |arg|
       options[:verbose] = arg
     end
   end.parse!
   options[:cmd_line]=cmd_line

   unless options[:quiet]
     options[:quiet]=:info
   end

   unless options[:test_name]  # Attempt to automatically discern testname. ignore ioshire sim directory
     path= Dir.pwd
     parts=path.split("/")
     if parts.last == "sim"
       options[:test_name]=parts[-2]
     else
       options[:test_name]=parts[-1]
     end
   end

   unless options[:output]
     options[:output]="#{options[:test_name]}"
   end

   #
   # Setup the workspace, cleanup, and get the log setup
   #
   setup_repo options
   @log.info "cmd_line=#{cmd_line}"

   require 'socket'
   hostname = Socket.gethostname
   @log.info "running on hostname=#{hostname}"



   ap options      if options[:verbose]
   @log.ap options if options[:verbose]

   if options[:merge]
     ap options[:merge]
     options[:merge_list] = options[:merge].split ","

     ap options[:merge_list]

     good_file_list=true
     missing_files=[]
     merge_list=Array.new
     options[:merge_list].each do |merge_file|
       @log.info "Processing Coverage file=#{merge_file}"
       unless File.exist? merge_file
         @log.error "merge file=#{merge_file} does not exist",true
         good_file_list=false
         missing_files << merge_file
       else
         rec=MergeRec.new
         rec.filename=merge_file
         rec.map=ObjectStash.load merge_file
         rec.size=rec.map.size
         merge_list << rec
         @log.info "Created record for file=#{rec.filename} of size=#{rec.size}"
       end
     end
     @log.info "Processed #{merge_list.size} coverage files"
     unless good_file_list
       @log.error "One of more of the files specified to merge does not exist.  please correct and try again!",true
       @log.error "missing_files=#{missing_files}"
     end
     @log.info "Loaded all databases to Merge"

     #ap merge_list, :raw => true
     merge_map=merge_cov merge_list
     if File.exists? options[:output]
       @log.error "Output file=#{options[:output]} already exists aborting...."
     end
     ObjectStash.store merge_map, "#{options[:output]}.cov.gz"
     @log.info "Wrote merged coverage database to #{options[:output]}.cov.gz"
     summary=compute_coverage options,merge_map
     gen_summary_report options,merge_map,summary
     gen_holes_report options,merge_map,summary
   elsif options[:cov_name]
     unless File.exists? options[:cov_name]
       @log.error "Coverage file=#{options[:cov_name]} does not exist!"
     else
       @log.info "Loading coverage database file=#{options[:cov_name]}"
     end
     map=ObjectStash.load options[:cov_name]
     if options[:filter_name]
       parse_filter_file options[:filter_name],map
     end
     summary=compute_coverage options,map
     gen_summary_report options,map,summary
     gen_holes_report options,map,summary
     ObjectStash.store map, "#{options[:output]}.cov.gz"
     @log.info "Wrote coverage database to #{options[:output]}.cov.gz"
     @log.info "DONE!"
   else
     unless options[:dis_name]
       @log.info "spMin parsing ... "
       dis = Dir.glob "../spMin/*.dis"
       options[:dis_name] = "../spMin/#{File.basename dis[0]}"
     end
       shire = 34

     map=parse_lst_file options[:dis_name]
     if options[:filter_name]
       parse_filter_file options[:filter_name],map
     end
     map_list_to_exe_c options,map, shire
     summary=compute_coverage options,map
     gen_summary_report options,map,summary
     gen_holes_report options,map,summary
     ObjectStash.store map, "#{options[:output]}.cov.gz"
     @log.info "Wrote coverage database to #{options[:output]}.cov.gz"
     @log.info "DONE!"
   end # if not Merge

rescue Interrupt => e
  @log.info "Interrupt detected (Ctrl-c): #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}"
  exit 1
#rescue Exception => e
#  @log.info "Exception detected : #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}"
# exit 1
rescue SystemExit => e
  exit e.status
ensure
  @log.close unless @log.nil?
end
