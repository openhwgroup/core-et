include ET_LOG


class Ifreq_map
  attr_accessor :started,:base,:consistent

  def initialize
    @started=false
    @consistent=[]
  end # end constructor

end # end class


def file_edit(filename, regexp, replacement)
  Tempfile.open(".#{File.basename(filename)}", File.dirname(filename)) do |tempfile|
    File.open(filename).each do |line|
      tempfile.puts line.gsub(regexp, replacement)
    end
    tempfile.fdatasync
    tempfile.close
    stat = File.stat(filename)
    FileUtils.chown stat.uid, stat.gid, tempfile.path
    FileUtils.chmod stat.mode, tempfile.path
    FileUtils.mv tempfile.path, filename
  end
end

def setup_repo options

   # Is $REPOROOT defined and is it a valid writable path?
   if ENV.has_key? "REPOROOT"
     unless File.writable? ENV['REPOROOT']
       error "$REPOROOT points to non existant path #{ENV['REPO_ROOT']} or is not writable".colorize("red")
     end
   else
       error "Env var reporoot is not defined.  source env.sh in root of repo".colorize("red")
   end

   logpath="."
   options[:logpath] = logpath

   # Now that we are done cleaning etc, we can setup the proper log
   #'
   options[:prog_name]="make_pll_hal"
   level=:info
   @log = EtLog.new("#{logpath}/#{options[:prog_name]}.log",:info,false,options[:prog_name])
   if options[:verbose]
    level=:debug
   end
   @log.level = level
   @log.info "#{options[:prog_name]} is running"
   @log.info "logpath is #{logpath}/#{options[:prog_name]}.log"
   options[:logfile] = "#{logpath}/#{options[:prog_name]}.log"

   @log.info "command line=#{options[:cmd_line]}"

   options[:git_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse HEAD"
   options[:git_hash].chomp!
   @log.info "git revision=#{options[:git_hash]}"

   options[:git_short_hash],rc = @log.et_backtick "cd ${REPOROOT};git rev-parse --short HEAD"
   options[:git_short_hash].chomp!
   @log.info "git short hash=#{options[:git_short_hash]}"

   #@log.info "Querying git repo for local modifications..."
   #diff,rc =@log.et_backtick "cd ${REPOROOT};git diff"
   #if diff != ""
   #  diff_path="#{logpath}/local_modifications.patch"
   #  f = File.new(diff_path, File::CREAT|File::TRUNC|File::RDWR, 0644)
   #  f.write diff
   #  f.close
   #  @log.warn "There were local modifications so creating patch file #{diff_path}"
   #else
   #  @log.info "Repo is clean there are no modifications"
   #end
end

def find_csv path
  return Dir["#{path}/*.csv"]
end

def parse_csv_list list
  csv_hash=Hash.new
  list.each { |csv_file|
    @log.info "Parsing #{csv_file}"

    csv_file =~ /.*_mode_(\d+)_i(\d+)_o(\d+).*.csv$/
    @log.info "mode=#{$1} iFreq=#{$2} oFreq=#{$3} csv_file=#{csv_file}"
    csv_hash[$1.to_i] = [csv_file,CSV.read(csv_file),$2,$3]
  }
  return csv_hash
end

#
#
# Generate full PLL HAL
#
#
def gen_pll_hal  csv_hash, path, pll_name,ifreq_hash

pll_header_template = <<-EOS_PLL_HEADER
//============================================================================
//
// WARNING: This file is autogenerated please don't edit
// WARNING: This file is autogenerated please don't edit 
//
//============================================================================
#ifndef __MOVELLUS_#{pll_name.upcase}_MODES_CONFIG_H__
#define __MOVELLUS_#{pll_name.upcase}_MODES_CONFIG_H__

#include <stdint.h>

typedef struct #{pll_name.upcase}_MODE_CFG_s {
    uint8_t mode;
    uint8_t count;
    uint32_t input_frequency;  // Frequency in Hertz
    uint32_t output_frequency; // Frequency in Hertz
    const uint8_t offsets[36];
    const uint16_t values[36];
    
} #{pll_name.upcase}_SETTING_t;

static const #{pll_name.upcase}_SETTING_t gs_#{pll_name.downcase}_settings[] = {
EOS_PLL_HEADER

pll_footer_template = <<-EOS_PLL_FOOTER
}; __attribute__ ((aligned (64)))
#endif
EOS_PLL_FOOTER

 # Generate the HAL
 open(path, 'w') do |f|
   f.puts pll_header_template
   hash_size=csv_hash.size
   index=0
   csv_hash.sort.each do |mode,val|

     @log.debug "Generating hal for mode=#{mode} "
     name=val[0]

     filename = File.basename name
     filename =~ /.*_i([\d]+)_o([\d]+)(.*).csv/
     i_freq=$1.to_i * 1000000
     o_freq=$2.to_i * 1000000
     is_dvfs=$3
     iFreq=$1
     @log.info "Mode=#{mode+1} Input Frequency=#{i_freq} Hz Output Frequency=#{o_freq} Hz dvfs=#{is_dvfs}"

     data=val[1];
     len = (data.size) -1
     offsets=""
     values=""
     quick_offsets=""
     quick_values=""
  
     rec=ifreq_hash[iFreq]

     #ap rec ,:raw => true

     for i in 1..len do
       offsets += data[i][0]
       offsets += "," if i != len
       values += data[i][1]
       values += "," if i != len
     end

     if (index != (hash_size-1))
       comma=",\n"
     else
       comma=""
     end
pll_entry_template = <<-EOS_PLL_ENTRY
  {   .mode             = #{mode},
      .count            = #{len},
      .input_frequency  = #{i_freq},
      .output_frequency = #{o_freq},
      .offsets = { #{offsets}
      },
      .values =  { #{values}
      }
  }#{comma}
EOS_PLL_ENTRY

     f.puts pll_entry_template
     index+=1
   end # for each csv file
   f.puts pll_footer_template
 end # end open file handle for hal
end # End method

#
#
#  HAL For DVFS
#
#
def gen_dvfs_hal  csv_hash, path, pll_name,ifreq_hash

  start_freq=0
  second_freq=0
  delta_freq=0
  index=0
  last_dvfs_index=0


  csv_hash.sort.each do |mode,val|
     name=val[0]
     filename = File.basename name
     filename =~ /.*_i([\d]+)_o([\d]+)_dvfs.csv/
     i_freq=$1.to_i * 1000000
     o_freq=$2.to_i * 1000000

     if index == 0 
       start_freq = $2.to_i
     end
     if index == 1
       second_freq = $2.to_i
       delta_freq = second_freq - start_freq
     end
     index +=1
     @log.debug "$1=#{$1} $2=#{$2}"
     if filename =~ /dvfs/
       last_dvfs_index=index
     end
  end

pll_header_template = <<-EOS_PLL_HEADER
//============================================================================
//
// WARNING: This file is autogenerated please don't edit
// WARNING: This file is autogenerated please don't edit 
//
//============================================================================
#ifndef __DVFS_MOVELLUS_#{pll_name.upcase}_MODES_CONFIG_H__
#define __DVFS_MOVELLUS_#{pll_name.upcase}_MODES_CONFIG_H__

#include <stdint.h>

typedef struct et_dvfs_pll_header_t {

const uint16_t start_freq ;     // Initial/Lowest frequency in Mhz
const uint16_t inc_freq ;       // each step freq in Mhz
const uint16_t num_entries;     // Number of entries in the offset array
const uint8_t quick_offsets[8]; // The address offsets that the data values below correspond too

                                // Highest Freq = start_freq + (num_entries*inc_freq)

} et_dvfs_lvdpll_mode_config_t;

typedef struct et_dvfs_#{pll_name.upcase}_MODE_CFG_s {

    const uint16_t quick_values[8];
    
} et_dvfs_#{pll_name.upcase}_SETTING_t;

static const et_dvfs_lvdpll_mode_config_t et_lvdpll_dvfs_mode_config = {

.start_freq = #{start_freq}, // Mhz

.inc_freq   = #{delta_freq}, // Mhz

.num_entries = #{last_dvfs_index}, // # of all entries in the dvfs pll mode table

.quick_offsets = { 0x2,0x3,0xb,0xe,0xf,0x10,0x11,0x20 }

};

static const et_dvfs_#{pll_name.upcase}_SETTING_t et_dvfs_#{pll_name.downcase}_settings[] = {
EOS_PLL_HEADER

pll_footer_template = <<-EOS_PLL_FOOTER
}; __attribute__ ((aligned (64)))
#endif
EOS_PLL_FOOTER


 # Generate the HAL
 open(path, 'w') do |f|
   f.puts pll_header_template
   hash_size=csv_hash.size
   index=0
   csv_hash.sort.each do |mode,val|

     @log.info "Generating hal for mode=#{mode} index=#{index} last_dvfs_index=#{last_dvfs_index} "
     name=val[0]

     filename = File.basename name
     filename =~ /.*_i([\d]+)_o([\d]+)_dvfs.csv/
     i_freq=$1.to_i * 1000000
     o_freq=$2.to_i * 1000000
    
     iFreq=$1
     @log.debug "Mode=#{mode+1} Input Frequency=#{i_freq} Hz Output Frequency=#{o_freq} Hz"

     data=val[1];
     len = (data.size) -1
     offsets=""
     values=""
     quick_offsets=""
     quick_values=""
  
     rec=ifreq_hash[iFreq]
     

     #ap rec ,:raw => true
     unless rec==nil
       for i in 1..len do
         offsets += data[i][0]
         offsets += "," if i != len
         values += data[i][1]
         values += "," if i != len

         if rec.consistent[i] == false
           quick_values += data[i][1]
           quick_values += "," if i != len
         end # end if 
       end # end for 

       if (index != (last_dvfs_index-1))
         comma=",\n"
       else
         comma=""
       end

pll_entry_template = <<-EOS_PLL_ENTRY
  { // #{name}
      .quick_values =  { #{quick_values[0...-1]}
      }
  }#{comma}
EOS_PLL_ENTRY

       f.puts pll_entry_template
       end # if rec == nil 
       index+=1
     end # for each csv file
     f.puts pll_footer_template
 end # end open file handle for hal
end # end method 

#
#
#  HAL For DVFS
#
#
def gen_dvfs_fast_hal  csv_hash, path, pll_name,ifreq_hash

  start_freq=0
  second_freq=0
  delta_freq=0
  index=0
  last_dvfs_index=0


  csv_hash.sort.each do |mode,val|
     name=val[0]
     filename = File.basename name
     filename =~ /.*_i([\d]+)_o([\d]+)_dvfs.csv/
     i_freq=$1.to_i * 1000000
     o_freq=$2.to_i * 1000000

     if index == 0 
       start_freq = $2.to_i
     end
     if index == 1
       second_freq = $2.to_i
       delta_freq = second_freq - start_freq
     end
     index +=1
     @log.debug "$1=#{$1} $2=#{$2}"
     if filename =~ /dvfs/
       last_dvfs_index=index
     end
  end

pll_header_template = <<-EOS_PLL_HEADER
//============================================================================
//
// WARNING: This file is autogenerated please don't edit
// WARNING: This file is autogenerated please don't edit 
//
//============================================================================
#ifndef __DVFS_MOVELLUS_DVFS_FAST_#{pll_name.upcase}_MODES_CONFIG_H__
#define __DVFS_MOVELLUS_DVFS_FAST_#{pll_name.upcase}_MODES_CONFIG_H__

#include <stdint.h>

typedef struct et_dvfs_fast_pll_header_t {

const uint16_t start_freq ;     // Initial/Lowest frequency in Mhz
const uint16_t inc_freq ;       // each step freq in Mhz
const uint16_t num_entries;     // Number of entries in the offset array
const uint8_t quick_offsets[3]; // The address offsets that the data values below correspond too

                                // Highest Freq = start_freq + (num_entries*inc_freq)

} et_dvfs_fast_lvdpll_mode_config_t;

typedef struct et_dvfs_fast_#{pll_name.upcase}_MODE_CFG_s {

    const uint16_t quick_values[3];
    
} et_dvfs_fast_#{pll_name.upcase}_SETTING_t;

static const et_dvfs_fast_lvdpll_mode_config_t et_lvdpll_dvfs_fast_mode_config = {

.start_freq = #{start_freq}, // Mhz

.inc_freq   = #{delta_freq}, // Mhz

.num_entries = #{last_dvfs_index}, // # of all entries in the dvfs pll mode table

.quick_offsets = { 0x2,0x3,0xe }

};

static const et_dvfs_fast_#{pll_name.upcase}_SETTING_t et_dvfs_fast_#{pll_name.downcase}_settings[] = {
EOS_PLL_HEADER

pll_footer_template = <<-EOS_PLL_FOOTER
}; __attribute__ ((aligned (64)))
#endif
EOS_PLL_FOOTER


 # Generate the HAL
 open(path, 'w') do |f|
   f.puts pll_header_template
   hash_size=csv_hash.size
   index=0
   csv_hash.sort.each do |mode,val|

     @log.info "Generating hal for mode=#{mode} index=#{index} last_dvfs_index=#{last_dvfs_index} "
     name=val[0]

     filename = File.basename name
     filename =~ /.*_i([\d]+)_o([\d]+)_dvfs.csv/
     i_freq=$1.to_i * 1000000
     o_freq=$2.to_i * 1000000
    
     iFreq=$1
     @log.debug "Mode=#{mode+1} Input Frequency=#{i_freq} Hz Output Frequency=#{o_freq} Hz"

     data=val[1];
     len = (data.size) -1
     offsets=""
     values=""
     quick_offsets=""
     quick_values=""
  
     rec=ifreq_hash[iFreq]

     #ap rec ,:raw => true
     unless rec==nil
       used=0
       for i in 1..len do
         offsets += data[i][0]
         offsets += "," if i != len
         values += data[i][1]
         values += "," if i != len

         @log.debug "i=#{i} data=#{data[i][0]} data_val=#{data[i][0].to_i(16)} used=#{used} quick_values=#{quick_values}"

         break if used==3
         if [0x2,0x3,0xE].include? data[i][0].to_i(16)
           @log.info "Trigger"
           used += 1
           quick_values += data[i][1]
           quick_values += "," if used != 3
           @log.debug "data=#{data[i][1]} data_val=#{data[i][1].to_i(16)} quick_values=#{quick_values}"

         end # end if 
       end # end for 

       if (index != (last_dvfs_index-1))
         comma=",\n"
       else
         comma=""
       end

pll_entry_template = <<-EOS_PLL_ENTRY
  { // #{name}
      .quick_values =  { #{quick_values}
      }
  }#{comma}
EOS_PLL_ENTRY

       f.puts pll_entry_template
       end # if rec == nil 
       index+=1
     end # for each csv file
     f.puts pll_footer_template
 end # end open file handle for hal
end # end method 



def c_2_sv_hex my_string
  return my_string.gsub "0x","'h"
end

#
#
# System Verilog HAL 
#
#
def gen_sv_hal  csv_hash, path, pll_name,ifreq_hash

pll_header_template = <<-EOS_PLL_HEADER
//============================================================================
//
// WARNING: This file is autogenerated please don't edit
// WARNING: This file is autogenerated please don't edit 
//
//============================================================================

typedef struct {
    string     input_frequency;
    string     output_frequency;
    bit[15:0]  offsets[36];
    bit[15:0]  values[36];
} #{pll_name.downcase}_settings;

#{pll_name.downcase}_settings lvdpll_modes[] = '{
EOS_PLL_HEADER

pll_footer_template = <<-EOS_PLL_FOOTER
}; 
EOS_PLL_FOOTER

 # Generate the HAL
 open(path, 'w') do |f|
   f.puts pll_header_template
   hash_size=csv_hash.size
   index=0
   csv_hash.sort.each do |mode,val|

     @log.debug "Generating hal for mode=#{mode} "
     name=val[0]

     filename = File.basename name
     filename =~ /.*_i([\d]+)_o([\d]+)(.*).csv/
     i_freq=$1.to_i * 1000000
     o_freq=$2.to_i * 1000000
     is_dvfs=$3
     iFreq=$1
     @log.debug "Mode=#{mode+1} Input Frequency=#{i_freq} Hz Output Frequency=#{o_freq} Hz dvfs=#{is_dvfs}"

     data=val[1];
     len = (data.size) -1
     offsets=""
     values=""
     quick_offsets=""
     quick_values=""
  
     rec=ifreq_hash[iFreq]

     #ap rec ,:raw => true

     for i in 1..len do
       offsets += c_2_sv_hex data[i][0]
       offsets += "," if i != len
       values += c_2_sv_hex data[i][1]
       values += "," if i != len
     end

     if (index != (hash_size-1))
       comma="},\n"
     else
       comma="}\n"
     end
pll_entry_template = <<-EOS_PLL_ENTRY
    '{  // #{name}
     "#{i_freq/1000000} Mhz",
     "#{o_freq/1000000} Mhz",
     '{ #{offsets} },
     '{ #{values} }
     #{comma}
EOS_PLL_ENTRY

     f.puts pll_entry_template
     index+=1
   end # for each csv file
   f.puts pll_footer_template
 end # end open file handle for hal
end # End method

begin
   cmd_line="make_pll_hal"
   ARGV.each { |arg| cmd_line += " #{arg}" }

   options = {}
   OptionParser.new do |opts|
     opts.banner = "Usage: gen_bist_br [options]"
     opts.on("-d path","--dir path","Specify path containing PLL CSV's") do |arg|
       options[:csv_dir] = File.expand_path arg
     end
     opts.on("-n name ", "--name name", "PLL Name used in hal generation. ex. HPDPLL,LVDPLL,DLL,etc") do |arg|
       options[:pll_name] = arg
     end
     opts.on("-o filename", "--output filename", "Output name for hal file to generate") do |arg|
       options[:hal_name] = arg
     end
     opts.on("-q", "--quiet", "Quiesce most output") do |arg|
       options[:quiet] = arg
     end
     opts.on("-v", "--verbose", "Verbose output") do |arg|
       options[:verbose] = arg
     end
   end.parse!
   options[:cmd_line]=cmd_line

   unless options[:quiet]
     options[:quiet]=:info
   end

   #
   # Setup the workspace, cleanup, and get the log setup
   #
   setup_repo options
   @log.info "cmd_line=#{cmd_line}"

   require 'socket'
   hostname = Socket.gethostname
   @log.info "running on hostname=#{hostname}"

   ap options      if options[:verbose]
   @log.ap options if options[:verbose]

   unless options[:pll_name]
     options[:pll_name]="HPDPLL"
     @log.info "-n or --name was not specified so using default_name=#{options[:pll_name]}".colorize("yellow")
   end

   unless options[:hal_name]
     options[:hal_name] = "movellus_#{options[:pll_name].downcase}_modes_config.h"
   end
   @log.info "Using output filename=#{options[:hal_name]}".colorize("green")
   @log.info "Looking for CSV's in path=#{options[:csv_dir]}".colorize("yellow")

   csv_list=find_csv options[:csv_dir]
   csv_hash=parse_csv_list    csv_list
    
   started=false
   base=[]
   ifreq_hash = Hash.new

   csv_hash.sort.each do |mode,val|
     oFreq= val[3]   
     iFreq= val[2]
     data = val[1]
     name = val[0] 

     unless ifreq_hash.has_key? iFreq
       ifreq_hash[iFreq] = Ifreq_map.new
     end
     rec = ifreq_hash[iFreq]   

     if !rec.started
       @log.debug "Started name=#{name} mode=#{mode} iFreq=#{iFreq} oFreq=#{oFreq}"
       rec.started=true
       rec.base=val[1]
       for i in 0..(data.size()-1)
         rec.consistent[i] = true
       end
     end

     for i in 1..(data.size()-1)
       @log.debug "mode=#{mode} i=#{i} iFreq=#{iFreq} data_size=#{data.size} base_size=#{rec.base.size}"
       if rec.base[i] != data[i]
         @log.debug "NO DATA MATCH: mode=#{mode} i=#{i} rec.base[i]=#{rec.base[i]} data[i]=#{data[i]} consistent_count=#{rec.consistent.count(false)}"
         rec.consistent[i]=false;  
       else 
         @log.debug "   DATA MATCH: mode=#{mode} i=#{i} rec.base[i]=#{rec.base[i]} data[i]=#{data[i]} consistent_count=#{rec.consistent.count(false)}"
       end
     end

     @log.info "ifreq=#{iFreq} consistent_count=#{rec.consistent.count(false)} consistent=#{rec.consistent}"
   end

   tempfn=options[:hal_name].split "."

   gen_pll_hal  csv_hash, options[:hal_name], options[:pll_name],ifreq_hash
   gen_sv_hal   csv_hash, "#{tempfn[0]}.svh", options[:pll_name],ifreq_hash   
 
   if options[:pll_name].upcase == "LVDPLL"
     @log.info "LVDPLL Detected.  Generating DVFS HAL"
     gen_dvfs_hal      csv_hash, "dvfs_#{options[:hal_name]}", options[:pll_name],ifreq_hash
     gen_dvfs_fast_hal csv_hash, "dvfs_fast_#{options[:hal_name]}", options[:pll_name],ifreq_hash
   end

   @log.info "Successfully generated hal=#{options[:hal_name]}"

rescue Interrupt => e
  @log.info "Interrupt detected (Ctrl-c): #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}"
  exit 1
#rescue Exception => e
#  @log.info "Exception detected : #{e}\nStack Trace Follows\n#{e.backtrace.join("\n")}"
# exit 1
rescue SystemExit => e
  exit e.status
ensure
  @log.close unless @log.nil?
end
