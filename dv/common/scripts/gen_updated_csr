file=DW_apb_i2c
try ipxact_2_csr ../${file}.xml
try sed -i '1s;^;#ifndef _DW_apb_i2c\n#define _DW_apb_i2c\n;'  ${file}.csr
# Many of the SNPS IP Xact have Extra Hierarchy which makes names longer than they need to be
# We use sed to remove these extra layers
try sed -i 's/group {//g' ${file}.csr            # This deletes the first group line
try sed -i '/DW_apb_i2c_addr_block1;/d' ${file}.csr # This deletes the end } for the group
try sed -i '/component {/,$d' ${file}.csr # Remove the component definition
try sed -i 's/} DW_apb_i2c_APB_Slave;/} i2c;/g' ${file}.csr # shorten the name
try sed -i -e '$a#endif' ${file}.csr
try csr_2_dv $file

file=DW_apb_ssi
try ipxact_2_csr ../${file}.xml
try sed -i '1s;^;#ifndef _DW_apb_ssi\n#define _DW_apb_ssi\n;'  ${file}.csr
# Many of the SNPS IP Xact have Extra Hierarchy which makes names longer than they need to be
# We use sed to remove these extra layers
try sed -i 's/group {//g' ${file}.csr
try sed -i '/ssi_address_block;/d' ${file}.csr
try sed -i '/component {/,$d' ${file}.csr # Remove the component definition
try sed -i 's/} DW_apb_ssi_APB_Slave;/} ssi;/g' ${file}.csr # shorten the name
try sed -i -e '$a#endif' ${file}.csr
try csr_2_dv $file


