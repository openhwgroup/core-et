file=ultrasoc_si_base_1024_chan_32
try ipxact_2_csr ../${file}.xml
# Many of the SNPS IP Xact have Extra Hierarchy which makes names longer than they need to be
# We use sed to remove these extra layers
try sed -i '/component {/,$d' ${file}.csr # Remove the component definition
try sed -i 's/} pu_static_Static_Memory_Map;/} pu_static_mem_map;/g' ${file}.csr # shorten the name
try sed -i 's/property size = 20480;//g' ${file}.csr  # FIXME: File bug on SNPS IP-XACT is invalid on size
try sed -i 's/property addressing = "word";/\/\/property addressing = "word";/g' ${file}.csr  # FIXME: File bug on SNPS IP-XACT is invalid on size
try sed -i 's/group {//g' ${file}.csr
try sed -i '/Static_Memory_Map_Address_Block/d' ${file}.csr
try csr_2_dv $file

file=ultrasoc_axi_communicator
try ipxact_2_csr ../${file}.xml
try sed -i '/component {/,$d' ${file}.csr # Remove the component definition
try sed -i 's/} AXICommunicator_AXICommunicatorMemoryMap;/} usoc_axi_comm;/g' ${file}.csr # shorten the name
try csr_2_dv ${file}


