endpackage;

module minion_core_cvg (input clock);
	import minion_core_cov_pkg::*;
	logic             wb_valid;
	logic [31:0]      wb_reg_inst;

	logic [32*4-1:0]  reg_inst;

	cg_instructions cg_instructions_inst;

	assign wb_reg_inst = reg_inst[32*4-1:32*3];
	initial begin
		int value;

		if (`et_value_plusargs("enable_inst_cov=%d", value) == 0) begin
			value = 1;
		end
		if (value != 0) begin
			cg_instructions_inst = new(wb_reg_inst);
			forever @ (posedge clock) begin
				if (wb_valid === 1'b1) begin
					cg_instructions_inst.sample();
				end
				wb_valid    <= intpipe_top.wb_valid;
				reg_inst    <= {reg_inst[32*3-1:0], intpipe_top.id_inst_bits};
			end
		end
	end

endmodule: minion_core_cvg

	bind intpipe_top minion_core_cvg minion_core_cov(.clock(clock));
`endif // __MINION_CORE_CVG

`endif // EVL_COVERAGE_ON

